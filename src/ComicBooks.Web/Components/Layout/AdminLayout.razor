@inherits LayoutComponentBase
@inject ThemeService ThemeSvc
@implements IDisposable

<MudThemeProvider Theme="@ThemeSvc.Theme" IsDarkMode="@_dark" />
<MudPopoverProvider />
<MudDialogProvider FullWidth="true" MaxWidth="MaxWidth.Small" />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Fixed="true">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit"
                       Edge="Edge.Start" OnClick="@(() => _open = !_open)" />
        <MudIcon Icon="@Icons.Material.Filled.AdminPanelSettings" Color="Color.Warning" Class="mr-2" />
        <MudText Typo="Typo.h6" Style="font-weight:800;">Admin panel</MudText>
        <MudSpacer />
        <MudIconButton Icon="@(_dark ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                       Color="Color.Inherit" OnClick="@ToggleTheme"
                       Title="@(_dark ? "Yorug' rejim" : "Tungi rejim")" />
        <MudButton Href="/" Variant="Variant.Text" Color="Color.Inherit"
                   StartIcon="@Icons.Material.Filled.ArrowBack"
                   Style="text-transform:none;">Saytga qaytish</MudButton>
    </MudAppBar>

    <MudDrawer @bind-Open="_open" Elevation="2"
               Variant="@DrawerVariant.Responsive"
               ClipMode="DrawerClipMode.Always">
        <MudDrawerHeader>
            <MudText Style="color:#7c3aed; font-weight:900; font-size:1rem;">⚙️ Admin panel</MudText>
        </MudDrawerHeader>
        <MudNavMenu>
            <MudNavLink Href="/admin"          Match="NavLinkMatch.All"    Icon="@Icons.Material.Filled.Dashboard">Boshqaruv paneli</MudNavLink>
            <MudNavLink Href="/admin/comics"   Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.MenuBook">Komiklar</MudNavLink>
            <MudNavLink Href="/admin/chapters" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.AutoStories">Boblar</MudNavLink>
            <MudNavLink Href="/admin/genres"   Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Label">Janrlar & Teglar</MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent Class="pt-16">
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _open = true;
    private bool _dark = true;

    protected override void OnInitialized()
    {
        _dark = ThemeSvc.IsDarkMode;
        ThemeSvc.ThemeChanged += OnThemeChanged;
    }

    private void ToggleTheme() => ThemeSvc.Toggle();
    private void OnThemeChanged(bool isDark) { _dark = isDark; InvokeAsync(StateHasChanged); }
    public void Dispose() => ThemeSvc.ThemeChanged -= OnThemeChanged;
}
