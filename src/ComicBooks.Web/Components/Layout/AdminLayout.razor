@inherits LayoutComponentBase
@inject ThemeService Theme
@implements IDisposable

<MudThemeProvider @ref="_themeProvider" Theme="@_theme" @bind-IsDarkMode="_dark" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Fixed="true">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit"
                       Edge="Edge.Start" OnClick="@(() => _open = !_open)" />
        <MudText Typo="Typo.h6" Style="font-weight:800;">⚙️ Admin panel</MudText>
        <MudSpacer />
        <MudIconButton Icon="@(_dark ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                       Color="Color.Inherit" OnClick="@ToggleTheme" />
        <MudButton Href="/" Variant="Variant.Text" Color="Color.Inherit" Style="text-transform:none;">← Sayt</MudButton>
    </MudAppBar>

    <MudDrawer @bind-Open="_open" Variant="DrawerVariant.Responsive" ClipMode="DrawerClipMode.Always" Elevation="2">
        <MudDrawerHeader>
            <MudText Style="color:#7c3aed;font-weight:800;">⚙️ Admin</MudText>
        </MudDrawerHeader>
        <MudNavMenu>
            <MudNavLink Href="/admin"                Match="NavLinkMatch.All"    Icon="@Icons.Material.Filled.Dashboard">Boshqaruv paneli</MudNavLink>
            <MudNavLink Href="/admin/comics"         Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.MenuBook">Komiklar</MudNavLink>
            <MudNavLink Href="/admin/chapters"       Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.AutoStories">Boblar</MudNavLink>
            <MudNavLink Href="/admin/chapter-pricing" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Lock">Bob narxlari</MudNavLink>
            <MudNavLink Href="/admin/genres"         Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Label">Janrlar & Teglar</MudNavLink>
            <MudDivider Class="my-2" />
            <MudNavGroup Title="🪙 Coin boshqaruvi" Icon="@Icons.Material.Filled.MonetizationOn" Expanded="true">
                <MudNavLink Href="/admin/coins"          Match="NavLinkMatch.All"    Icon="@Icons.Material.Filled.People">Foydalanuvchi coinlar</MudNavLink>
                <MudNavLink Href="/admin/coin-packages"  Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Inventory">Coin paketlari</MudNavLink>
            </MudNavGroup>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent Class="pt-16">
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    MudThemeProvider _themeProvider = null!;
    bool _open = true;
    bool _dark = true;

    readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#7c3aed", Background = "#f3f4f6", Surface = "#ffffff",
            AppbarBackground = "#ffffff", AppbarText = "#111827",
            DrawerBackground = "#f9f9fb", DrawerText = "#111827", TextPrimary = "#111827"
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#7c3aed", Background = "#0f0f1a", Surface = "#1a1a2e",
            AppbarBackground = "#16213e", AppbarText = "#e5e7eb",
            DrawerBackground = "#16213e", DrawerText = "#e5e7eb",
            TextPrimary = "#f9fafb", TextSecondary = "#9ca3af"
        }
    };

    protected override void OnInitialized()
    {
        _dark = Theme.IsDark;
        Theme.OnChange += OnThemeChanged;
    }

    async void ToggleTheme()
    {
        Theme.Toggle();
        _dark = Theme.IsDark;
        await InvokeAsync(StateHasChanged);
    }

    async void OnThemeChanged()
    {
        _dark = Theme.IsDark;
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose() => Theme.OnChange -= OnThemeChanged;
}
