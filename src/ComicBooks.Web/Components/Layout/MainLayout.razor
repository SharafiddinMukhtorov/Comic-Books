@inherits LayoutComponentBase
@inject ThemeService Theme
@inject NavigationManager Nav
@implements IDisposable

<MudThemeProvider @ref="_tp" Theme="@_theme" @bind-IsDarkMode="_dark" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="0" Fixed="true" Style="background:#7c3aed !important;">
        <!-- Logo icon -->
        <div style="width:40px;height:40px;background:rgba(0,0,0,0.25);border-radius:50%;
                    display:flex;align-items:center;justify-content:center;margin-right:16px;flex-shrink:0;">
            <MudIcon Icon="@Icons.Material.Filled.MenuBook" Style="color:#fff;font-size:22px;" />
        </div>

        <MudHidden Breakpoint="Breakpoint.SmAndDown">
            <MudButton Href="/"          Color="Color.Inherit" Variant="Variant.Text" Style="text-transform:none;font-weight:600;font-size:15px;color:#fff;">Home</MudButton>
            <MudButton Href="/bookmarks" Color="Color.Inherit" Variant="Variant.Text" Style="text-transform:none;font-weight:600;font-size:15px;color:#fff;">Bookmarks</MudButton>
            <MudButton Href="/comics"    Color="Color.Inherit" Variant="Variant.Text" Style="text-transform:none;font-weight:600;font-size:15px;color:#fff;">Browse</MudButton>
        </MudHidden>

        <MudSpacer />

        <!-- Search bar -->
        <MudHidden Breakpoint="Breakpoint.SmAndDown">
            <div style="background:rgba(255,255,255,0.15);border-radius:8px;
                        display:flex;align-items:center;padding:6px 14px;gap:8px;width:220px;">
                <MudIcon Icon="@Icons.Material.Filled.Search" Style="color:rgba(255,255,255,0.7);font-size:18px;" />
                <input @bind="_q" @bind:event="oninput" @onkeydown="@OnSearch"
                       placeholder="Search..."
                       style="background:transparent;border:none;outline:none;
                              color:#fff;font-size:14px;width:100%;" />
            </div>
        </MudHidden>

        <!-- Dark mode -->
        <MudIconButton Icon="@(_dark ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                       Color="Color.Inherit" OnClick="@ToggleTheme" Class="ml-2" Style="color:#fff;" />

        <!-- Log In button -->
        <MudButton Href="/login" Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.Login"
                   Size="Size.Small" Class="ml-2"
                   Style="border-radius:8px;text-transform:none;font-weight:700;
                          background:rgba(255,255,255,0.2);color:#fff;border:1px solid rgba(255,255,255,0.3);">
            Log In
        </MudButton>

        <MudHidden Breakpoint="Breakpoint.MdAndUp">
            <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit"
                           OnClick="@(() => _open = !_open)" Style="color:#fff;" />
        </MudHidden>
    </MudAppBar>

    <MudDrawer @bind-Open="_open" Anchor="Anchor.Right" Variant="DrawerVariant.Temporary" Elevation="4">
        <MudDrawerHeader>
            <MudText Style="font-weight:900;font-size:1.1rem;color:#7c3aed;">AsuraComic</MudText>
        </MudDrawerHeader>
        <div style="padding:0 12px 8px;">
            <input @bind="_q" @bind:event="oninput" @onkeydown="@OnSearch"
                   placeholder="Search..."
                   style="width:100%;padding:8px 12px;border-radius:8px;border:1px solid rgba(128,128,128,0.3);
                          background:transparent;outline:none;font-size:14px;" />
        </div>
        <MudNavMenu>
            <MudNavLink Href="/"          Match="NavLinkMatch.All"    Icon="@Icons.Material.Filled.Home"               OnClick="@Close">Home</MudNavLink>
            <MudNavLink Href="/bookmarks" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Bookmark"           OnClick="@Close">Bookmarks</MudNavLink>
            <MudNavLink Href="/comics"    Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.MenuBook"           OnClick="@Close">Browse</MudNavLink>
            <MudDivider />
            <MudNavLink Href="/admin"     Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.AdminPanelSettings" OnClick="@Close">Admin</MudNavLink>
            <MudNavLink Href="/login"     Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Login"              OnClick="@Close">Log In</MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent Style="padding-top:64px;min-height:100vh;">
        @Body
    </MudMainContent>
</MudLayout>

@code {
    MudThemeProvider _tp = null!;
    bool _dark = true;
    bool _open;
    string _q = "";

    readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary           = "#7c3aed",
            Secondary         = "#5b21b6",
            Background        = "#f4f4f8",
            Surface           = "#ffffff",
            AppbarBackground  = "#7c3aed",
            AppbarText        = "#ffffff",
            DrawerBackground  = "#ffffff",
            DrawerText        = "#1f1f2e",
            TextPrimary       = "#1a1a2e",
            TextSecondary     = "#6b7280",
            ActionDefault     = "#374151",
            LinesDefault      = "rgba(0,0,0,0.08)",
        },
        PaletteDark = new PaletteDark
        {
            Primary           = "#7c3aed",
            Secondary         = "#5b21b6",
            Background        = "#0d0d18",
            Surface           = "#16162a",
            AppbarBackground  = "#7c3aed",
            AppbarText        = "#ffffff",
            DrawerBackground  = "#111120",
            DrawerText        = "#e2e2f0",
            TextPrimary       = "#f0f0f8",
            TextSecondary     = "#9ca3af",
            ActionDefault     = "#d1d5db",
            LinesDefault      = "rgba(255,255,255,0.08)",
        }
    };

    protected override void OnInitialized() { _dark = Theme.IsDark; Theme.OnChange += Refresh; }
    async void ToggleTheme() { Theme.Toggle(); _dark = Theme.IsDark; await InvokeAsync(StateHasChanged); }
    async void Refresh()     { _dark = Theme.IsDark; await InvokeAsync(StateHasChanged); }
    void Close() => _open = false;

    void OnSearch(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_q))
        {
            Nav.NavigateTo($"/comics?search={Uri.EscapeDataString(_q)}");
            _open = false; _q = "";
        }
    }

    public void Dispose() => Theme.OnChange -= Refresh;
}
