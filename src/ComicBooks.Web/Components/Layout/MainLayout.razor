@inherits LayoutComponentBase
@inject ThemeService ThemeSvc
@inject NavigationManager Nav
@implements IDisposable

<MudThemeProvider Theme="@ThemeSvc.Theme" IsDarkMode="@_dark" />
<MudPopoverProvider />
<MudDialogProvider FullWidth="true" MaxWidth="MaxWidth.Small" />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="2" Fixed="true" Dense="false">
        <!-- Logo -->
        <MudLink Href="/" Underline="Underline.None">
            <span style="font-weight:900; font-size:1.25rem; color:#7c3aed; letter-spacing:-0.5px;">
                📚 AsuraComic
            </span>
        </MudLink>

        <!-- Desktop nav -->
        <MudHidden Breakpoint="Breakpoint.SmAndDown">
            <MudButton Href="/"         Color="Color.Inherit" Variant="Variant.Text" Class="ml-3" Style="text-transform:none; font-weight:600;">Bosh sahifa</MudButton>
            <MudButton Href="/bookmarks" Color="Color.Inherit" Variant="Variant.Text" Style="text-transform:none; font-weight:600;">Saralganlar</MudButton>
            <MudButton Href="/comics"   Color="Color.Inherit" Variant="Variant.Text" Style="text-transform:none; font-weight:600;">Komiklar</MudButton>
            <MudButton Href="/genres"   Color="Color.Inherit" Variant="Variant.Text" Style="text-transform:none; font-weight:600;">Janrlar</MudButton>
        </MudHidden>

        <MudSpacer />

        <!-- Search -->
        <MudHidden Breakpoint="Breakpoint.SmAndDown">
            <MudTextField @bind-Value="_q"
                          Placeholder="Qidirish..."
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Style="width:220px;"
                          OnKeyDown="@OnSearch" />
        </MudHidden>

        <!-- Theme toggle -->
        <MudIconButton Icon="@(_dark ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                       Color="Color.Inherit"
                       OnClick="@ToggleTheme"
                       Class="ml-1"
                       Title="@(_dark ? "Yorug' rejim" : "Tungi rejim")" />

        <!-- Admin -->
        <MudHidden Breakpoint="Breakpoint.SmAndDown">
            <MudButton Href="/admin" Variant="Variant.Outlined" Color="Color.Primary"
                       Size="Size.Small" Class="ml-2"
                       Style="border-radius:20px; text-transform:none; font-weight:700;">
                Admin
            </MudButton>
        </MudHidden>

        <!-- Mobile menu -->
        <MudHidden Breakpoint="Breakpoint.MdAndUp">
            <MudIconButton Icon="@Icons.Material.Filled.Menu"
                           Color="Color.Inherit"
                           OnClick="@(() => _drawer = !_drawer)" />
        </MudHidden>
    </MudAppBar>

    <!-- Mobile drawer -->
    <MudDrawer @bind-Open="_drawer" Anchor="Anchor.Right"
               Variant="DrawerVariant.Temporary" Elevation="4">
        <MudDrawerHeader>
            <MudText Style="font-weight:900; color:#7c3aed; font-size:1.1rem;">📚 AsuraComic</MudText>
        </MudDrawerHeader>
        <div style="padding:0 12px 12px;">
            <MudTextField @bind-Value="_q" Placeholder="Qidirish..."
                          Variant="Variant.Outlined" Margin="Margin.Dense"
                          FullWidth="true" OnKeyDown="@OnSearch"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search" />
        </div>
        <MudNavMenu>
            <MudNavLink Href="/"          Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home"         OnClick="@CloseDrawer">Bosh sahifa</MudNavLink>
            <MudNavLink Href="/bookmarks" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Bookmark"   OnClick="@CloseDrawer">Saralganlar</MudNavLink>
            <MudNavLink Href="/comics"    Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.MenuBook"   OnClick="@CloseDrawer">Komiklar</MudNavLink>
            <MudNavLink Href="/genres"    Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Label"      OnClick="@CloseDrawer">Janrlar</MudNavLink>
            <MudDivider Class="my-2" />
            <MudNavLink Href="/admin"     Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.AdminPanelSettings" OnClick="@CloseDrawer">Admin panel</MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent Style="padding-top:64px; min-height:100vh;">
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private bool _dark = true;
    private bool _drawer;
    private string _q = "";

    protected override void OnInitialized()
    {
        _dark = ThemeSvc.IsDarkMode;
        ThemeSvc.ThemeChanged += OnThemeChanged;
    }

    private void ToggleTheme()
    {
        ThemeSvc.Toggle();
        // _dark is updated via event
    }

    private void OnThemeChanged(bool isDark)
    {
        _dark = isDark;
        InvokeAsync(StateHasChanged);
    }

    private void CloseDrawer() => _drawer = false;

    private void OnSearch(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_q))
        {
            Nav.NavigateTo($"/comics?search={Uri.EscapeDataString(_q)}");
            _drawer = false;
            _q = "";
        }
    }

    public void Dispose() => ThemeSvc.ThemeChanged -= OnThemeChanged;
}
