@inherits LayoutComponentBase
@inject ThemeService Theme
@inject NavigationManager Nav
@implements IDisposable

<MudThemeProvider @ref="_themeProvider" Theme="@_theme" @bind-IsDarkMode="_dark" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="2" Fixed="true">
        <MudLink Href="/" Underline="Underline.None">
            <MudText Style="font-weight:900;font-size:1.2rem;color:#7c3aed;">📚 AsuraComic</MudText>
        </MudLink>

        <MudHidden Breakpoint="Breakpoint.SmAndDown">
            <MudButton Href="/"          Color="Color.Inherit" Variant="Variant.Text" Class="ml-3" Style="text-transform:none;">Bosh sahifa</MudButton>
            <MudButton Href="/bookmarks" Color="Color.Inherit" Variant="Variant.Text" Style="text-transform:none;">Saralganlar</MudButton>
            <MudButton Href="/comics"    Color="Color.Inherit" Variant="Variant.Text" Style="text-transform:none;">Komiklar</MudButton>
            <MudButton Href="/genres"    Color="Color.Inherit" Variant="Variant.Text" Style="text-transform:none;">Janrlar</MudButton>
        </MudHidden>

        <MudSpacer />

        <MudHidden Breakpoint="Breakpoint.SmAndDown">
            <MudTextField @bind-Value="_q" Placeholder="Qidirish..." Variant="Variant.Outlined"
                          Margin="Margin.Dense" Style="width:200px;"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          OnKeyDown="@OnSearch" />
        </MudHidden>

        <MudIconButton Icon="@(_dark ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                       Color="Color.Inherit" OnClick="@ToggleTheme" Class="ml-1" />

        <MudHidden Breakpoint="Breakpoint.SmAndDown">
            <MudButton Href="/admin" Variant="Variant.Outlined" Color="Color.Primary"
                       Size="Size.Small" Class="ml-2" Style="text-transform:none;">Admin</MudButton>
        </MudHidden>

        <MudHidden Breakpoint="Breakpoint.MdAndUp">
            <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit"
                           OnClick="@(() => _open = !_open)" />
        </MudHidden>
    </MudAppBar>

    <MudDrawer @bind-Open="_open" Anchor="Anchor.Right" Variant="DrawerVariant.Temporary">
        <MudDrawerHeader>
            <MudText Style="font-weight:900;color:#7c3aed;">📚 AsuraComic</MudText>
        </MudDrawerHeader>
        <MudTextField @bind-Value="_q" Placeholder="Qidirish..." Variant="Variant.Outlined"
                      Margin="Margin.Dense" Class="mx-3 mb-2" OnKeyDown="@OnSearch" />
        <MudNavMenu>
            <MudNavLink Href="/"          Match="NavLinkMatch.All"    Icon="@Icons.Material.Filled.Home"               OnClick="@(() => _open=false)">Bosh sahifa</MudNavLink>
            <MudNavLink Href="/bookmarks" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Bookmark"           OnClick="@(() => _open=false)">Saralganlar</MudNavLink>
            <MudNavLink Href="/comics"    Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.MenuBook"           OnClick="@(() => _open=false)">Komiklar</MudNavLink>
            <MudNavLink Href="/genres"    Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Label"              OnClick="@(() => _open=false)">Janrlar</MudNavLink>
            <MudDivider />
            <MudNavLink Href="/admin"     Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.AdminPanelSettings" OnClick="@(() => _open=false)">Admin</MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent Style="padding-top:64px;">
        @Body
    </MudMainContent>
</MudLayout>

@code {
    MudThemeProvider _themeProvider = null!;
    bool _dark = true;
    bool _open;
    string _q = "";

    readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#7c3aed", Background = "#f3f4f6", Surface = "#ffffff",
            AppbarBackground = "#ffffff", AppbarText = "#111827",
            DrawerBackground = "#f9f9fb", DrawerText = "#111827", TextPrimary = "#111827"
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#7c3aed", Background = "#0f0f1a", Surface = "#1a1a2e",
            AppbarBackground = "#16213e", AppbarText = "#e5e7eb",
            DrawerBackground = "#16213e", DrawerText = "#e5e7eb",
            TextPrimary = "#f9fafb", TextSecondary = "#9ca3af"
        }
    };

    protected override void OnInitialized()
    {
        _dark = Theme.IsDark;
        Theme.OnChange += OnThemeChanged;
    }

    async void ToggleTheme()
    {
        Theme.Toggle();
        _dark = Theme.IsDark;
        await InvokeAsync(StateHasChanged);
    }

    async void OnThemeChanged()
    {
        _dark = Theme.IsDark;
        await InvokeAsync(StateHasChanged);
    }

    void OnSearch(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_q))
        {
            Nav.NavigateTo($"/comics?search={Uri.EscapeDataString(_q)}");
            _open = false;
            _q = "";
        }
    }

    public void Dispose() => Theme.OnChange -= OnThemeChanged;
}
