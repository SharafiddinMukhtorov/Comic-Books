<Router AppAssembly="typeof(App).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="routeData" DefaultLayout="typeof(Layout.MainLayout)" />
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
    <NotFound>
        <PageTitle>404 - Topilmadi</PageTitle>
        <LayoutView Layout="typeof(Layout.MainLayout)">
            <MudContainer Class="text-center py-16">
                <MudText Typo="Typo.h1" Color="Color.Primary">404</MudText>
                <MudText Typo="Typo.h5" Class="mt-4">Sahifa topilmadi</MudText>
                <MudButton Href="/" Variant="Variant.Filled" Color="Color.Primary" Class="mt-6" Style="text-transform:none;">
                    Bosh sahifaga qaytish
                </MudButton>
            </MudContainer>
        </LayoutView>
    </NotFound>
</Router>
