@page "/bookmarks"
@rendermode InteractiveServer
@inject BookmarkService BookmarkSvc
@inject IMediator Mediator
@implements IDisposable

<PageTitle>Saralganlar - AsuraComic</PageTitle>

<div style="max-width:1400px; margin:0 auto; padding:24px 16px 48px;">
    <div style="display:flex; align-items:center; gap:12px; margin-bottom:24px;">
        <MudIcon Icon="@Icons.Material.Filled.Bookmark" Color="Color.Primary" Style="font-size:32px;" />
        <MudText Typo="Typo.h4" Class="font-bold">Mening saralganlarim</MudText>
    </div>

    @if (_loading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
    }
    else if (!_list.Any())
    {
        <MudPaper Elevation="1" Class="pa-12 text-center" Style="border-radius:16px;">
            <MudIcon Icon="@Icons.Material.Outlined.BookmarkBorder" Style="font-size:72px; opacity:0.25;" />
            <MudText Typo="Typo.h6" Class="mt-4" Style="opacity:0.5;">Hali saralganlar yo'q</MudText>
            <MudText Typo="Typo.body2" Style="opacity:0.35;" Class="mt-2">
                Komiklar kartasidagi 🔖 tugmasini bosib saralang
            </MudText>
            <MudButton Href="/comics" Variant="Variant.Filled" Color="Color.Primary"
                       Class="mt-6" Style="border-radius:20px; text-transform:none;">
                Komiklar ko'rish
            </MudButton>
        </MudPaper>
    }
    else
    {
        <MudText Typo="Typo.body2" Style="opacity:0.5;" Class="mb-4">
            @_list.Count ta saralgan
        </MudText>
        <MudGrid Spacing="2">
            @foreach (var c in _list)
            {
                <MudItem xs="6" sm="4" md="3" lg="2">
                    <ComicCard Comic="c" />
                </MudItem>
            }
        </MudGrid>
    }
</div>

@code {
    private List<ComicDto> _list = new();
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        BookmarkSvc.OnChanged += Refresh;
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        var ids = BookmarkSvc.GetAll();
        if (!ids.Any()) { _loading = false; return; }
        var all = await Mediator.Send(new GetComicsQuery(PageSize: 200));
        _list = all.Items.Where(c => ids.Contains(c.Id)).ToList();
        _loading = false;
    }

    private void Refresh() => InvokeAsync(async () => { await LoadData(); StateHasChanged(); });
    public void Dispose() => BookmarkSvc.OnChanged -= Refresh;
}
