@page "/"
@inject IMediator Mediator
@inject NavigationManager Nav

<PageTitle>AsuraComic - Read Manhwa Online</PageTitle>

@if (_loading)
{
    <div style="display:flex;justify-content:center;align-items:center;height:80vh;">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
    </div>
}
else
{
    <!-- ═══ HERO SECTION ═══ -->
    <!-- Fixed height container so cards are always visible -->
    <div style="position:relative;height:340px;background:#0d0d18;overflow:hidden;">

        <!-- Blur background - changes with selected hero -->
        <div style="position:absolute;inset:0;z-index:0;">
            @if (_hero != null)
            {
                <img src="@BgOf(_hero)"
                     style="width:100%;height:100%;object-fit:cover;
                            filter:blur(32px) brightness(0.18) saturate(2);
                            transform:scale(1.15);" />
            }
            <!-- Dark overlay -->
            <div style="position:absolute;inset:0;
                        background:linear-gradient(to bottom,rgba(13,13,24,0.4) 0%,rgba(13,13,24,0.96) 100%);"></div>
        </div>

        <!-- Cards centered row -->
        <div style="position:absolute;inset:0;z-index:1;
                    display:flex;align-items:flex-end;justify-content:center;
                    padding:0 24px;gap:10px;overflow-x:auto;
                    scrollbar-width:none;-webkit-overflow-scrolling:touch;">

            @{ var featList = _featured?.Items ?? new(); }
            @foreach (var c in featList)
            {
                bool active = _hero?.Id == c.Id;
                <div @onclick="@(() => SetHero(c))"
                     style="flex:0 0 auto;cursor:pointer;transition:all 0.3s;
                            @(active
                                ? "width:190px;transform:translateY(-12px);"
                                : "width:120px;opacity:0.5;transform:translateY(0);")">
                    <div style="border-radius:10px;overflow:hidden;aspect-ratio:2/3;
                                box-shadow:@(active ? "0 20px 50px rgba(0,0,0,0.7)" : "0 4px 16px rgba(0,0,0,0.4)");">
                        <img src="@(c.CoverImageUrl ?? $"https://picsum.photos/seed/{c.Slug}/300/450")"
                             style="width:100%;height:100%;object-fit:cover;display:block;"
                             onerror="this.onerror=null;this.src='https://picsum.photos/seed/@(c.Slug)/300/450'" />
                    </div>
                    @if (active)
                    {
                        <div style="text-align:center;padding:6px 4px 0;">
                            <div style="font-size:12px;font-weight:700;color:#fff;
                                        white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                                @c.Title
                            </div>
                            <div style="font-size:11px;color:#f59e0b;font-weight:700;">★ @c.AverageRating.ToString("F1")</div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <!-- ═══ MAIN BODY ═══ -->
    <div style="max-width:1280px;margin:0 auto;padding:28px 20px 60px;">

        <!-- Trending Today -->
        <div style="margin-bottom:36px;">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
                <span style="font-size:1.1rem;font-weight:800;">Trending Today</span>
                <MudLink Href="/comics?sortBy=views" Underline="Underline.None"
                         Style="font-size:13px;color:#7c3aed;font-weight:600;">View All →</MudLink>
            </div>
            <div style="display:flex;gap:12px;overflow-x:auto;padding-bottom:8px;
                        scrollbar-width:thin;scrollbar-color:#7c3aed transparent;">
                @foreach (var c in _trending?.Items ?? new())
                {
                    <div style="flex:0 0 140px;">
                        <ComicCard Comic="c" />
                    </div>
                }
                <div style="flex:0 0 44px;display:flex;align-items:center;justify-content:center;cursor:pointer;"
                     @onclick="@(() => Nav.NavigateTo("/comics?sortBy=views"))">
                    <div style="width:36px;height:36px;border-radius:50%;
                                background:rgba(124,58,237,0.15);
                                display:flex;align-items:center;justify-content:center;">
                        <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Style="color:#7c3aed;" />
                    </div>
                </div>
            </div>
        </div>

        <!-- Latest Updates (2-col) + Popular sidebar -->
        <div style="display:grid;grid-template-columns:1fr 300px;gap:32px;">

            <!-- Latest Updates -->
            <div>
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;">
                    <span style="font-size:1.1rem;font-weight:800;">Latest Updates</span>
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:0;">
                    @foreach (var c in _latest?.Items ?? new())
                    {
                        <MudLink Href="@($"/comic/{c.Slug}")" Underline="Underline.None" Color="Color.Default">
                            <div @onmouseover="@(()=>_latestHover=c.Id)"
                                 @onmouseout="@(()=>_latestHover=Guid.Empty)"
                                 style="display:flex;gap:10px;padding:10px 8px;cursor:pointer;
                                        border-bottom:1px solid rgba(128,128,128,0.1);
                                        transition:background 0.15s;
                                        background:@(_latestHover==c.Id ? "rgba(124,58,237,0.06)" : "transparent");">
                                <img src="@(c.CoverImageUrl ?? $"https://picsum.photos/seed/{c.Slug}/80/110")"
                                     style="width:60px;height:84px;object-fit:cover;border-radius:6px;flex-shrink:0;"
                                     onerror="this.onerror=null;this.src='https://picsum.photos/seed/@(c.Slug)l/80/110'" />
                                <div style="flex:1;min-width:0;">
                                    <div style="font-weight:700;font-size:13px;margin-bottom:5px;
                                                overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                                        @c.Title
                                    </div>
                                    @if (c.LatestChapterNumber.HasValue)
                                    {
                                        <div style="font-size:12px;opacity:0.75;margin-bottom:2px;
                                                    display:flex;justify-content:space-between;">
                                            <span>Chapter @((int)c.LatestChapterNumber.Value)</span>
                                            <span style="opacity:0.45;font-size:11px;">@FmtDate(c.CreatedAt)</span>
                                        </div>
                                        @if (c.LatestChapterNumber.Value >= 2)
                                        {
                                            <div style="font-size:12px;color:#7c3aed;margin-bottom:2px;
                                                        display:flex;justify-content:space-between;">
                                                <span>Chapter @((int)c.LatestChapterNumber.Value - 1)</span>
                                                <span style="opacity:0.4;font-size:11px;">last week</span>
                                            </div>
                                        }
                                        @if (c.LatestChapterNumber.Value >= 3)
                                        {
                                            <div style="font-size:12px;opacity:0.5;
                                                        display:flex;justify-content:space-between;">
                                                <span>Chapter @((int)c.LatestChapterNumber.Value - 2)</span>
                                                <span style="opacity:0.4;font-size:11px;">2 weeks ago</span>
                                            </div>
                                        }
                                    }
                                </div>
                            </div>
                        </MudLink>
                    }
                </div>
            </div>

            <!-- Popular sidebar -->
            <div>
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;flex-wrap:wrap;gap:4px;">
                    <span style="font-size:1.1rem;font-weight:800;">Popular</span>
                    <div style="display:flex;gap:4px;">
                        <button @onclick="@(()=>_tab=0)" style="@TabBtn(_tab==0)">Weekly</button>
                        <button @onclick="@(()=>_tab=1)" style="@TabBtn(_tab==1)">Monthly</button>
                        <button @onclick="@(()=>_tab=2)" style="@TabBtn(_tab==2)">All Time</button>
                    </div>
                </div>
                @{ int rk = 0; }
                @foreach (var c in TabList())
                {
                    int r = ++rk;
                    <MudLink Href="@($"/comic/{c.Slug}")" Underline="Underline.None" Color="Color.Default">
                        <div style="display:flex;gap:10px;align-items:center;padding:8px 0;
                                    border-bottom:1px solid rgba(128,128,128,0.08);cursor:pointer;">
                            <div style="@RankStyle(r);width:22px;height:22px;border-radius:6px;
                                        display:flex;align-items:center;justify-content:center;
                                        font-size:11px;font-weight:900;flex-shrink:0;">@r</div>
                            <img src="@(c.CoverImageUrl ?? $"https://picsum.photos/seed/{c.Slug}/44/60")"
                                 style="width:44px;height:60px;object-fit:cover;border-radius:5px;flex-shrink:0;"
                                 onerror="this.onerror=null;this.src='https://picsum.photos/seed/@(c.Slug)r/44/60'" />
                            <div style="flex:1;min-width:0;">
                                <div style="font-size:13px;font-weight:700;overflow:hidden;
                                            text-overflow:ellipsis;white-space:nowrap;margin-bottom:2px;">
                                    @c.Title
                                </div>
                                <div style="font-size:11px;opacity:0.4;margin-bottom:3px;
                                            overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                                    @string.Join(", ", c.Genres.Take(2))
                                </div>
                                <div style="display:flex;gap:1px;align-items:center;">
                                    @for (int s = 1; s <= 5; s++)
                                    {
                                        <span style="color:@(s <= Math.Round(c.AverageRating/2.0) ? "#f59e0b" : "rgba(128,128,128,0.25)");font-size:11px;">★</span>
                                    }
                                    <span style="font-size:11px;font-weight:700;color:#f59e0b;margin-left:3px;">
                                        @c.AverageRating.ToString("F1")
                                    </span>
                                </div>
                            </div>
                        </div>
                    </MudLink>
                }
            </div>
        </div>
    </div>
}

@code {
    PaginatedList<ComicDto>? _featured, _trending, _popular, _latest;
    bool      _loading     = true;
    int       _tab         = 0;
    ComicDto? _hero;
    Guid      _latestHover;

    protected override async Task OnInitializedAsync()
    {
        _featured = await Mediator.Send(new GetComicsQuery(PageSize:12, IsFeatured:true,  SortBy:"rating"));
        _trending = await Mediator.Send(new GetComicsQuery(PageSize:8,  SortBy:"views"));
        _popular  = await Mediator.Send(new GetComicsQuery(PageSize:10, IsPopular:true,   SortBy:"rating"));
        _latest   = await Mediator.Send(new GetComicsQuery(PageSize:12, SortBy:"createdAt"));

        // Default active hero = middle of featured list
        var list = _featured?.Items ?? new();
        _hero = list.Count > 0 ? list[list.Count / 2] : null;
        _loading = false;
    }

    void SetHero(ComicDto c) => _hero = c;

    string BgOf(ComicDto c)
    {
        if (!string.IsNullOrEmpty(c.BannerImageUrl)) return c.BannerImageUrl;
        if (!string.IsNullOrEmpty(c.CoverImageUrl))  return c.CoverImageUrl;
        return $"https://picsum.photos/seed/{c.Slug}bg/1400/500";
    }

    List<ComicDto> TabList() => (_tab == 0 ? _trending?.Items : _popular?.Items) ?? new();

    string FmtDate(DateTime d)
    {
        var diff = DateTime.UtcNow - d;
        if (diff.TotalHours  < 1)  return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours  < 24) return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays   < 7)  return $"{(int)diff.TotalDays} days ago";
        if (diff.TotalDays   < 30) return $"{(int)(diff.TotalDays/7)} weeks ago";
        return d.ToString("MMM d");
    }

    string TabBtn(bool on) => on
        ? "background:#7c3aed;color:#fff;font-size:11px;font-weight:700;padding:3px 8px;border-radius:20px;border:none;cursor:pointer;"
        : "background:transparent;color:inherit;font-size:11px;padding:3px 8px;border-radius:20px;border:1px solid rgba(128,128,128,0.3);cursor:pointer;opacity:0.65;";

    string RankStyle(int r) => r switch {
        1 => "background:#f59e0b;color:#000;",
        2 => "background:#9ca3af;color:#000;",
        3 => "background:#b45309;color:#fff;",
        _ => "background:rgba(124,58,237,0.12);color:#7c3aed;"
    };
}
