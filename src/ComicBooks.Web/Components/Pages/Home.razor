@page "/"
@inject IMediator Mediator
@inject NavigationManager Nav
@inject ThemeService Theme

<PageTitle>Manga Dunyo - Manhwa, Manga o'qing</PageTitle>

<style>
    .trending-scroll {
        display: flex;
        gap: 16px;
        overflow-x: auto;
        padding-bottom: 12px;
        scrollbar-width: none;
    }

        .trending-scroll::-webkit-scrollbar {
            display: none;
        }

    .trending-card {
        flex: 0 0 170px;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 8px 25px rgba(0,0,0,0.4);
        transition: all 0.3s ease;
        text-decoration: none;
        color: inherit;
        display: block;
    }

        .trending-card:hover {
            transform: translateY(-8px);
        }

        .trending-card img {
            width: 100%;
            height: 235px;
            object-fit: cover;
        }

    .trending-info {
        padding: 12px 10px;
    }

    .latest-row {
        display: flex;
        gap: 10px;
        padding: 10px 8px;
        border-bottom: 1px solid rgba(128,128,128,0.09);
        cursor: pointer;
        transition: background 0.15s;
    }

        .latest-row:hover {
            background: rgba(65,159,217,0.07);
        }

    .hero-carousel {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        z-index: 5;
        display: flex;
        gap: 12px;
        overflow-x: auto;
        padding: 0 40px 0 40px;
        scrollbar-width: none;
        align-items: flex-end;
        height: 320px;
    }

        .hero-carousel::-webkit-scrollbar {
            display: none;
        }

    .hero-slide {
        flex: 0 0 140px;
        height: 200px;
        border-radius: 12px;
        overflow: hidden;
        cursor: pointer;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        box-shadow: 0 8px 24px rgba(0,0,0,0.6);
    }

        .hero-slide:hover {
            transform: translateY(-6px);
        }

        .hero-slide.active {
            flex: 0 0 180px;
            height: 250px;
            box-shadow: 0 16px 40px rgba(0,0,0,0.8);
        }

        .hero-slide img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
            pointer-events: none;
        }
</style>

@if (_loading)
{
    <div style="display:flex;justify-content:center;align-items:center;height:80vh;">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
    </div>
}
else
{
    <div class="hero-wrap">
        <img src="@BgOf(_hero)" class="hero-bg-img" key="@(_hero?.Id)" />
        <div class="hero-overlay"></div>
        <div class="hero-overlay-bottom"></div>

        <div class="hero-carousel">
            @foreach (var c in (_featured?.Items ?? new()).Take(9))
            {
                var cc = c;
                bool isActive = _hero?.Id == c.Id;
                <div class="hero-slide @(isActive ? "active" : "")"
                     @onclick="@(() => HandleSlideClick(cc))">
                    <img src="@(c.CoverImageUrl ?? $"https://picsum.photos/seed/{c.Slug}/300/420")"
                         alt="@c.Title"
                         onerror="this.onerror=null;this.src='https://picsum.photos/seed/@(c.Slug)cv/300/420'" />
                </div>
            }
        </div>
    </div>

    <div style="max-width:1300px;margin:0 auto;padding:28px 20px 80px;">

        <!-- Trending Today -->
        <div style="margin-bottom:36px;">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;">
                <span style="font-size:1.05rem;font-weight:800;">Trending Today</span>
                <MudLink Href="/comics?sortBy=views" Underline="Underline.None"
                         Style="@($"font-size:13px;font-weight:600;color:{(Theme.IsDark?"#5b8af0":"#2563eb")};")">
                    View All →
                </MudLink>
            </div>
            <div class="trending-scroll">
                @foreach (var c in _trending?.Items ?? new())
                {
                    <a href="/comic/@c.Slug" class="trending-card">
                        <img src="@(c.CoverImageUrl ?? $"https://picsum.photos/seed/{c.Slug}/300/420")"
                             onerror="this.onerror=null;this.src='https://picsum.photos/seed/@(c.Slug)t/300/420'" />
                        <div class="trending-info">
                            <div style="font-weight:700;font-size:14px;margin-bottom:4px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@c.Title</div>
                            <div style="color:#f59e0b;font-weight:700;">★ @c.AverageRating.ToString("F1")</div>
                        </div>
                    </a>
                }
            </div>
        </div>

        <!-- Latest Updates + Popular -->
        <div style="display:grid;grid-template-columns:1fr 300px;gap:32px;">

            <!-- Latest Updates -->
            <div>
                <div style="font-size:1.05rem;font-weight:800;margin-bottom:14px;">Latest Updates</div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:0;">
                    @foreach (var c in _latest?.Items ?? new())
                    {
                        <a href="/comic/@c.Slug" style="text-decoration:none;color:inherit;">
                            <div class="latest-row">
                                <img src="@(c.CoverImageUrl ?? $"https://picsum.photos/seed/{c.Slug}/80/110")"
                                     style="width:58px;height:80px;object-fit:cover;border-radius:5px;flex-shrink:0;"
                                     onerror="this.onerror=null;this.src='https://picsum.photos/seed/@(c.Slug)l/80/110'" />
                                <div style="flex:1;min-width:0;">
                                    <div style="font-weight:700;font-size:13px;margin-bottom:4px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@c.Title</div>
                                    @if (c.LatestChapterNumber.HasValue)
                                    {
                                        <div style="font-size:12px;opacity:0.7;display:flex;justify-content:space-between;">
                                            <span>Ch. @((int)c.LatestChapterNumber.Value)</span>
                                            <span style="opacity:0.4;font-size:11px;">@FmtDate(c.CreatedAt)</span>
                                        </div>
                                        @if (c.LatestChapterNumber.Value >= 2)
                                        {
                                            <div style="font-size:12px;color:@(Theme.IsDark ? "#5b8af0" : "#2563eb");display:flex;justify-content:space-between;">
                                                <span>Ch. @((int)c.LatestChapterNumber.Value - 1)</span>
                                                <span style="opacity:0.35;font-size:11px;">last week</span>
                                            </div>
                                        }
                                    }
                                </div>
                            </div>
                        </a>
                    }
                </div>
            </div>

            <!-- Popular -->
            <div>
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;flex-wrap:wrap;gap:4px;">
                    <span style="font-size:1.05rem;font-weight:800;">Popular</span>
                    <div style="display:flex;gap:4px;">
                        @foreach (var (label, ti) in new[] { ("Haftalik", 0), ("Oylik", 1), ("All Time", 2) })
                        {
                            <button @onclick="@(() => _tab = ti)" style="@TabBtn(_tab == ti)">@label</button>
                        }
                    </div>
                </div>
                @{
                    int rk = 0;
                }
                @foreach (var c in TabList())
                {
                    int r = ++rk;
                    <a href="/comic/@c.Slug" style="text-decoration:none;color:inherit;">
                        <div style="display:flex;gap:10px;align-items:center;padding:8px 0;border-bottom:1px solid rgba(128,128,128,0.08);">
                            <div style="@RankStyle(r);width:22px;height:22px;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:900;flex-shrink:0;">@r</div>
                            <img src="@(c.CoverImageUrl ?? $"https://picsum.photos/seed/{c.Slug}/44/60")"
                                 style="width:44px;height:60px;object-fit:cover;border-radius:5px;flex-shrink:0;"
                                 onerror="this.onerror=null;this.src='https://picsum.photos/seed/@(c.Slug)r/44/60'" />
                            <div style="flex:1;min-width:0;">
                                <div style="font-size:13px;font-weight:700;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;margin-bottom:2px;">@c.Title</div>
                                <div style="font-size:11px;opacity:0.4;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@string.Join(", ", c.Genres.Take(2))</div>
                                <div style="font-size:11px;color:#f59e0b;font-weight:700;">★ @c.AverageRating.ToString("F1")</div>
                            </div>
                        </div>
                    </a>
                }
            </div>
        </div>
    </div>
}

@code {
    PaginatedList<ComicDto>? _featured, _trending, _popular, _latest;
    bool _loading = true;
    int _tab = 0;
    int _activeIdx = 4;
    ComicDto? _hero;

    protected override async Task OnInitializedAsync()
    {
        _featured = await Mediator.Send(new GetComicsQuery(PageSize: 9, IsFeatured: true, SortBy: "rating"));
        _trending = await Mediator.Send(new GetComicsQuery(PageSize: 10, SortBy: "views"));
        _popular = await Mediator.Send(new GetComicsQuery(PageSize: 10, IsPopular: true, SortBy: "rating"));
        _latest = await Mediator.Send(new GetComicsQuery(PageSize: 14, SortBy: "createdAt"));

        var list = _featured?.Items ?? new();
        _activeIdx = list.Count / 2;
        _hero = list.Count > 0 ? list[_activeIdx] : null;
        _loading = false;
    }

    private void HandleSlideClick(ComicDto c)
    {
        if (_hero?.Id == c.Id)
            Nav.NavigateTo($"/comic/{c.Slug}");
        else
            _hero = c;
    }

    string SlideStyle(int idx)
    {
        int diff = idx - _activeIdx;
        int abs = Math.Abs(diff);
        double x = diff == 0 ? 0 : Math.Sign(diff) * Math.Min(abs * 155.0, 300);
        double scale = diff == 0 ? 1.22 : Math.Max(0.72 - (abs - 1) * 0.07, 0.45);
        int zIndex = 50 - abs * 5;
        double rotY = diff == 0 ? 0 : Math.Sign(diff) * Math.Min(abs * 12.0, 30);
        double op = diff == 0 ? 1 : Math.Max(1 - (abs - 1) * 0.25, 0);
        if (abs > 3) op = 0;

        return $"transform:translateX({x:F0}px) scale({scale:F2}) rotateY({rotY:F0}deg);" +
               $"z-index:{zIndex};opacity:{op:F2};" +
               $"pointer-events:{(op < 0.1 ? "none" : "auto")};";
    }

    string BgOf(ComicDto? c) =>
        c is null ? "" :
        !string.IsNullOrEmpty(c.BannerImageUrl) ? c.BannerImageUrl :
        !string.IsNullOrEmpty(c.CoverImageUrl) ? c.CoverImageUrl :
        $"https://picsum.photos/seed/{c.Slug}bg/1400/500";

    List<ComicDto> TabList() =>
        _tab == 0 ? (_trending?.Items?.Take(10).ToList() ?? new()) :
                    (_popular?.Items?.Take(10).ToList() ?? new());

    string FmtDate(DateTime d)
    {
        var diff = DateTime.UtcNow - d;
        if (diff.TotalHours < 1) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays}d ago";
        return $"{(int)(diff.TotalDays / 7)}w ago";
    }

    string TabBtn(bool on) => on
        ? "background:#419fd9;color:#fff;font-size:11px;font-weight:700;padding:6px 16px;border-radius:9999px;border:none;cursor:pointer;"
        : "background:transparent;color:inherit;font-size:11px;font-weight:600;padding:6px 16px;border-radius:9999px;border:1px solid rgba(128,128,128,0.3);cursor:pointer;";

    string RankStyle(int r) => r switch
    {
        1 => "background:#f59e0b;color:#000;",
        2 => "background:#9ca3af;color:#000;",
        3 => "background:#b45309;color:#fff;",
        _ => "background:rgba(124,58,237,0.15);color:#a78bfa;"
    };
}