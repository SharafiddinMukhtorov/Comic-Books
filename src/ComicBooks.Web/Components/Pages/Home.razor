@page "/"
@inject IMediator Mediator
@inject NavigationManager Nav

<PageTitle>AsuraComic - Read Manhwa Online</PageTitle>

@if (_loading)
{
    <div style="display:flex;justify-content:center;align-items:center;height:80vh;">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
    </div>
}
else
{
    <!-- ═══ HERO HORIZONTAL SCROLL (AsuraScans exact) ═══ -->
    <div style="background:#0d0d18;padding:20px 0 0;overflow:hidden;position:relative;">
        <!-- Ambient background from active hero -->
        @if (_hero != null)
        {
            <div style="position:absolute;inset:0;z-index:0;pointer-events:none;">
                <img src="@BgOf(_hero)"
                     style="width:100%;height:100%;object-fit:cover;
                            filter:blur(40px) brightness(0.15) saturate(1.8);
                            transform:scale(1.2);transition:opacity 0.6s;" />
            </div>
        }
        <div style="position:absolute;inset:0;z-index:0;pointer-events:none;
                    background:linear-gradient(to bottom,rgba(13,13,24,0.5) 0%,rgba(13,13,24,0.98) 100%);"></div>

        <!-- Cards row -->
        <div style="position:relative;z-index:1;display:flex;align-items:flex-end;justify-content:center;
                    gap:10px;padding:0 16px 0;overflow-x:auto;scrollbar-width:none;
                    scroll-snap-type:x mandatory;-webkit-overflow-scrolling:touch;">
            @{ int hi = 0; var featList = _featured?.Items ?? new(); }
            @foreach (var c in featList)
            {
                bool isCenter = (_heroIdx >= 0 && featList.Count > 0 && c.Id == featList[Math.Min(_heroIdx, featList.Count-1)].Id);
                hi++;
                <div style="flex:0 0 auto;scroll-snap-align:center;cursor:pointer;
                            transition:all 0.3s ease;
                            @(isCenter
                                ? "width:200px;transform:translateY(-8px);filter:none;z-index:2;"
                                : "width:130px;filter:brightness(0.55);z-index:1;")"
                     @onclick="@(() => SetHero(c, featList.IndexOf(c)))">
                    <div style="position:relative;border-radius:10px;overflow:hidden;
                                aspect-ratio:2/3;box-shadow:@(isCenter?"0 24px 60px rgba(0,0,0,0.7)":"0 8px 24px rgba(0,0,0,0.4)");">
                        <img src="@(c.CoverImageUrl ?? $"https://picsum.photos/seed/{c.Slug}/300/450")"
                             style="width:100%;height:100%;object-fit:cover;display:block;"
                             onerror="this.onerror=null;this.src='https://picsum.photos/seed/@(c.Slug)/300/450'" />
                        @if (isCenter)
                        {
                            <div style="position:absolute;top:8px;left:8px;
                                        background:rgba(0,0,0,0.75);backdrop-filter:blur(4px);
                                        border-radius:6px;padding:2px 8px;
                                        display:flex;align-items:center;gap:3px;">
                                <span style="color:#f59e0b;font-size:12px;">★</span>
                                <span style="color:#fff;font-size:12px;font-weight:800;">@c.AverageRating.ToString("F1")</span>
                            </div>
                        }
                    </div>
                    @if (isCenter)
                    {
                        <div style="text-align:center;margin-top:8px;padding-bottom:12px;">
                            <div style="font-size:13px;font-weight:700;color:#fff;
                                        overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:200px;">
                                @c.Title
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Bottom fade -->
        <div style="height:32px;background:linear-gradient(transparent,var(--mud-palette-background));position:relative;z-index:2;"></div>
    </div>

    <!-- ═══ MAIN BODY ═══ -->
    <div style="max-width:1280px;margin:0 auto;padding:24px 20px 60px;">

        <!-- Trending Today -->
        <div style="margin-bottom:36px;">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;">
                <span style="font-size:1.1rem;font-weight:800;">Trending Today</span>
                <MudLink Href="/comics?sortBy=views" Underline="Underline.None"
                         Style="font-size:13px;color:#7c3aed;font-weight:600;">View All →</MudLink>
            </div>
            <!-- Horizontal scroll row like AsuraScans -->
            <div style="display:flex;gap:12px;overflow-x:auto;padding-bottom:8px;scrollbar-width:thin;
                        scrollbar-color:#7c3aed transparent;scroll-snap-type:x mandatory;">
                @foreach (var c in _trending?.Items ?? new())
                {
                    <div style="flex:0 0 auto;width:130px;scroll-snap-align:start;">
                        <ComicCard Comic="c" />
                    </div>
                }
                <!-- View all arrow -->
                <div style="flex:0 0 auto;width:48px;display:flex;align-items:center;justify-content:center;cursor:pointer;"
                     @onclick="@(() => Nav.NavigateTo("/comics?sortBy=views"))">
                    <div style="width:36px;height:36px;border-radius:50%;
                                background:rgba(124,58,237,0.15);display:flex;align-items:center;justify-content:center;">
                        <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Style="color:#7c3aed;" />
                    </div>
                </div>
            </div>
        </div>

        <!-- Latest Updates (2-column) + Popular sidebar -->
        <div style="display:grid;grid-template-columns:1fr 320px;gap:28px;">

            <!-- Latest Updates - 2 columns of comic+chapters -->
            <div>
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;">
                    <span style="font-size:1.1rem;font-weight:800;">Latest Updates</span>
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:0;">
                    @foreach (var c in _latest?.Items ?? new())
                    {
                        <MudLink Href="@($"/comic/{c.Slug}")" Underline="Underline.None" Color="Color.Default">
                            <div style="display:flex;gap:10px;padding:10px 8px;cursor:pointer;
                                        border-bottom:1px solid rgba(128,128,128,0.1);
                                        transition:background 0.15s;@(_latestHover==c.Id?"background:rgba(124,58,237,0.06);":"")"
                                 @onmouseover="@(e => _latestHover=c.Id)"
                                 @onmouseout="@(e => _latestHover=Guid.Empty)">
                                <!-- Cover -->
                                <img src="@(c.CoverImageUrl ?? $"https://picsum.photos/seed/{c.Slug}/80/110")"
                                     style="width:60px;height:84px;object-fit:cover;border-radius:6px;flex-shrink:0;"
                                     onerror="this.onerror=null;this.src='https://picsum.photos/seed/@(c.Slug)l/80/110'" />
                                <div style="flex:1;min-width:0;">
                                    <div style="font-weight:700;font-size:13px;margin-bottom:5px;
                                                overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                                        @c.Title
                                    </div>
                                    <!-- Show up to 3 chapter numbers like AsuraScans -->
                                    @if (c.LatestChapterNumber.HasValue)
                                    {
                                        <div style="font-size:12px;opacity:0.75;margin-bottom:2px;">
                                            Chapter @((int)c.LatestChapterNumber.Value)
                                            <span style="float:right;opacity:0.45;font-size:11px;">
                                                @FormatDate(c.CreatedAt)
                                            </span>
                                        </div>
                                        @if (c.LatestChapterNumber.Value > 1)
                                        {
                                            <div style="font-size:12px;color:#7c3aed;opacity:0.8;margin-bottom:2px;">
                                                Chapter @((int)c.LatestChapterNumber.Value - 1)
                                                <span style="float:right;opacity:0.45;font-size:11px;">last week</span>
                                            </div>
                                        }
                                        @if (c.LatestChapterNumber.Value > 2)
                                        {
                                            <div style="font-size:12px;opacity:0.55;">
                                                Chapter @((int)c.LatestChapterNumber.Value - 2)
                                                <span style="float:right;opacity:0.4;font-size:11px;">2 weeks ago</span>
                                            </div>
                                        }
                                    }
                                </div>
                            </div>
                        </MudLink>
                    }
                </div>
            </div>

            <!-- Popular Sidebar -->
            <div>
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;">
                    <span style="font-size:1.1rem;font-weight:800;">Popular</span>
                    <div style="display:flex;gap:4px;">
                        <button @onclick="@(()=>_tab=0)" style="@TabBtn(_tab==0)">Weekly</button>
                        <button @onclick="@(()=>_tab=1)" style="@TabBtn(_tab==1)">Monthly</button>
                        <button @onclick="@(()=>_tab=2)" style="@TabBtn(_tab==2)">All Time</button>
                    </div>
                </div>
                @{ int rk = 0; }
                @foreach (var c in TabList())
                {
                    int r = ++rk;
                    <MudLink Href="@($"/comic/{c.Slug}")" Underline="Underline.None" Color="Color.Default">
                        <div style="display:flex;gap:10px;align-items:center;padding:8px 0;
                                    border-bottom:1px solid rgba(128,128,128,0.08);cursor:pointer;">
                            <!-- Rank number -->
                            <div style="@RankStyle(r);width:22px;height:22px;border-radius:6px;
                                        display:flex;align-items:center;justify-content:center;
                                        font-size:11px;font-weight:900;flex-shrink:0;">@r</div>
                            <!-- Cover -->
                            <img src="@(c.CoverImageUrl ?? $"https://picsum.photos/seed/{c.Slug}/40/56")"
                                 style="width:44px;height:60px;object-fit:cover;border-radius:5px;flex-shrink:0;"
                                 onerror="this.onerror=null;this.src='https://picsum.photos/seed/@(c.Slug)r/44/60'" />
                            <div style="flex:1;min-width:0;">
                                <div style="font-size:13px;font-weight:700;overflow:hidden;
                                            text-overflow:ellipsis;white-space:nowrap;margin-bottom:2px;">@c.Title</div>
                                <div style="font-size:11px;opacity:0.45;margin-bottom:3px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                                    Genres: @string.Join(", ", c.Genres.Take(3))
                                </div>
                                <div style="display:flex;gap:2px;">
                                    @for(int s=1;s<=5;s++)
                                    {
                                        <span style="color:@(s <= Math.Round(c.AverageRating/2.0) ? "#f59e0b" : "rgba(128,128,128,0.3)");font-size:12px;">★</span>
                                    }
                                    <span style="font-size:11px;font-weight:700;color:#f59e0b;margin-left:3px;">@c.AverageRating.ToString("F1")</span>
                                </div>
                            </div>
                        </div>
                    </MudLink>
                }
            </div>
        </div>
    </div>
}

@code {
    PaginatedList<ComicDto>? _featured, _trending, _popular, _latest;
    bool      _loading    = true;
    int       _tab        = 0;
    int       _heroIdx    = 0;
    ComicDto? _hero;
    Guid      _latestHover;

    protected override async Task OnInitializedAsync()
    {
        _featured = await Mediator.Send(new GetComicsQuery(PageSize:12, IsFeatured:true,  SortBy:"rating"));
        _trending = await Mediator.Send(new GetComicsQuery(PageSize:8,  SortBy:"views"));
        _popular  = await Mediator.Send(new GetComicsQuery(PageSize:10, IsPopular:true,   SortBy:"rating"));
        _latest   = await Mediator.Send(new GetComicsQuery(PageSize:12, SortBy:"createdAt"));

        var featList = _featured?.Items ?? new();
        _heroIdx = featList.Count > 2 ? featList.Count / 2 : 0;
        _hero    = featList.Count > 0 ? featList[_heroIdx] : null;
        _loading = false;
    }

    void SetHero(ComicDto c, int idx) { _hero = c; _heroIdx = idx; }

    string BgOf(ComicDto c) => !string.IsNullOrEmpty(c.BannerImageUrl) ? c.BannerImageUrl
                             : !string.IsNullOrEmpty(c.CoverImageUrl)  ? c.CoverImageUrl
                             : $"https://picsum.photos/seed/{c.Slug}bg/1400/600";

    List<ComicDto> TabList() => _tab == 0 ? (_trending?.Items?.Take(10).ToList() ?? new())
                              : _tab == 1 ? (_popular?.Items?.Take(10).ToList()  ?? new())
                              :              (_popular?.Items?.Take(10).ToList()  ?? new());

    string FormatDate(DateTime d)
    {
        var diff = DateTime.UtcNow - d;
        if (diff.TotalHours  < 1)  return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours  < 24) return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays   < 7)  return $"{(int)diff.TotalDays} days ago";
        if (diff.TotalDays   < 30) return $"{(int)(diff.TotalDays/7)} weeks ago";
        return d.ToString("MMM d");
    }

    string TabBtn(bool active) => active
        ? "background:#7c3aed;color:#fff;font-size:11px;font-weight:700;padding:3px 10px;border-radius:20px;border:none;cursor:pointer;"
        : "background:transparent;color:inherit;font-size:11px;font-weight:600;padding:3px 10px;border-radius:20px;border:1px solid rgba(128,128,128,0.3);cursor:pointer;opacity:0.7;";

    string RankStyle(int r) => r switch {
        1 => "background:#f59e0b;color:#000;",
        2 => "background:#9ca3af;color:#000;",
        3 => "background:#b45309;color:#fff;",
        _ => "background:rgba(124,58,237,0.12);color:#7c3aed;"
    };
}
