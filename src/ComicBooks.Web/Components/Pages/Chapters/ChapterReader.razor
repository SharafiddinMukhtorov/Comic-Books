@page "/chapter/{ChapterId:guid}"
@inject IMediator Mediator
@inject NavigationManager Nav

<PageTitle>@GetTitle()</PageTitle>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else if (_chapter is null)
{
    <div style="text-align:center;padding:80px;">
        <MudText Typo="Typo.h5" Class="mb-4">Bob topilmadi</MudText>
        <MudButton Href="/" Variant="Variant.Filled" Color="Color.Primary" Style="text-transform:none;">Bosh sahifa</MudButton>
    </div>
}
else
{
    <!-- ═══ STICKY TOOLBAR ═══ -->
    <div style="position:sticky;top:64px;z-index:200;
                background:var(--mud-palette-appbar-background);
                border-bottom:1px solid rgba(128,128,128,0.12);
                padding:8px 16px;display:flex;align-items:center;gap:8px;flex-wrap:wrap;">

        <MudButton Href="@($"/comic/{ComicSlug()}")"
                   Variant="Variant.Text" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.ArrowBack"
                   Style="text-transform:none;flex-shrink:0;">
            Back
        </MudButton>

        <div style="flex:1;min-width:0;font-size:13px;font-weight:600;
                    overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
            @_chapter.ComicTitle &nbsp;›&nbsp; Chapter @_chapter.ChapterNumber
            @if (!string.IsNullOrEmpty(_chapter.Title)) { <text> – @_chapter.Title</text> }
        </div>

        <span style="font-size:12px;opacity:0.4;">@_pages.Count pages</span>

        <!-- Prev / Next -->
        @if (_prevId != Guid.Empty)
        {
            <MudButton Href="@($"/chapter/{_prevId}")" Variant="Variant.Outlined" Size="Size.Small"
                       Color="Color.Primary" Style="border-radius:20px;text-transform:none;flex-shrink:0;">
                ← Prev
            </MudButton>
        }
        @if (_nextId != Guid.Empty)
        {
            <MudButton Href="@($"/chapter/{_nextId}")" Variant="Variant.Filled" Size="Size.Small"
                       Color="Color.Primary" Style="border-radius:20px;text-transform:none;flex-shrink:0;">
                Next →
            </MudButton>
        }

        <!-- Settings button -->
        <MudIconButton Icon="@Icons.Material.Filled.Tune"
                       Size="Size.Small"
                       OnClick="@(() => _showSettings = !_showSettings)"
                       Title="O'qish moslamasi" />
    </div>

    <!-- ═══ SETTINGS PANEL ═══ -->
    @if (_showSettings)
    {
        <div style="position:sticky;top:112px;z-index:199;
                    background:var(--mud-palette-surface);
                    border-bottom:1px solid rgba(128,128,128,0.1);
                    padding:16px 20px;">
            <div style="max-width:600px;margin:0 auto;">
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
                    <MudText Typo="Typo.subtitle1" Style="font-weight:700;">O'qish moslamasi</MudText>
                    <MudText Typo="Typo.caption" Style="opacity:0.5;">Reader eni shu brauzerda saqlanadi.</MudText>
                    <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                   OnClick="@(() => _showSettings = false)" />
                </div>

                <!-- Width slider - px based like AsuraScans -->
                <div style="display:flex;align-items:center;gap:12px;margin-bottom:8px;">
                    <MudIconButton Icon="@Icons.Material.Filled.Remove" Size="Size.Small"
                                   Variant="Variant.Filled" Color="Color.Primary"
                                   OnClick="@(() => SetWidth(_width - 40))" />

                    <MudSlider T="int" Value="@_width" ValueChanged="@SetWidth"
                               Min="400" Max="1400" Step="40"
                               Color="Color.Primary" Style="flex:1;" />

                    <MudIconButton Icon="@Icons.Material.Filled.Add" Size="Size.Small"
                                   Variant="Variant.Filled" Color="Color.Primary"
                                   OnClick="@(() => SetWidth(_width + 40))" />

                    <MudIconButton Icon="@Icons.Material.Filled.RestartAlt" Size="Size.Small"
                                   Variant="Variant.Filled" Color="Color.Secondary"
                                   OnClick="@(() => SetWidth(800))" />
                </div>

                <div style="text-align:center;font-size:13px;font-weight:700;color:#7c3aed;margin-bottom:4px;">
                    @_width px
                </div>

                <MudText Typo="Typo.caption" Style="opacity:0.45;">
                    Qisqa tugmalar: +/−, 0 (oldingi holiga qaytish), P (panel), Esc (yopish).
                </MudText>
            </div>
        </div>
    }

    <!-- ═══ PAGES ═══ -->
    <div style="max-width:@(_width)px;margin:0 auto;padding:8px 0;transition:max-width 0.2s;">
        @foreach (var p in _pages.OrderBy(x => x.PageNumber))
        {
            <img src="@p.ImageUrl"
                 alt="Page @p.PageNumber"
                 style="width:100%;display:block;margin-bottom:2px;"
                 loading="lazy"
                 onerror="this.onerror=null;this.src='https://picsum.photos/seed/pg@(p.PageNumber)/800/1200'" />
        }
    </div>

    <!-- ═══ BOTTOM NAV ═══ -->
    <div style="display:flex;justify-content:center;gap:12px;
                padding:32px 16px 48px;flex-wrap:wrap;">
        @if (_prevId != Guid.Empty)
        {
            <MudButton Href="@($"/chapter/{_prevId}")" Variant="Variant.Outlined"
                       Color="Color.Primary" Size="Size.Large"
                       Style="border-radius:10px;text-transform:none;font-weight:700;">
                ← Previous Chapter
            </MudButton>
        }
        <MudButton Href="@($"/comic/{ComicSlug()}")" Variant="Variant.Text"
                   Size="Size.Large" Style="text-transform:none;">
            Comic Page
        </MudButton>
        @if (_nextId != Guid.Empty)
        {
            <MudButton Href="@($"/chapter/{_nextId}")" Variant="Variant.Filled"
                       Color="Color.Primary" Size="Size.Large"
                       Style="border-radius:10px;text-transform:none;font-weight:700;">
                Next Chapter →
            </MudButton>
        }
    </div>

    <!-- Floating settings button -->
    <div style="position:fixed;bottom:24px;right:24px;z-index:300;">
        <MudFab Color="Color.Primary"
                StartIcon="@Icons.Material.Filled.Tune"
                Label="O'qish moslamasi"
                Size="Size.Medium"
                OnClick="@(() => _showSettings = !_showSettings)"
                Style="box-shadow:0 4px 20px rgba(124,58,237,0.4);" />
    </div>
}

@code {
    [Parameter] public Guid ChapterId { get; set; }

    ChapterDto?          _chapter;
    List<ChapterPageDto> _pages    = new();
    Guid  _prevId, _nextId;
    bool  _loading      = true;
    bool  _showSettings = false;
    int   _width        = 800;
    int   _prevWidth    = 800;

    string GetTitle() => _chapter != null
        ? $"Ch.@_chapter.ChapterNumber — @_chapter.ComicTitle"
        : "O'qilmoqda...";

    string ComicSlug() => _chapter?.ComicTitle != null
        ? System.Text.RegularExpressions.Regex.Replace(
            _chapter.ComicTitle.ToLower(), @"[^a-z0-9]+", "-").Trim('-')
        : "";

    void SetWidth(int w)
    {
        _prevWidth = _width;
        _width = Math.Clamp(w, 400, 1400);
    }

    protected override async Task OnInitializedAsync() => await Load();
    protected override async Task OnParametersSetAsync()
    {
        if (!_loading) await Load();
    }

    async Task Load()
    {
        _loading = true;
        StateHasChanged();

        var r = await Mediator.Send(new GetChapterWithPagesQuery(ChapterId));
        _chapter = r.Chapter;
        _pages   = r.Pages;

        if (_chapter != null && !_pages.Any())
            _pages = Enumerable.Range(1, 22).Select(i => new ChapterPageDto
            {
                Id = Guid.NewGuid(), ChapterId = ChapterId, PageNumber = i,
                ImageUrl = $"https://picsum.photos/seed/{_chapter.ComicId}-{(int)_chapter.ChapterNumber}-{i}/800/1200"
            }).ToList();

        if (_chapter != null)
        {
            var all = (await Mediator.Send(new GetChaptersByComicQuery(_chapter.ComicId)))
                        .OrderBy(c => c.ChapterNumber).ToList();
            var idx = all.FindIndex(c => c.Id == ChapterId);
            _prevId = idx > 0              ? all[idx - 1].Id : Guid.Empty;
            _nextId = idx < all.Count - 1 ? all[idx + 1].Id : Guid.Empty;
        }

        _loading = false;
    }
}
