@page "/chapter/{ChapterId:guid}"
@rendermode InteractiveServer
@inject IMediator Mediator
@inject NavigationManager Nav

<PageTitle>@GetTitle() - AsuraComic</PageTitle>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else if (_chapter is null)
{
    <div style="padding:64px; text-align:center;">
        <MudText Typo="Typo.h5">Chapter not found</MudText>
    </div>
}
else
{
    <!-- Sticky toolbar -->
    <div style="position:sticky; top:64px; z-index:100; background:var(--mud-palette-appbar-background); border-bottom:1px solid var(--mud-palette-divider); padding:8px 16px; display:flex; align-items:center; gap:8px; flex-wrap:wrap;">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Small"
                       OnClick="@(() => Nav.NavigateTo($"/comic/{_chapter.ComicTitle?.ToLower().Replace(" ","-")}"))" />

        <div style="flex:1; min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; font-size:13px; font-weight:600;">
            @_chapter.ComicTitle &nbsp;›&nbsp; Chapter @_chapter.ChapterNumber
            @if (!string.IsNullOrEmpty(_chapter.Title)) { <text> – @_chapter.Title</text> }
        </div>

        <MudHidden Breakpoint="Breakpoint.SmAndDown">
            <MudSelect T="string" Value="@_width" ValueChanged="@(v => _width = v)"
                       Label="Width" Variant="Variant.Outlined" Margin="Margin.Dense"
                       Style="width:110px;">
                <MudSelectItem T="string" Value="@_n">Narrow</MudSelectItem>
                <MudSelectItem T="string" Value="@_m">Medium</MudSelectItem>
                <MudSelectItem T="string" Value="@_w">Wide</MudSelectItem>
                <MudSelectItem T="string" Value="@_f">Full</MudSelectItem>
            </MudSelect>
        </MudHidden>

        <span style="font-size:12px; opacity:0.5;">@_pages.Count pages</span>

        <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Primary"
                   Disabled="@(_prevId == Guid.Empty)" OnClick="@GoPrev"
                   Style="border-radius:20px;">
            ← Prev
        </MudButton>
        <MudButton Variant="Variant.Filled" Size="Size.Small" Color="Color.Primary"
                   Disabled="@(_nextId == Guid.Empty)" OnClick="@GoNext"
                   Style="border-radius:20px;">
            Next →
        </MudButton>
    </div>

    <!-- Pages -->
    <div style="@ReaderStyle()">
        @foreach (var p in _pages.OrderBy(x => x.PageNumber))
        {
            <img src="@p.ImageUrl"
                 alt="Page @p.PageNumber"
                 class="reader-page-img"
                 loading="lazy"
                 onerror="this.src='https://picsum.photos/seed/page@(p.PageNumber)/800/1200'" />
        }
    </div>

    <!-- Bottom nav -->
    <div style="display:flex; justify-content:center; gap:16px; padding:32px 16px;">
        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Large"
                   Disabled="@(_prevId == Guid.Empty)" OnClick="@GoPrev" Style="border-radius:20px;">
            ← Previous Chapter
        </MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                   Disabled="@(_nextId == Guid.Empty)" OnClick="@GoNext" Style="border-radius:20px;">
            Next Chapter →
        </MudButton>
    </div>
}

@code {
    [Parameter] public Guid ChapterId { get; set; }

    private readonly string _n = "600px";
    private readonly string _m = "800px";
    private readonly string _w = "1000px";
    private readonly string _f = "100%";

    private ChapterDto? _chapter;
    private List<ChapterPageDto> _pages = new();
    private Guid _prevId, _nextId;
    private string _width = "800px";
    private bool _loading = true;

    private string GetTitle() => _chapter != null ? $"Ch.{_chapter.ChapterNumber} - {_chapter.ComicTitle}" : "Reading...";
    private string ReaderStyle() => $"max-width:{_width}; margin:0 auto; padding:8px 0;";
    private void GoPrev() => Nav.NavigateTo($"/chapter/{_prevId}");
    private void GoNext() => Nav.NavigateTo($"/chapter/{_nextId}");

    protected override async Task OnInitializedAsync() => await Load();
    protected override async Task OnParametersSetAsync() { if (!_loading) await Load(); }

    private async Task Load()
    {
        _loading = true;
        StateHasChanged();

        var r = await Mediator.Send(new GetChapterWithPagesQuery(ChapterId));
        _chapter = r.Chapter;
        _pages = r.Pages;

        if (_chapter != null && !_pages.Any())
        {
            // Generate mock pages if none exist
            _pages = Enumerable.Range(1, 20).Select(i => new ChapterPageDto
            {
                Id = Guid.NewGuid(),
                ChapterId = ChapterId,
                PageNumber = i,
                ImageUrl = $"https://picsum.photos/seed/{_chapter.ComicId}-{_chapter.ChapterNumber}-{i}/800/1200"
            }).ToList();
        }

        if (_chapter != null)
        {
            var all = await Mediator.Send(new GetChaptersByComicQuery(_chapter.ComicId));
            var ordered = all.OrderBy(c => c.ChapterNumber).ToList();
            var idx = ordered.FindIndex(c => c.Id == ChapterId);
            _prevId = idx > 0 ? ordered[idx - 1].Id : Guid.Empty;
            _nextId = idx < ordered.Count - 1 ? ordered[idx + 1].Id : Guid.Empty;
        }

        _loading = false;
    }
}
