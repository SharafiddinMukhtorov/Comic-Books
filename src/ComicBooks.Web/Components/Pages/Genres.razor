@page "/genres"
@rendermode InteractiveServer
@inject IMediator Mediator
@inject NavigationManager Nav

<PageTitle>Janrlar - AsuraComic</PageTitle>

<div style="max-width:1200px; margin:0 auto; padding:24px 16px 48px;">
    <MudText Typo="Typo.h4" Class="font-bold mb-6">🏷️ Janrlar bo'yicha qidirish</MudText>

    @if (_loading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
    }
    else
    {
        <MudGrid Spacing="2">
            @foreach (var g in _genres)
            {
                <MudItem xs="6" sm="4" md="3" lg="2">
                    <MudPaper Elevation="1" Style="border-radius:12px; cursor:pointer; transition:all 0.2s; overflow:hidden;"
                              @onclick="@(() => Nav.NavigateTo($"/comics?search={g.Name}"))">
                        <div style="background:linear-gradient(135deg, #7c3aed22, #5b21b611); padding:20px 16px; text-align:center;">
                            <MudIcon Icon="@Icons.Material.Filled.LocalOffer" Color="Color.Primary" Style="font-size:32px; margin-bottom:8px;" />
                            <MudText Typo="Typo.subtitle1" Class="font-bold">@g.Name</MudText>
                            <MudText Typo="Typo.caption" Style="opacity:0.5;">@g.ComicCount ta komik</MudText>
                        </div>
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
    }
</div>

@code {
    private List<GenreDto> _genres = new();
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _genres = await Mediator.Send(new GetAllGenresQuery());
        _loading = false;
    }
}
