@page "/coins"
@inject ICoinPackageService PackageSvc
@inject NavigationManager Nav

<PageTitle>Coin sotib olish - Manga Dunyo</PageTitle>

<style>
    .pkg-card {
        border-radius: 16px;
        padding: 28px 20px;
        text-align: center;
        cursor: pointer;
        transition: transform 0.2s, box-shadow 0.2s;
        position: relative;
        border: 1px solid rgba(128,128,128,0.18);
    }
    .pkg-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 20px 48px rgba(0,0,0,0.35);
    }
    .pkg-card.popular {
        border: 2px solid #7c3aed;
        background: rgba(124,58,237,0.07);
    }
    .pkg-popular-badge {
        position: absolute;
        top: -13px;
        left: 50%;
        transform: translateX(-50%);
        background: #7c3aed;
        color: #fff;
        font-size: 10px;
        font-weight: 900;
        padding: 3px 14px;
        border-radius: 20px;
        white-space: nowrap;
        letter-spacing: 0.5px;
    }

    /* Carousel scroll */
    .pkg-carousel {
        display: flex;
        gap: 16px;
        overflow-x: auto;
        padding: 20px 4px 8px;
        scrollbar-width: thin;
        scrollbar-color: rgba(124,58,237,0.3) transparent;
        scroll-snap-type: x mandatory;
    }
    .pkg-carousel::-webkit-scrollbar { height: 4px; }
    .pkg-carousel::-webkit-scrollbar-thumb { background: rgba(124,58,237,0.3); border-radius: 2px; }
    .pkg-carousel-item {
        flex: 0 0 240px;
        scroll-snap-align: start;
    }
</style>

<MudContainer MaxWidth="MaxWidth.Medium" Class="py-8">

    <!-- Header -->
    <div style="text-align:center;margin-bottom:40px;">
        <span style="font-size:3.5rem;">🪙</span>
        <MudText Typo="Typo.h4" Style="font-weight:900;margin-top:8px;">Coin sotib olish</MudText>
        <MudText Style="opacity:0.5;margin-top:6px;font-size:15px;">
            Qulflangan boblarni o'qish uchun coin to'plab boring
        </MudText>
    </div>

    <!-- Packages carousel -->
    @if (_loading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
    }
    else if (_packages.Any())
    {
        <div class="pkg-carousel">
            @foreach (var pkg in _packages)
            {
                <div class="pkg-carousel-item">
                    <div class="pkg-card @(pkg.IsPopular ? "popular" : "")"
                         @onclick="@(() => Buy(pkg))">

                        @if (pkg.IsPopular)
                        {
                            <div class="pkg-popular-badge">⭐ ENG MASHHUR</div>
                        }

                        <div style="font-size:2.8rem;margin-bottom:4px;">🪙</div>
                        <div style="font-size:2.4rem;font-weight:900;color:#f59e0b;line-height:1;">
                            @pkg.CoinAmount
                        </div>
                        @if (pkg.BonusCoins > 0)
                        {
                            <div style="font-size:12px;color:#22c55e;font-weight:700;margin-top:2px;">
                                +@pkg.BonusCoins bonus 🎁
                            </div>
                        }
                        <div style="font-size:12px;opacity:0.4;margin-bottom:16px;margin-top:2px;">
                            @(string.IsNullOrEmpty(pkg.Name) ? "coins" : pkg.Name)
                        </div>

                        <button style="width:100%;background:@(pkg.IsPopular?"#7c3aed":"rgba(124,58,237,0.15)");
                                       color:@(pkg.IsPopular?"#fff":"#a78bfa");
                                       border:none;border-radius:10px;padding:12px;
                                       font-size:15px;font-weight:800;cursor:pointer;
                                       box-shadow:@(pkg.IsPopular?"0 4px 20px rgba(124,58,237,0.4)":"none");"
                                @onclick="@(() => Buy(pkg))" @onclick:stopPropagation="true">
                            @pkg.Price
                        </button>

                        <div style="font-size:11px;opacity:0.3;margin-top:10px;">
                            Telegram orqali to'lash
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <!-- Default packages if none in DB -->
        <div class="pkg-carousel">
            @foreach (var pkg in DefaultPackages)
            {
                <div class="pkg-carousel-item">
                    <div class="pkg-card @(pkg.IsPopular ? "popular" : "")"
                         @onclick="@(() => BuyDefault(pkg))">
                        @if (pkg.IsPopular)
                        {
                            <div class="pkg-popular-badge">⭐ ENG MASHHUR</div>
                        }
                        <div style="font-size:2.8rem;margin-bottom:4px;">🪙</div>
                        <div style="font-size:2.4rem;font-weight:900;color:#f59e0b;line-height:1;">@pkg.Coins</div>
                        @if (pkg.Bonus > 0)
                        {
                            <div style="font-size:12px;color:#22c55e;font-weight:700;margin-top:2px;">+@pkg.Bonus bonus 🎁</div>
                        }
                        <div style="font-size:12px;opacity:0.4;margin-bottom:16px;margin-top:2px;">coins</div>
                        <button style="width:100%;background:@(pkg.IsPopular?"#7c3aed":"rgba(124,58,237,0.15)");
                                       color:@(pkg.IsPopular?"#fff":"#a78bfa");
                                       border:none;border-radius:10px;padding:12px;
                                       font-size:15px;font-weight:800;cursor:pointer;">
                            @pkg.Price UZS
                        </button>
                        <div style="font-size:11px;opacity:0.3;margin-top:10px;">Telegram orqali to'lash</div>
                    </div>
                </div>
            }
        </div>
    }

    <!-- How to buy -->
    <MudPaper Class="pa-5 mt-8" Elevation="1" Style="border-radius:14px;">
        <MudText Typo="Typo.h6" Class="mb-4" Style="font-weight:700;">
            📖 Qanday sotib olish kerak?
        </MudText>
        <div style="display:flex;flex-direction:column;gap:14px;">
            @foreach (var (step, i) in Steps.Select((s, i) => (s, i + 1)))
            {
                <div style="display:flex;gap:14px;align-items:flex-start;">
                    <div style="width:30px;height:30px;border-radius:50%;background:#7c3aed;color:#fff;
                                display:flex;align-items:center;justify-content:center;
                                font-size:13px;font-weight:800;flex-shrink:0;margin-top:1px;">@i</div>
                    <div style="font-size:14px;padding-top:5px;">@step</div>
                </div>
            }
        </div>

        <div style="margin-top:24px;padding:16px;border-radius:10px;
                    background:rgba(124,58,237,0.08);border:1px solid rgba(124,58,237,0.2);
                    display:flex;align-items:center;gap:14px;">
            <span style="font-size:2rem;">💬</span>
            <div>
                <div style="font-weight:700;margin-bottom:4px;">Telegram orqali to'lov</div>
                <div style="font-size:13px;opacity:0.6;">
                    To'lovni amalga oshirgach admin balansni 5 daqiqa ichida to'ldiradi
                </div>
            </div>
            <a href="https://t.me/MukhtorovSh" target="_blank"
               style="margin-left:auto;background:#7c3aed;color:#fff;border-radius:8px;
                      padding:8px 18px;font-weight:700;font-size:13px;text-decoration:none;
                      white-space:nowrap;flex-shrink:0;">
                Telegram →
            </a>
        </div>
    </MudPaper>
</MudContainer>

@code {
    List<CoinPackageDto> _packages = new();
    bool _loading = true;

    record DefPkg(int Coins, int Bonus, string Price, bool IsPopular = false);

    readonly List<DefPkg> DefaultPackages = new()
    {
        new(10,  0,  "5,000"),
        new(25,  0,  "10,000"),
        new(50,  5,  "20,000", IsPopular: true),
        new(100, 15, "35,000"),
        new(200, 40, "60,000"),
    };

    readonly List<string> Steps = new()
    {
        "Yuqoridagi paketlardan birini tanlang",
        "Telegram botimizga o'tasiz — paket va miqdori ko'rsatiladi",
        "To'lovni amalga oshiring (Payme / Click / Uzum)",
        "Admin 5 daqiqa ichida coin balansini to'ldiradi",
        "Coin bilan istalgan qulflangan bobni o'qing! 🎉"
    };

    protected override async Task OnInitializedAsync()
    {
        _packages = await PackageSvc.GetAllAsync();
        _loading  = false;
    }

    void Buy(CoinPackageDto pkg)
    {
        var total   = pkg.CoinAmount + pkg.BonusCoins;
        var msg     = Uri.EscapeDataString($"Coin sotib olmoqchiman:\nPaket: {pkg.Name}\nMiqdor: {total} coins\nNarx: {pkg.Price}\n\nTelegram: @MukhtorovSh");
        Nav.NavigateTo($"https://t.me/MukhtorovSh?text={msg}", forceLoad: true);
    }

    void BuyDefault(DefPkg pkg)
    {
        var total = pkg.Coins + pkg.Bonus;
        var msg   = Uri.EscapeDataString($"Coin sotib olmoqchiman:\n{total} coins — {pkg.Price} UZS");
        Nav.NavigateTo($"https://t.me/MukhtorovSh?text={msg}", forceLoad: true);
    }
}
