@page "/comics"
@rendermode InteractiveServer
@inject IMediator Mediator

<PageTitle>Komiklar - AsuraComic</PageTitle>

<div style="max-width:1400px;margin:0 auto;padding:20px 16px 48px;">

    <!-- Back -->
    <div style="margin-bottom:16px;">
        <MudButton Href="/" Variant="Variant.Text"
                   StartIcon="@Icons.Material.Filled.ArrowBack"
                   Style="text-transform:none;">Bosh sahifaga qaytish</MudButton>
    </div>

    <MudText Typo="Typo.h4" Class="font-bold mb-5">Barcha komiklar</MudText>

    <!-- Filters -->
    <MudPaper Elevation="1" Class="pa-4 mb-5" Style="border-radius:14px;">
        <MudGrid Spacing="2">
            <MudItem xs="12" sm="6" md="4">
                <MudTextField @bind-Value="_search"
                              Label="Qidirish..."
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Immediate="false"
                              OnKeyDown="@HandleKey" />
            </MudItem>

            <MudItem xs="6" sm="3" md="2">
                <MudSelect T="ComicStatus?"
                           Value="@_status"
                           ValueChanged="@StatusChanged"
                           Label="Holat"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Clearable="true">
                    <MudSelectItem T="ComicStatus?" Value="@((ComicStatus?)ComicStatus.Ongoing)">Davom etmoqda</MudSelectItem>
                    <MudSelectItem T="ComicStatus?" Value="@((ComicStatus?)ComicStatus.Completed)">Tugallangan</MudSelectItem>
                    <MudSelectItem T="ComicStatus?" Value="@((ComicStatus?)ComicStatus.Hiatus)">To'xtatilgan</MudSelectItem>
                </MudSelect>
            </MudItem>

            <MudItem xs="6" sm="3" md="2">
                <MudSelect T="ComicType?"
                           Value="@_type"
                           ValueChanged="@TypeChanged"
                           Label="Turi"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Clearable="true">
                    <MudSelectItem T="ComicType?" Value="@((ComicType?)ComicType.Manhwa)">Manhwa</MudSelectItem>
                    <MudSelectItem T="ComicType?" Value="@((ComicType?)ComicType.Manga)">Manga</MudSelectItem>
                    <MudSelectItem T="ComicType?" Value="@((ComicType?)ComicType.Manhua)">Manhua</MudSelectItem>
                </MudSelect>
            </MudItem>

            <MudItem xs="6" sm="3" md="2">
                <MudSelect T="string"
                           Value="@_sort"
                           ValueChanged="@SortChanged"
                           Label="Saralash"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense">
                    <MudSelectItem T="string" Value="@("createdAt")">Yangi</MudSelectItem>
                    <MudSelectItem T="string" Value="@("views")">Ko'p ko'rilgan</MudSelectItem>
                    <MudSelectItem T="string" Value="@("rating")">Reyting</MudSelectItem>
                    <MudSelectItem T="string" Value="@("title")">A-Z</MudSelectItem>
                </MudSelect>
            </MudItem>

            <MudItem xs="6" sm="3" md="2" Class="d-flex align-end">
                <MudButton Variant="Variant.Outlined" Color="Color.Default"
                           OnClick="@ResetFilters" FullWidth="true"
                           Style="height:40px;text-transform:none;">
                    Tozalash
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    @if (_loading)
    {
        <MudGrid Spacing="2">
            @for (int i = 0; i < 12; i++)
            {
                <MudItem xs="6" sm="4" md="3" lg="2">
                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="260px" Style="border-radius:10px;" />
                    <MudSkeleton Class="mt-1" Width="80%" />
                </MudItem>
            }
        </MudGrid>
    }
    else if (_result?.Items.Any() == true)
    {
        <MudText Typo="Typo.body2" Style="opacity:0.5;" Class="mb-4">
            @_result.TotalCount ta komik
        </MudText>
        <MudGrid Spacing="2">
            @foreach (var c in _result.Items)
            {
                <MudItem xs="6" sm="4" md="3" lg="2">
                    <ComicCard Comic="c" />
                </MudItem>
            }
        </MudGrid>
        @if (_result.TotalPages > 1)
        {
            <div class="d-flex justify-center mt-8">
                <MudPagination Count="@_result.TotalPages"
                               Selected="@_page"
                               SelectedChanged="@OnPageChanged"
                               Color="Color.Primary"
                               ShowFirstButton="true"
                               ShowLastButton="true" />
            </div>
        }
    }
    else
    {
        <MudAlert Severity="Severity.Info" Style="border-radius:12px;">
            Hech narsa topilmadi.
        </MudAlert>
    }
</div>

@code {
    [SupplyParameterFromQuery] public string? search { get; set; }
    [SupplyParameterFromQuery] public string? sortBy { get; set; }

    PaginatedList<ComicDto>? _result;
    bool _loading = true;
    int _page = 1;

    string _search = "";
    ComicStatus? _status;
    ComicType? _type;
    string _sort = "createdAt";

    protected override async Task OnInitializedAsync()
    {
        _search = search ?? "";
        _sort   = sortBy ?? "createdAt";
        await Load();
    }

    async Task Load()
    {
        _loading = true;
        StateHasChanged();
        _result = await Mediator.Send(new GetComicsQuery(
            PageNumber: _page,
            PageSize:   24,
            Search:     string.IsNullOrWhiteSpace(_search) ? null : _search,
            Status:     _status,
            Type:       _type,
            SortBy:     _sort));
        _loading = false;
    }

    // Dropdown handlers — each triggers a new query
    async Task StatusChanged(ComicStatus? v) { _status = v; _page = 1; await Load(); }
    async Task TypeChanged(ComicType? v)     { _type   = v; _page = 1; await Load(); }
    async Task SortChanged(string v)         { _sort   = v; _page = 1; await Load(); }

    async Task OnPageChanged(int p) { _page = p; await Load(); }

    async Task HandleKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") { _page = 1; await Load(); }
    }

    async Task ResetFilters()
    {
        _search = ""; _status = null; _type = null;
        _sort = "createdAt"; _page = 1;
        await Load();
    }
}
