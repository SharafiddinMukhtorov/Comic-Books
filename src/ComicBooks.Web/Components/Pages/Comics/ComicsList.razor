@page "/comics"
@inject IMediator Mediator

<PageTitle>Komiklar - AsuraComic</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
        <MudButton Href="/" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack" Style="text-transform:none;">Orqaga</MudButton>
        <MudText Typo="Typo.h5">Barcha komiklar</MudText>
    </MudStack>

    <MudPaper Class="pa-3 mb-4">
        <MudGrid Spacing="2">
            <MudItem xs="12" sm="5">
                <MudTextField @bind-Value="_search" Label="Qidirish..." Variant="Variant.Outlined"
                              Margin="Margin.Dense" OnKeyDown="@OnKey" Clearable="true" />
            </MudItem>
            <MudItem xs="6" sm="2">
                <MudSelect T="ComicStatus?" @bind-Value="_status" Label="Holat" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                    <MudSelectItem T="ComicStatus?" Value="@((ComicStatus?)ComicStatus.Ongoing)">Davom etmoqda</MudSelectItem>
                    <MudSelectItem T="ComicStatus?" Value="@((ComicStatus?)ComicStatus.Completed)">Tugallangan</MudSelectItem>
                    <MudSelectItem T="ComicStatus?" Value="@((ComicStatus?)ComicStatus.Hiatus)">To'xtatilgan</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="6" sm="2">
                <MudSelect T="ComicType?" @bind-Value="_type" Label="Turi" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                    <MudSelectItem T="ComicType?" Value="@((ComicType?)ComicType.Manhwa)">Manhwa</MudSelectItem>
                    <MudSelectItem T="ComicType?" Value="@((ComicType?)ComicType.Manga)">Manga</MudSelectItem>
                    <MudSelectItem T="ComicType?" Value="@((ComicType?)ComicType.Manhua)">Manhua</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="6" sm="2">
                <MudSelect T="string" @bind-Value="_sort" Label="Saralash" Variant="Variant.Outlined" Margin="Margin.Dense">
                    <MudSelectItem T="string" Value="@("createdAt")">Yangi</MudSelectItem>
                    <MudSelectItem T="string" Value="@("views")">Ko'p ko'rilgan</MudSelectItem>
                    <MudSelectItem T="string" Value="@("rating")">Reyting</MudSelectItem>
                    <MudSelectItem T="string" Value="@("title")">A-Z</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="6" sm="1">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@Search"
                           FullWidth="true" Style="height:40px;text-transform:none;">Qidirish</MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    @if (_loading)
    {
        <MudGrid Spacing="2">
            @for (int i = 0; i < 12; i++)
            {
                <MudItem xs="6" sm="4" md="3" lg="2">
                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="260px" />
                    <MudSkeleton Class="mt-1" />
                </MudItem>
            }
        </MudGrid>
    }
    else if (_result?.Items.Any() == true)
    {
        <MudText Typo="Typo.body2" Style="opacity:0.5;" Class="mb-3">@_result.TotalCount ta komik</MudText>
        <MudGrid Spacing="2">
            @foreach (var c in _result.Items)
            {
                <MudItem xs="6" sm="4" md="3" lg="2"><ComicCard Comic="c" /></MudItem>
            }
        </MudGrid>
        @if (_result.TotalPages > 1)
        {
            <MudStack AlignItems="AlignItems.Center" Class="mt-6">
                <MudPagination Count="@_result.TotalPages" Selected="@_page" SelectedChanged="@OnPage"
                               Color="Color.Primary" ShowFirstButton="true" ShowLastButton="true" />
            </MudStack>
        }
    }
    else
    {
        <MudText Style="opacity:0.5;text-align:center;padding:40px;">Hech narsa topilmadi.</MudText>
    }
</MudContainer>

@code {
    [SupplyParameterFromQuery] public string? search { get; set; }
    [SupplyParameterFromQuery] public string? sortBy { get; set; }

    PaginatedList<ComicDto>? _result;
    bool   _loading = true;
    int    _page    = 1;
    string _search  = "";
    string _sort    = "createdAt";
    ComicStatus? _status;
    ComicType?   _type;

    protected override async Task OnInitializedAsync()
    {
        _search = search ?? "";
        _sort   = sortBy ?? "createdAt";
        await Load();
    }

    async Task Load()
    {
        _loading = true;
        StateHasChanged();
        _result = await Mediator.Send(new GetComicsQuery(PageNumber: _page, PageSize: 24,
            Search: string.IsNullOrWhiteSpace(_search) ? null : _search,
            Status: _status, Type: _type, SortBy: _sort));
        _loading = false;
    }

    async Task Search() { _page = 1; await Load(); }
    async Task OnPage(int p) { _page = p; await Load(); }
    async Task OnKey(KeyboardEventArgs e) { if (e.Key == "Enter") await Search(); }
}
