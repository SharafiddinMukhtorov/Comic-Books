@page "/comic/{Slug}"
@rendermode InteractiveServer
@inject IMediator Mediator
@inject NavigationManager Nav
@inject BookmarkService BookmarkSvc

<PageTitle>@(_comic?.Title ?? "Comic") - AsuraComic</PageTitle>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else if (_comic is null)
{
    <div style="padding:64px; text-align:center;">
        <MudText Typo="Typo.h4">Comic not found</MudText>
        <MudButton Href="/" Variant="Variant.Filled" Color="Color.Primary" Class="mt-4">Go Home</MudButton>
    </div>
}
else
{
    <!-- Banner -->
    <div style="position:relative; width:100%; height:300px; overflow:hidden; margin-bottom:0;">
        <img src="@(_comic.CoverImageUrl ?? $"https://picsum.photos/seed/{_comic.Slug}/1200/400")"
             style="width:100%; height:100%; object-fit:cover; display:block; filter:blur(4px) brightness(0.4);"
             onerror="this.src='https://picsum.photos/seed/banner/1200/400'" />
        <div style="position:absolute; inset:0; background:linear-gradient(to bottom, rgba(0,0,0,0.2), rgba(0,0,0,0.7));"></div>
    </div>

    <div style="max-width:1200px; margin:-80px auto 0; padding:0 16px 40px; position:relative; z-index:2;">
        <MudGrid Spacing="4">
            <!-- Cover -->
            <MudItem xs="12" sm="3" md="2">
                <div style="border-radius:12px; overflow:hidden; box-shadow:0 16px 40px rgba(0,0,0,0.5);">
                    <img src="@(_comic.CoverImageUrl ?? $"https://picsum.photos/seed/{_comic.Slug}/300/420")"
                         alt="@_comic.Title"
                         style="width:100%; display:block; aspect-ratio:2/3; object-fit:cover;"
                         onerror="this.src='https://picsum.photos/seed/fallback/300/420'" />
                </div>
            </MudItem>

            <!-- Info -->
            <MudItem xs="12" sm="9" md="10">
                <MudText Typo="Typo.h4" Style="font-weight:800; margin-bottom:6px;">@_comic.Title</MudText>

                @if (!string.IsNullOrEmpty(_comic.AlternativeTitles))
                {
                    <MudText Typo="Typo.body2" Style="opacity:0.5; font-style:italic; margin-bottom:8px;">@_comic.AlternativeTitles</MudText>
                }

                <div style="display:flex; align-items:center; gap:16px; flex-wrap:wrap; margin-bottom:12px;">
                    <div style="display:flex; align-items:center; gap:4px;">
                        <span style="color:#f59e0b; font-size:20px;">★</span>
                        <span style="font-size:1.3rem; font-weight:800;">@_comic.AverageRating.ToString("F1")</span>
                        <span style="opacity:0.5; font-size:12px;">/10</span>
                    </div>
                    <span style="@GetStatusStyle(_comic.Status) font-size:12px; font-weight:700; padding:4px 12px; border-radius:12px;">@_comic.Status</span>
                    <span style="background:rgba(124,58,237,0.15); color:#7c3aed; font-size:12px; font-weight:600; padding:4px 12px; border-radius:12px;">@_comic.Type</span>
                    <span style="opacity:0.5; font-size:13px;">@FormatViews(_comic.ViewCount) views</span>
                </div>

                <!-- Genres -->
                <div style="display:flex; flex-wrap:wrap; gap:6px; margin-bottom:16px;">
                    @foreach (var g in _comic.Genres)
                    {
                        <span style="background:rgba(124,58,237,0.12); color:#7c3aed; font-size:12px; font-weight:600; padding:4px 12px; border-radius:20px; cursor:pointer;"
                              @onclick="@(() => Nav.NavigateTo($"/comics?search={g}"))">@g</span>
                    }
                    @foreach (var t in _comic.Tags)
                    {
                        <span style="background:rgba(255,255,255,0.08); font-size:11px; font-weight:500; padding:3px 10px; border-radius:20px; opacity:0.7;">@t</span>
                    }
                </div>

                <div style="display:flex; gap:12px; flex-wrap:wrap; margin-bottom:16px;">
                    @if (_chapters.Any())
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                                   Style="border-radius:20px; font-weight:700;"
                                   OnClick="@(() => Nav.NavigateTo($"/chapter/{_chapters.Last().Id}"))">
                            <MudIcon Icon="@Icons.Material.Filled.PlayArrow" Class="mr-1" />
                            Start Reading
                        </MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Large"
                                   Style="border-radius:20px;"
                                   OnClick="@(() => Nav.NavigateTo($"/chapter/{_chapters.First().Id}"))">
                            <MudIcon Icon="@Icons.Material.Filled.SkipNext" Class="mr-1" />
                            Ch. @_chapters.First().ChapterNumber
                        </MudButton>
                    }
                    <MudButton Variant="Variant.Outlined"
                               Color="@(IsBookmarked ? Color.Primary : Color.Default)"
                               Size="Size.Large"
                               Style="border-radius:20px;"
                               OnClick="@(() => BookmarkSvc.Toggle(_comic.Id))">
                        <MudIcon Icon="@(IsBookmarked ? Icons.Material.Filled.Bookmark : Icons.Material.Outlined.BookmarkBorder)" Class="mr-1" />
                        @(IsBookmarked ? "Bookmarked" : "Bookmark")
                    </MudButton>
                </div>

                <!-- Meta info -->
                <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(150px,1fr)); gap:8px; font-size:13px;">
                    @if (_comic.Author != null)
                    {
                        <div><span style="opacity:0.5;">Author: </span><strong>@_comic.Author</strong></div>
                    }
                    @if (_comic.Artist != null)
                    {
                        <div><span style="opacity:0.5;">Artist: </span><strong>@_comic.Artist</strong></div>
                    }
                    @if (_comic.ReleaseYear.HasValue)
                    {
                        <div><span style="opacity:0.5;">Released: </span><strong>@_comic.ReleaseYear</strong></div>
                    }
                    <div><span style="opacity:0.5;">Chapters: </span><strong>@_comic.ChapterCount</strong></div>
                </div>
            </MudItem>
        </MudGrid>

        <!-- Description -->
        @if (!string.IsNullOrEmpty(_comic.Description))
        {
            <MudPaper Elevation="1" Class="pa-5 mt-6" Style="border-radius:14px;">
                <MudText Typo="Typo.h6" Class="font-bold mb-3">Synopsis</MudText>
                <MudText Typo="Typo.body1" Style="line-height:1.8; opacity:0.85;">@_comic.Description</MudText>
            </MudPaper>
        }

        <!-- Chapter List -->
        <MudPaper Elevation="1" Class="pa-5 mt-4" Style="border-radius:14px;">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:16px;">
                <MudText Typo="Typo.h6" Class="font-bold">Chapters (@_chapters.Count)</MudText>
                <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Primary"
                           OnClick="@(() => _reverseChapters = !_reverseChapters)">
                    @(_reverseChapters ? "Oldest First" : "Newest First")
                </MudButton>
            </div>
            <div style="max-height:500px; overflow-y:auto;">
                @foreach (var ch in GetDisplayChapters())
                {
                    <div style="@GetChapterRowStyle(ch.Id)"
                         @onclick="@(() => Nav.NavigateTo($"/chapter/{ch.Id}"))"
                         @onmouseover="@(e => _hoveredChapter = ch.Id)"
                         @onmouseout="@(e => _hoveredChapter = Guid.Empty)">
                        <div>
                            <span style="color:#7c3aed; font-weight:700; margin-right:8px;">Ch. @ch.ChapterNumber</span>
                            @if (!string.IsNullOrEmpty(ch.Title))
                            {
                                <span style="font-size:13px; opacity:0.8;">@ch.Title</span>
                            }
                        </div>
                        <div style="display:flex; gap:12px; align-items:center; font-size:12px; opacity:0.5;">
                            <span>@ch.PageCount pages</span>
                            <span>@ch.PublishedAt?.ToString("MMM dd, yyyy")</span>
                        </div>
                    </div>
                }
            </div>
        </MudPaper>
    </div>
}

@code {
    [Parameter] public string Slug { get; set; } = "";

    private ComicDto? _comic;
    private List<ChapterDto> _chapters = new();
    private bool _loading = true;
    private bool _reverseChapters = true;
    private Guid _hoveredChapter;

    private bool IsBookmarked => _comic != null && BookmarkSvc.IsBookmarked(_comic.Id);

    private List<ChapterDto> GetDisplayChapters() => _reverseChapters
        ? _chapters.OrderByDescending(c => c.ChapterNumber).ToList()
        : _chapters.OrderBy(c => c.ChapterNumber).ToList();

    private string GetChapterRowStyle(Guid chId)
    {
        var hover = _hoveredChapter == chId ? "background:rgba(124,58,237,0.1);" : "";
        return $"display:flex; justify-content:space-between; align-items:center; padding:10px 12px; border-radius:8px; cursor:pointer; transition:background 0.15s; {hover}";
    }

    protected override async Task OnInitializedAsync()
    {
        _comic = await Mediator.Send(new GetComicBySlugQuery(Slug));
        if (_comic != null)
            _chapters = await Mediator.Send(new GetChaptersByComicQuery(_comic.Id));
        _loading = false;
    }

    private string FormatViews(int v) => v >= 1000000 ? $"{v / 1000000.0:F1}M" : v >= 1000 ? $"{v / 1000}K" : v.ToString();

    private string GetStatusStyle(ComicStatus s) => s switch
    {
        ComicStatus.Ongoing => "background:#059669; color:#fff;",
        ComicStatus.Completed => "background:#7c3aed; color:#fff;",
        ComicStatus.Hiatus => "background:#d97706; color:#fff;",
        _ => "background:#6b7280; color:#fff;"
    };
}
