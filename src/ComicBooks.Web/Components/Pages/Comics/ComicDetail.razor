@page "/comic/{Slug}"
@inject IMediator Mediator
@inject NavigationManager Nav
@inject BookmarkService BookmarkSvc

<PageTitle>@(_comic?.Title ?? "Comic") - Manga Dunyo</PageTitle>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else if (_comic is null)
{
    <div style="text-align:center;padding:80px;">
        <MudText Typo="Typo.h4" Class="mb-4">Comic not found</MudText>
        <MudButton Href="/" Variant="Variant.Filled" Color="Color.Primary" Style="text-transform:none;">Go Home</MudButton>
    </div>
}
else
{
    <!-- ═══ HERO BANNER ═══ -->
    <div style="position:relative;min-height:380px;overflow:hidden;">

        <!-- Blurred background -->
        <img src="@BgUrl()"
             style="position:absolute;top:0;left:0;width:100%;height:100%;
                    object-fit:cover;
                    filter:blur(18px) brightness(0.35) saturate(1.4);
                    transform:scale(1.08);z-index:0;" />

        <!-- Gradients -->
        <div style="position:absolute;inset:0;z-index:1;
                    background:linear-gradient(to right,rgba(10,10,20,0.9) 0%,rgba(10,10,20,0.5) 50%,rgba(10,10,20,0.15) 100%);"></div>
        <div style="position:absolute;bottom:0;left:0;right:0;height:180px;z-index:1;
                    background:linear-gradient(transparent,var(--mud-palette-background));"></div>

        <!-- Content -->
        <div style="position:relative;z-index:2;max-width:1100px;margin:0 auto;
                    padding:40px 24px 60px;display:flex;gap:28px;align-items:flex-start;">

            <!-- Cover -->
            <div style="flex:0 0 auto;">
                <img src="@CoverUrl()" alt="@_comic.Title"
                     style="width:200px;height:285px;object-fit:cover;border-radius:10px;
                            box-shadow:0 24px 60px rgba(0,0,0,0.8);display:block;"
                     onerror="this.onerror=null;this.src='https://picsum.photos/seed/@(_comic.Slug)/300/420'" />
            </div>

            <!-- Info -->
            <div style="flex:1;min-width:0;padding-top:4px;">

                <!-- Title -->
                <h1 style="font-size:1.9rem;font-weight:900;color:#fff;margin:0 0 6px;line-height:1.2;">
                    @_comic.Title
                </h1>

                <!-- Alt title -->
                @if (!string.IsNullOrEmpty(_comic.AlternativeTitles))
                {
                    <div style="font-size:12px;color:rgba(255,255,255,0.35);margin-bottom:12px;">
                        @_comic.AlternativeTitles
                    </div>
                }

                <!-- Rating stars row -->
                <div style="display:flex;align-items:center;gap:12px;margin-bottom:14px;">
                    <div style="display:flex;gap:2px;">
                        @for (int s = 1; s <= 5; s++)
                        {
                            double half = _comic.AverageRating / 2.0;
                            <span style="font-size:16px;color:@(s<=Math.Round(half)?"#f59e0b":"rgba(255,255,255,0.2)");">★</span>
                        }
                    </div>
                    <span style="font-size:14px;font-weight:700;color:#f59e0b;">@_comic.AverageRating.ToString("F1")</span>
                    <span style="font-size:12px;color:rgba(255,255,255,0.35);">/ 10</span>
                    <span style="color:rgba(255,255,255,0.2);">|</span>
                    <span style="font-size:12px;color:rgba(255,255,255,0.5);">
                        👁 @Fmt(_comic.ViewCount) ko'rishlar
                    </span>
                </div>

                <!-- Description -->
                @if (!string.IsNullOrEmpty(_comic.Description))
                {
                    <div style="font-size:14px;line-height:1.75;color:rgba(255,255,255,0.72);
                                margin-bottom:6px;
                                @(!_showMore ? "display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;" : "")">
                        @_comic.Description
                    </div>
                    <span style="color:#a78bfa;font-size:12px;font-weight:600;cursor:pointer;margin-bottom:18px;display:inline-block;"
                          @onclick="@(() => _showMore = !_showMore)">
                        @(_showMore ? "Ko'proq yig'ish ↑" : "Ko'proq ko'rish ↓")
                    </span>
                }

                <!-- Genres -->
                @if (_comic.Genres.Any())
                {
                    <div style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:18px;">
                        @foreach (var g in _comic.Genres)
                        {
                            <a href="/comics?genre=@g"
                               style="padding:3px 12px;border-radius:20px;font-size:11px;font-weight:700;
                                      background:rgba(124,58,237,0.25);color:#c4b5fd;
                                      border:1px solid rgba(124,58,237,0.4);text-decoration:none;
                                      transition:background 0.15s;"
                               onmouseover="this.style.background='rgba(124,58,237,0.45)'"
                               onmouseout="this.style.background='rgba(124,58,237,0.25)'">
                                @g
                            </a>
                        }
                    </div>
                }

                <!-- Action buttons -->
                <div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:20px;">
                    @if (FirstId != Guid.Empty)
                    {
                        <a href="/chapter/@FirstId"
                           style="display:inline-flex;align-items:center;gap:6px;height:42px;padding:0 20px;
                                  background:#7c3aed;color:#fff;border-radius:8px;
                                  font-weight:700;font-size:13px;text-decoration:none;
                                  box-shadow:0 4px 16px rgba(124,58,237,0.4);">
                            ▶ Birinchi bob
                        </a>
                        <a href="/chapter/@LastId"
                           style="display:inline-flex;align-items:center;gap:6px;height:42px;padding:0 20px;
                                  background:rgba(255,255,255,0.08);color:#fff;border-radius:8px;
                                  font-weight:600;font-size:13px;text-decoration:none;
                                  border:1px solid rgba(255,255,255,0.18);">
                            ⏭ Oxirgi bob
                        </a>
                    }
                    <button @onclick="@(() => BookmarkSvc.Toggle(_comic.Id))"
                            style="display:inline-flex;align-items:center;gap:6px;height:42px;padding:0 18px;
                                   background:@(IsBookmarked ? "rgba(124,58,237,0.35)" : "rgba(255,255,255,0.06)");
                                   color:@(IsBookmarked ? "#a78bfa" : "rgba(255,255,255,0.7)");
                                   border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;
                                   border:1px solid @(IsBookmarked ? "rgba(124,58,237,0.5)" : "rgba(255,255,255,0.15)");">
                        @(IsBookmarked ? "✓ Saqlangan" : "🔖 Saqlash")
                    </button>
                </div>

                <!-- Meta info row -->
                <div style="display:flex;flex-wrap:wrap;gap:16px;font-size:12px;color:rgba(255,255,255,0.5);">
                    <div>
                        <span style="opacity:0.5;margin-right:4px;">Holat</span>
                        <span style="@StatusBadge();padding:2px 8px;border-radius:5px;font-size:11px;font-weight:700;">
                            @_comic.Status
                        </span>
                    </div>
                    <div>
                        <span style="opacity:0.5;margin-right:4px;">Turi</span>
                        <span style="color:#7c3aed;font-weight:700;">@_comic.Type</span>
                    </div>
                    @if (!string.IsNullOrEmpty(_comic.Author))
                    {
                        <div>✍️ <span>@_comic.Author</span></div>
                    }
                    @if (_comic.ReleaseYear.HasValue)
                    {
                        <div>📅 <span>@_comic.ReleaseYear</span></div>
                    }
                    <div>📖 <strong style="color:rgba(255,255,255,0.8);">@_comic.ChapterCount</strong> bob</div>
                </div>
            </div>
        </div>
    </div>

    <!-- ═══ CHAPTER LIST ═══ -->
    <div style="max-width:1100px;margin:0 auto;padding:16px 24px 80px;">

        <!-- Chapter list header -->
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">
            <span style="font-size:1rem;font-weight:800;">
                @_chapters.Count Boblar
            </span>
            <div style="display:flex;gap:8px;align-items:center;">
                <!-- Search -->
                <div style="display:flex;align-items:center;gap:6px;padding:6px 12px;
                            background:var(--mud-palette-surface);border-radius:8px;
                            border:1px solid rgba(128,128,128,0.14);">
                    <MudIcon Icon="@Icons.Material.Filled.Search" Style="opacity:0.3;font-size:16px;" />
                    <input @bind="_chapSearch" @bind:event="oninput"
                           placeholder="Bob qidirish..."
                           style="background:transparent;border:none;outline:none;
                                  font-size:13px;color:var(--mud-palette-text-primary);width:140px;" />
                </div>
                <button @onclick="@(() => _desc = !_desc)"
                        style="padding:6px 14px;border-radius:8px;font-size:12px;font-weight:600;
                               border:1px solid rgba(128,128,128,0.2);background:transparent;
                               cursor:pointer;color:inherit;">
                    @(_desc ? "Yangi ↓" : "Eski ↑")
                </button>
            </div>
        </div>

        <!-- Chapter rows — AsuraScans style -->
        <div style="border:1px solid rgba(128,128,128,0.1);border-radius:10px;
                    background:var(--mud-palette-surface);overflow:hidden;max-height:560px;overflow-y:auto;">
            @foreach (var ch in Filtered())
            {
                <a href="/chapter/@ch.Id" style="text-decoration:none;color:inherit;">
                    <div @onmouseover="@(()=>_chapHover=ch.Id)"
                         @onmouseout="@(()=>_chapHover=Guid.Empty)"
                         style="display:flex;justify-content:space-between;align-items:center;
                                padding:12px 18px;cursor:pointer;transition:background 0.15s;
                                border-bottom:1px solid rgba(128,128,128,0.07);
                                background:@(_chapHover==ch.Id ? "rgba(124,58,237,0.07)" : "transparent");">

                        <div style="display:flex;align-items:center;gap:10px;">
                            @if (ch.IsLocked)
                            {
                                <span style="font-size:13px;color:#f59e0b;">🔒</span>
                            }
                            else
                            {
                                <span style="font-size:13px;opacity:0.25;">📖</span>
                            }
                            <div>
                                <span style="font-weight:700;font-size:14px;">Chapter @ch.ChapterNumber</span>
                                @if (!string.IsNullOrEmpty(ch.Title))
                                {
                                    <span style="font-size:13px;opacity:0.45;margin-left:6px;">@ch.Title</span>
                                }
                            </div>
                            @if (ch.IsLocked && ch.CoinPrice > 0)
                            {
                                <span style="font-size:11px;background:rgba(245,158,11,0.15);
                                             color:#f59e0b;padding:1px 8px;border-radius:10px;font-weight:700;">
                                    🪙 @ch.CoinPrice
                                </span>
                            }
                        </div>

                        <div style="display:flex;align-items:center;gap:12px;font-size:12px;opacity:0.4;">
                            @if (ch.ViewCount > 0)
                            {
                                <span>👁 @Fmt(ch.ViewCount)</span>
                            }
                            <span>@FmtDate(ch.PublishedAt)</span>
                        </div>
                    </div>
                </a>
            }

            @if (!Filtered().Any())
            {
                <div style="padding:32px;text-align:center;opacity:0.4;">Bob topilmadi.</div>
            }
        </div>
    </div>
}

@code {
    [Parameter] public string Slug { get; set; } = "";

    ComicDto?        _comic;
    List<ChapterDto> _chapters    = new();
    bool   _loading     = true;
    bool   _desc        = true;
    bool   _showMore    = false;
    string _chapSearch  = "";
    Guid   _chapHover;

    bool IsBookmarked => _comic != null && BookmarkSvc.IsBookmarked(_comic.Id);
    Guid FirstId => _chapters.OrderBy(c => c.ChapterNumber).FirstOrDefault()?.Id ?? Guid.Empty;
    Guid LastId  => _chapters.OrderByDescending(c => c.ChapterNumber).FirstOrDefault()?.Id ?? Guid.Empty;

    string CoverUrl() => !string.IsNullOrEmpty(_comic?.CoverImageUrl) ? _comic.CoverImageUrl
                       : $"https://picsum.photos/seed/{_comic?.Slug}/300/420";

    string BgUrl() => !string.IsNullOrEmpty(_comic?.BannerImageUrl) ? _comic.BannerImageUrl
                    : !string.IsNullOrEmpty(_comic?.CoverImageUrl)  ? _comic.CoverImageUrl
                    : $"https://picsum.photos/seed/{_comic?.Slug}bg/1400/500";

    string Fmt(int v) => v >= 1_000_000 ? $"{v/1_000_000.0:F1}M" : v >= 1_000 ? $"{v/1_000}K" : v.ToString();

    string FmtDate(DateTime? d)
    {
        if (d is null) return "";
        var diff = DateTime.UtcNow - d.Value;
        if (diff.TotalHours < 1)  return $"{(int)diff.TotalMinutes}m oldin";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}s oldin";
        if (diff.TotalDays  < 7)  return $"{(int)diff.TotalDays} kun oldin";
        if (diff.TotalDays  < 30) return $"{(int)(diff.TotalDays/7)} hafta oldin";
        return d.Value.ToString("dd.MM.yyyy");
    }

    List<ChapterDto> Filtered()
    {
        var list = _desc
            ? _chapters.OrderByDescending(c => c.ChapterNumber).ToList()
            : _chapters.OrderBy(c => c.ChapterNumber).ToList();
        if (!string.IsNullOrWhiteSpace(_chapSearch))
            list = list.Where(c => c.ChapterNumber.ToString().Contains(_chapSearch)
                               || (c.Title ?? "").Contains(_chapSearch, StringComparison.OrdinalIgnoreCase)).ToList();
        return list;
    }

    protected override async Task OnInitializedAsync()
    {
        _comic    = await Mediator.Send(new GetComicBySlugQuery(Slug));
        if (_comic != null)
            _chapters = await Mediator.Send(new GetChaptersByComicQuery(_comic.Id));
        _loading  = false;
    }

    string StatusBadge() => _comic?.Status switch
    {
        ComicStatus.Ongoing   => "background:rgba(5,150,105,0.2);color:#34d399;",
        ComicStatus.Completed => "background:rgba(124,58,237,0.2);color:#a78bfa;",
        ComicStatus.Hiatus    => "background:rgba(217,119,6,0.2);color:#fbbf24;",
        _                     => "background:rgba(75,85,99,0.2);color:#9ca3af;"
    };
}
