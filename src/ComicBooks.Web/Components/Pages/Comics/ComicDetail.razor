@page "/comic/{Slug}"
@inject IMediator Mediator
@inject NavigationManager Nav
@inject BookmarkService BookmarkSvc

<PageTitle>@(_comic?.Title ?? "Comic") - Manga Dunyo</PageTitle>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else if (_comic is null)
{
    <div style="text-align:center;padding:80px;">
        <MudText Typo="Typo.h4" Class="mb-4">Komik topilmadi</MudText>
        <MudButton Href="/" Variant="Variant.Filled" Color="Color.Primary" Style="text-transform:none;">Bosh sahifaga</MudButton>
    </div>
}
else
{
    <!-- ═══ BLUR BACKGROUND ═══ -->
    <div style="position:relative;min-height:520px;">
        <!-- Blurred bg image -->
        <img src="@BgUrl()" crossorigin="anonymous"
             style="position:absolute;top:0;left:0;width:100%;height:100%;
                    object-fit:cover;
                    filter:blur(18px) brightness(0.28) saturate(1.4);
                    transform:scale(1.06);z-index:0;" />
        <!-- Overlay -->
        <div style="position:absolute;inset:0;z-index:1;
                    background:linear-gradient(
                        90deg,
                        rgba(8,8,20,0.92) 0%,
                        rgba(8,8,20,0.70) 50%,
                        rgba(8,8,20,0.40) 100%);"></div>
        <div style="position:absolute;bottom:0;left:0;right:0;height:180px;z-index:1;
                    background:linear-gradient(transparent, var(--mud-palette-background));"></div>

        <!-- Content -->
        <div style="position:relative;z-index:2;max-width:1100px;margin:0 auto;padding:32px 24px 60px;
                    display:flex;gap:28px;align-items:flex-start;">

            <!-- LEFT: Cover image -->
            <div style="flex:0 0 240px;">
                <div style="border-radius:10px;overflow:hidden;box-shadow:0 20px 56px rgba(0,0,0,0.7);">
                    <img src="@CoverUrl()" alt="@_comic.Title"
                         crossorigin="anonymous"
                         style="width:240px;height:340px;object-fit:cover;display:block;"
                         onerror="this.onerror=null;this.src='https://picsum.photos/seed/@(_comic.Slug)/300/420'" />
                </div>
                <!-- Rating button below cover like AsuraScans -->
                <div style="margin-top:12px;background:rgba(245,158,11,0.15);border:1px solid rgba(245,158,11,0.4);
                            border-radius:8px;padding:8px 12px;text-align:center;cursor:pointer;">
                    <span style="color:#f59e0b;font-size:13px;font-weight:700;">★ Rating</span>
                </div>

                <!-- Stats row -->
                <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-top:10px;text-align:center;">
                    <div style="background:rgba(255,255,255,0.06);border-radius:8px;padding:8px 4px;">
                        <div style="color:#f59e0b;font-size:1.1rem;font-weight:900;">@_comic.AverageRating.ToString("F1")</div>
                        <div style="font-size:10px;opacity:0.45;margin-top:1px;">Rating</div>
                    </div>
                    <div style="background:rgba(255,255,255,0.06);border-radius:8px;padding:8px 4px;">
                        <div style="color:#22c55e;font-size:1.1rem;font-weight:900;">@_comic.ChapterCount</div>
                        <div style="font-size:10px;opacity:0.45;margin-top:1px;">Chapters</div>
                    </div>
                    <div style="background:rgba(255,255,255,0.06);border-radius:8px;padding:8px 4px;">
                        <div style="color:#60a5fa;font-size:1.1rem;font-weight:900;">@Fmt(_comic.ViewCount)</div>
                        <div style="font-size:10px;opacity:0.45;margin-top:1px;">Views</div>
                    </div>
                </div>

                <!-- Meta: Status, Type, Author, Artist -->
                <div style="margin-top:12px;font-size:12px;">
                    <div style="display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid rgba(255,255,255,0.07);">
                        <span style="opacity:0.45;">Status</span>
                        <span style="@StatusBadge();padding:2px 8px;border-radius:5px;font-size:11px;font-weight:700;">@_comic.Status</span>
                    </div>
                    <div style="display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid rgba(255,255,255,0.07);">
                        <span style="opacity:0.45;">Type</span>
                        <span style="color:#7c3aed;font-weight:700;">● @_comic.Type</span>
                    </div>
                    @if (!string.IsNullOrEmpty(_comic.Author))
                    {
                        <div style="display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid rgba(255,255,255,0.07);">
                            <span style="opacity:0.45;display:flex;align-items:center;gap:4px;">
                                <MudIcon Icon="@Icons.Material.Outlined.Edit" Style="font-size:13px;" /> Author
                            </span>
                            <span>@_comic.Author</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(_comic.Artist))
                    {
                        <div style="display:flex;justify-content:space-between;padding:6px 0;">
                            <span style="opacity:0.45;display:flex;align-items:center;gap:4px;">
                                <MudIcon Icon="@Icons.Material.Outlined.Brush" Style="font-size:13px;" /> Artist
                            </span>
                            <span>@_comic.Artist</span>
                        </div>
                    }
                </div>
            </div>

            <!-- RIGHT: Info -->
            <div style="flex:1;min-width:0;padding-top:4px;">
                <h1 style="font-size:1.8rem;font-weight:900;color:#fff;margin:0 0 6px;line-height:1.2;">
                    @_comic.Title
                </h1>

                @if (!string.IsNullOrEmpty(_comic.AlternativeTitles))
                {
                    <div style="font-size:12px;color:rgba(255,255,255,0.35);margin-bottom:14px;">
                        @_comic.AlternativeTitles
                    </div>
                }

                <!-- Description -->
                @if (!string.IsNullOrEmpty(_comic.Description))
                {
                    <div style="font-size:14px;line-height:1.8;color:rgba(255,255,255,0.78);margin-bottom:6px;
                                @(!_showMore ? "display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;" : "")">
                        @_comic.Description
                    </div>
                    <div style="margin-bottom:22px;">
                        <span style="color:#7c3aed;font-size:13px;cursor:pointer;"
                              @onclick="@(() => _showMore = !_showMore)">
                            @(_showMore ? "Show less ↑" : "Show more ↓")
                        </span>
                    </div>
                }

                <!-- 3 Buttons — Bookmark, First Chapter, Latest Chapter -->
                <div style="display:flex;gap:10px;margin-bottom:20px;">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Bookmark"
                               OnClick="@(() => BookmarkSvc.Toggle(_comic.Id))"
                               Style="border-radius:6px;text-transform:none;font-weight:700;height:44px;flex:1;">
                        @(IsBookmarked ? "Bookmarked" : "Bookmark")
                    </MudButton>
                    @if (FirstId != Guid.Empty)
                    {
                        <MudButton Href="@($"/chapter/{FirstId}")" Variant="Variant.Outlined"
                                   StartIcon="@Icons.Material.Outlined.MenuBook"
                                   Style="border-radius:6px;text-transform:none;font-weight:600;height:44px;flex:1;
                                          border-color:rgba(255,255,255,0.2);color:#fff;">
                            First Chapter
                        </MudButton>
                        <MudButton Href="@($"/chapter/{LastId}")" Variant="Variant.Outlined"
                                   StartIcon="@Icons.Material.Filled.SkipNext"
                                   Style="border-radius:6px;text-transform:none;font-weight:600;height:44px;flex:1;
                                          border-color:rgba(255,255,255,0.2);color:#fff;">
                            Latest Chapter
                        </MudButton>
                    }
                </div>

                <!-- Genres -->
                <div style="display:flex;flex-wrap:wrap;gap:6px;">
                    @foreach (var g in _comic.Genres)
                    {
                        <MudChip T="string" Size="Size.Small" Label="true"
                                 Style="background:rgba(124,58,237,0.15);color:#a78bfa;font-weight:600;">
                            @g
                        </MudChip>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- ═══ CHAPTERS ═══ -->
    <div style="max-width:1100px;margin:0 auto;padding:0 24px 60px;">

        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">
            <span style="font-size:1rem;font-weight:800;">@_chapters.Count Chapters</span>
            <MudButton Variant="Variant.Outlined" Size="Size.Small"
                       OnClick="@(() => _desc = !_desc)"
                       Style="text-transform:none;border-radius:8px;font-size:12px;">
                @(_desc ? "Newest ↓" : "Oldest ↑")
            </MudButton>
        </div>

        <!-- Search -->
        <div style="display:flex;align-items:center;gap:8px;padding:8px 14px;margin-bottom:4px;
                    background:var(--mud-palette-surface);border-radius:8px;
                    border:1px solid rgba(128,128,128,0.14);">
            <MudIcon Icon="@Icons.Material.Filled.Search" Style="opacity:0.3;font-size:18px;" />
            <input @bind="_chapSearch" @bind:event="oninput" placeholder="Search chapters..."
                   style="background:transparent;border:none;outline:none;flex:1;font-size:14px;
                          color:var(--mud-palette-text-primary);" />
        </div>

        <!-- Chapter list -->
        <div style="border:1px solid rgba(128,128,128,0.1);border-radius:8px;
                    background:var(--mud-palette-surface);max-height:520px;overflow-y:auto;">
            @foreach (var ch in Filtered())
            {
                <MudLink Href="@($"/chapter/{ch.Id}")" Underline="Underline.None" Color="Color.Default">
                    <div @onmouseover="@(()=>_chapHover=ch.Id)"
                         @onmouseout="@(()=>_chapHover=Guid.Empty)"
                         style="display:flex;justify-content:space-between;align-items:center;
                                padding:13px 16px;cursor:pointer;transition:background 0.15s;
                                border-bottom:1px solid rgba(128,128,128,0.07);
                                background:@(_chapHover==ch.Id?"rgba(124,58,237,0.07)":"transparent");">
                        <div style="display:flex;align-items:center;gap:8px;">
                            @if (ch.IsLocked && ch.CoinPrice > 0)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Small" Style="color:#f59e0b;" />
                            }
                            <div>
                                <span style="font-weight:600;font-size:14px;">Chapter @ch.ChapterNumber</span>
                                @if (!string.IsNullOrEmpty(ch.Title))
                                { <span style="font-size:13px;opacity:0.45;margin-left:6px;">- @ch.Title</span> }
                            </div>
                            @if (ch.IsLocked && ch.CoinPrice > 0)
                            {
                                <span style="font-size:11px;background:rgba(245,158,11,0.15);color:#f59e0b;
                                            padding:1px 7px;border-radius:8px;font-weight:700;">
                                    🪙 @ch.CoinPrice
                                </span>
                            }
                        </div>
                        <span style="font-size:12px;opacity:0.38;white-space:nowrap;">@FmtDate(ch.PublishedAt)</span>
                    </div>
                </MudLink>
            }
        </div>
    </div>
}

@code {
    [Parameter] public string Slug { get; set; } = "";

    ComicDto?        _comic;
    List<ChapterDto> _chapters    = new();
    bool  _loading = true, _desc = true, _showMore = false;
    string _chapSearch = "";
    Guid  _chapHover;

    bool IsBookmarked => _comic != null && BookmarkSvc.IsBookmarked(_comic.Id);
    Guid FirstId => _chapters.OrderBy(c => c.ChapterNumber).FirstOrDefault()?.Id ?? Guid.Empty;
    Guid LastId  => _chapters.OrderByDescending(c => c.ChapterNumber).FirstOrDefault()?.Id ?? Guid.Empty;

    string CoverUrl() => !string.IsNullOrEmpty(_comic?.CoverImageUrl) ? _comic.CoverImageUrl : $"https://picsum.photos/seed/{_comic?.Slug}/300/420";
    string BgUrl()    => !string.IsNullOrEmpty(_comic?.BannerImageUrl) ? _comic.BannerImageUrl : CoverUrl();
    string Fmt(int v) => v >= 1_000_000 ? $"{v/1_000_000.0:F1}M" : v >= 1_000 ? $"{v/1_000}K" : v.ToString();

    string FmtDate(DateTime? d)
    {
        if (d is null) return "";
        var diff = DateTime.UtcNow - d.Value;
        if (diff.TotalHours < 1)  return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays  < 7)  return $"{(int)diff.TotalDays} days ago";
        if (diff.TotalDays  < 30) return $"{(int)(diff.TotalDays/7)} weeks ago";
        return d.Value.ToString("MMM d, yyyy");
    }

    List<ChapterDto> Filtered()
    {
        var list = _desc
            ? _chapters.OrderByDescending(c => c.ChapterNumber).ToList()
            : _chapters.OrderBy(c => c.ChapterNumber).ToList();
        if (!string.IsNullOrWhiteSpace(_chapSearch))
            list = list.Where(c => c.ChapterNumber.ToString().Contains(_chapSearch)
                               || (c.Title ?? "").Contains(_chapSearch, StringComparison.OrdinalIgnoreCase)).ToList();
        return list;
    }

    protected override async Task OnInitializedAsync()
    {
        _comic    = await Mediator.Send(new GetComicBySlugQuery(Slug));
        if (_comic != null)
            _chapters = await Mediator.Send(new GetChaptersByComicQuery(_comic.Id));
        _loading = false;
    }

    string StatusBadge() => _comic?.Status switch
    {
        ComicStatus.Ongoing   => "background:rgba(5,150,105,0.2);color:#34d399;",
        ComicStatus.Completed => "background:rgba(124,58,237,0.2);color:#a78bfa;",
        ComicStatus.Hiatus    => "background:rgba(217,119,6,0.2);color:#fbbf24;",
        _                     => "background:rgba(75,85,99,0.2);color:#9ca3af;"
    };
}
