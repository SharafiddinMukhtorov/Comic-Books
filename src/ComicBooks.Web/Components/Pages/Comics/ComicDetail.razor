@page "/comic/{Slug}"
@rendermode InteractiveServer
@inject IMediator Mediator
@inject NavigationManager Nav
@inject BookmarkService BookmarkSvc

<PageTitle>@(_comic?.Title ?? "Komik") - AsuraComic</PageTitle>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else if (_comic is null)
{
    <div style="text-align:center;padding:80px 16px;">
        <MudText Typo="Typo.h4" Class="mb-4">Komik topilmadi</MudText>
        <MudButton Href="/" Variant="Variant.Filled" Color="Color.Primary"
                   Style="border-radius:20px;text-transform:none;">
            Bosh sahifaga qaytish
        </MudButton>
    </div>
}
else
{
    <!-- Blurred banner -->
    <div style="position:relative;height:260px;overflow:hidden;">
        <img src="@CoverUrl()"
             style="width:100%;height:100%;object-fit:cover;filter:blur(6px) brightness(0.3);display:block;"
             onerror="this.onerror=null;this.src='https://picsum.photos/seed/@(_comic.Slug)bg/1200/400'" />
        <div style="position:absolute;inset:0;background:linear-gradient(to bottom,rgba(0,0,0,0.1),var(--mud-palette-background));"></div>
    </div>

    <div style="max-width:1200px;margin:-100px auto 0;padding:0 16px 48px;position:relative;z-index:2;">

        <!-- Back button -->
        <MudButton Href="/" Variant="Variant.Text"
                   StartIcon="@Icons.Material.Filled.ArrowBack"
                   Style="text-transform:none;margin-bottom:12px;">
            Bosh sahifaga qaytish
        </MudButton>

        <MudGrid Spacing="3">
            <!-- Cover image -->
            <MudItem xs="12" sm="3" md="2">
                <div style="border-radius:14px;overflow:hidden;box-shadow:0 20px 50px rgba(0,0,0,0.5);">
                    <img src="@CoverUrl()" alt="@_comic.Title"
                         style="width:100%;display:block;aspect-ratio:2/3;object-fit:cover;"
                         onerror="this.onerror=null;this.src='https://picsum.photos/seed/@(_comic.Slug)/300/420'" />
                </div>
            </MudItem>

            <!-- Info -->
            <MudItem xs="12" sm="9" md="10">
                <MudText Typo="Typo.h4" Style="font-weight:900;margin-bottom:8px;">@_comic.Title</MudText>

                @if (!string.IsNullOrEmpty(_comic.AlternativeTitles))
                {
                    <div style="font-size:13px;opacity:0.4;font-style:italic;margin-bottom:10px;">@_comic.AlternativeTitles</div>
                }

                <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;margin-bottom:14px;">
                    <span style="font-size:1.4rem;font-weight:900;color:#f59e0b;">★ @_comic.AverageRating.ToString("F1")</span>
                    <span style="@BadgeStyle();font-size:12px;font-weight:700;padding:4px 14px;border-radius:12px;">@StatusUz()</span>
                    <span style="background:rgba(124,58,237,0.15);color:#7c3aed;font-size:12px;font-weight:600;padding:4px 14px;border-radius:12px;">@_comic.Type</span>
                    <span style="font-size:13px;opacity:0.4;">@FormatViews(_comic.ViewCount) marta ko'rildi</span>
                </div>

                <!-- Genres -->
                <div style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:16px;">
                    @foreach (var g in _comic.Genres)
                    {
                        <MudLink Href="@($"/comics?search={Uri.EscapeDataString(g)}")"
                                 Underline="Underline.None">
                            <span style="background:rgba(124,58,237,0.12);color:#7c3aed;font-size:12px;font-weight:600;padding:5px 14px;border-radius:20px;cursor:pointer;">@g</span>
                        </MudLink>
                    }
                </div>

                <!-- Action buttons -->
                <div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:16px;">
                    @if (_chapters.Any())
                    {
                        var firstId = _chapters.OrderBy(c => c.ChapterNumber).First().Id;
                        var lastId  = _chapters.OrderByDescending(c => c.ChapterNumber).First().Id;
                        <MudButton Href="@($"/chapter/{firstId}")"
                                   Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                                   Style="border-radius:22px;font-weight:700;text-transform:none;">
                            ▶ O'qishni boshlash
                        </MudButton>
                        <MudButton Href="@($"/chapter/{lastId}")"
                                   Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Large"
                                   Style="border-radius:22px;text-transform:none;">
                            So'nggi bob →
                        </MudButton>
                    }
                    <MudButton Variant="Variant.Outlined"
                               Color="@(IsBookmarked ? Color.Primary : Color.Default)"
                               Size="Size.Large"
                               Style="border-radius:22px;text-transform:none;"
                               OnClick="@(() => BookmarkSvc.Toggle(_comic.Id))">
                        @(IsBookmarked ? "🔖 Saralangan" : "🔖 Saralash")
                    </MudButton>
                </div>

                <!-- Meta -->
                <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:8px;font-size:13px;opacity:0.85;">
                    @if (!string.IsNullOrEmpty(_comic.Author))
                    { <div><span style="opacity:0.45;">Muallif: </span><strong>@_comic.Author</strong></div> }
                    @if (!string.IsNullOrEmpty(_comic.Artist))
                    { <div><span style="opacity:0.45;">Rassom: </span><strong>@_comic.Artist</strong></div> }
                    @if (_comic.ReleaseYear.HasValue)
                    { <div><span style="opacity:0.45;">Yil: </span><strong>@_comic.ReleaseYear</strong></div> }
                    <div><span style="opacity:0.45;">Boblar: </span><strong>@_comic.ChapterCount</strong></div>
                </div>
            </MudItem>
        </MudGrid>

        <!-- Synopsis -->
        @if (!string.IsNullOrEmpty(_comic.Description))
        {
            <MudPaper Elevation="1" Class="pa-5 mt-5" Style="border-radius:14px;">
                <MudText Typo="Typo.h6" Class="font-bold mb-3">📖 Qisqacha mazmun</MudText>
                <MudText Style="line-height:1.9;opacity:0.85;">@_comic.Description</MudText>
            </MudPaper>
        }

        <!-- Chapter list -->
        <MudPaper Elevation="1" Class="pa-5 mt-4" Style="border-radius:14px;">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;">
                <MudText Typo="Typo.h6" Class="font-bold">📋 Boblar ro'yxati (@_chapters.Count)</MudText>
                <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Primary"
                           Style="text-transform:none;"
                           OnClick="@(() => _desc = !_desc)">
                    @(_desc ? "⬆ Eski avval" : "⬇ Yangi avval")
                </MudButton>
            </div>
            <div style="max-height:520px;overflow-y:auto;">
                @foreach (var ch in SortedChapters())
                {
                    <MudLink Href="@($"/chapter/{ch.Id}")" Underline="Underline.None" Color="Color.Default">
                        <div style="display:flex;justify-content:space-between;align-items:center;
                                    padding:11px 12px;border-radius:8px;cursor:pointer;
                                    transition:background 0.15s;"
                             @onmouseover="@(_ => _hover = ch.Id)"
                             @onmouseout="@(_ => _hover = Guid.Empty)"
                             style="@(_hover == ch.Id ? "background:rgba(124,58,237,0.1);" : "")">
                            <div>
                                <span style="color:#7c3aed;font-weight:800;margin-right:6px;">@ch.ChapterNumber-bob</span>
                                @if (!string.IsNullOrEmpty(ch.Title))
                                {
                                    <span style="font-size:13px;opacity:0.7;">@ch.Title</span>
                                }
                            </div>
                            <div style="display:flex;gap:12px;font-size:12px;opacity:0.4;flex-shrink:0;">
                                <span>@ch.PageCount bet</span>
                                <span>@ch.PublishedAt?.ToString("dd.MM.yyyy")</span>
                            </div>
                        </div>
                    </MudLink>
                }
            </div>
        </MudPaper>
    </div>
}

@code {
    [Parameter] public string Slug { get; set; } = "";

    ComicDto? _comic;
    List<ChapterDto> _chapters = new();
    bool _loading = true;
    bool _desc = true;
    Guid _hover;

    bool IsBookmarked => _comic != null && BookmarkSvc.IsBookmarked(_comic.Id);
    string CoverUrl() => !string.IsNullOrEmpty(_comic?.CoverImageUrl) ? _comic.CoverImageUrl : $"https://picsum.photos/seed/{_comic?.Slug}/300/420";

    List<ChapterDto> SortedChapters() => _desc
        ? _chapters.OrderByDescending(c => c.ChapterNumber).ToList()
        : _chapters.OrderBy(c => c.ChapterNumber).ToList();

    protected override async Task OnInitializedAsync()
    {
        _comic = await Mediator.Send(new GetComicBySlugQuery(Slug));
        if (_comic != null)
            _chapters = await Mediator.Send(new GetChaptersByComicQuery(_comic.Id));
        _loading = false;
    }

    string BadgeStyle() => _comic?.Status switch
    {
        ComicStatus.Ongoing   => "background:#059669;color:#fff",
        ComicStatus.Completed => "background:#7c3aed;color:#fff",
        ComicStatus.Hiatus    => "background:#d97706;color:#fff",
        _                     => "background:#4b5563;color:#fff"
    };

    string StatusUz() => _comic?.Status switch
    {
        ComicStatus.Ongoing   => "Davom etmoqda",
        ComicStatus.Completed => "Tugallangan",
        ComicStatus.Hiatus    => "To'xtatilgan",
        _                     => _comic?.Status.ToString() ?? ""
    };

    string FormatViews(int v) => v >= 1_000_000 ? $"{v/1_000_000.0:F1}M" : v >= 1_000 ? $"{v/1_000}K" : v.ToString();
}
