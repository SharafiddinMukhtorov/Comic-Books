@page "/admin/comics/create"
@page "/admin/comics/edit/{Id:guid}"
@layout AdminLayout
@inject IMediator Mediator
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>@(IsEdit ? "Tahrirlash" : "Yangi komik") - Admin</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">@(IsEdit ? "✏️ Komikni tahrirlash" : "➕ Yangi komik")</MudText>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    <MudText Class="mt-2" Style="opacity:0.5;">Yuklanmoqda...</MudText>
}
else
{
<MudGrid>
    <MudItem xs="12" md="8">
        <MudPaper Class="pa-4 mb-4">
            <MudTextField @bind-Value="_title"     Label="Nomi *"       Variant="Variant.Outlined" Class="mb-3" />
            <MudTextField @bind-Value="_altTitles" Label="Boshqa nomlar" Variant="Variant.Outlined" Class="mb-3" />
            <MudTextField @bind-Value="_desc"      Label="Tavsif"        Variant="Variant.Outlined" Lines="5" Class="mb-3" />
            <MudGrid>
                <MudItem xs="6"><MudTextField @bind-Value="_author" Label="Muallif" Variant="Variant.Outlined" /></MudItem>
                <MudItem xs="6"><MudTextField @bind-Value="_artist" Label="Rassom"  Variant="Variant.Outlined" /></MudItem>
            </MudGrid>
            <MudTextField @bind-Value="_coverUrl"  Label="Muqova URL"  Variant="Variant.Outlined" Class="mt-3" />
            <MudTextField @bind-Value="_bannerUrl" Label="Banner URL"   Variant="Variant.Outlined" Class="mt-3" />
        </MudPaper>

        <MudPaper Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-3">Janrlar va Teglar</MudText>
            <MudSelect T="Guid"
                           SelectedValues="@_genreIds"
                           SelectedValuesChanged="@((IEnumerable<Guid> v) => _genreIds = v.ToList())"
                           Label="Janrlar"
                           MultiSelection="true" Variant="Variant.Outlined" Class="mb-3">
                @foreach (var g in _genres)
                { <MudSelectItem T="Guid" Value="@g.Id">@g.Name</MudSelectItem> }
            </MudSelect>
            <MudSelect T="Guid"
                           SelectedValues="@_tagIds"
                           SelectedValuesChanged="@((IEnumerable<Guid> v) => _tagIds = v.ToList())"
                           Label="Teglar"
                           MultiSelection="true" Variant="Variant.Outlined">
                @foreach (var t in _tags)
                { <MudSelectItem T="Guid" Value="@t.Id">@t.Name</MudSelectItem> }
            </MudSelect>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="4">
        @if (!string.IsNullOrEmpty(_coverUrl))
        {
            <MudPaper Class="pa-4 mb-4">
                <MudText Typo="Typo.subtitle2" Class="mb-2">Muqova</MudText>
                <img src="@_coverUrl" style="width:100%;border-radius:8px;max-height:280px;object-fit:cover;" onerror="this.style.display='none'" />
            </MudPaper>
        }

        <MudPaper Class="pa-4">
            <MudSelect T="ComicStatus" @bind-Value="_status" Label="Holati" Variant="Variant.Outlined" Class="mb-3">
                <MudSelectItem T="ComicStatus" Value="@ComicStatus.Ongoing">Davom etmoqda</MudSelectItem>
                <MudSelectItem T="ComicStatus" Value="@ComicStatus.Completed">Tugallangan</MudSelectItem>
                <MudSelectItem T="ComicStatus" Value="@ComicStatus.Hiatus">To'xtatilgan</MudSelectItem>
                <MudSelectItem T="ComicStatus" Value="@ComicStatus.Cancelled">Bekor qilingan</MudSelectItem>
            </MudSelect>

            <MudSelect T="ComicType" @bind-Value="_type" Label="Turi" Variant="Variant.Outlined" Class="mb-3">
                <MudSelectItem T="ComicType" Value="@ComicType.Manhwa">Manhwa</MudSelectItem>
                <MudSelectItem T="ComicType" Value="@ComicType.Manga">Manga</MudSelectItem>
                <MudSelectItem T="ComicType" Value="@ComicType.Manhua">Manhua</MudSelectItem>
                <MudSelectItem T="ComicType" Value="@ComicType.Comic">Comic</MudSelectItem>
            </MudSelect>

            <MudSelect T="ContentRating" @bind-Value="_rating" Label="Yosh chegarasi" Variant="Variant.Outlined" Class="mb-3">
                <MudSelectItem T="ContentRating" Value="@ContentRating.Everyone">Hammaga</MudSelectItem>
                <MudSelectItem T="ContentRating" Value="@ContentRating.Teen">O'smirlar (13+)</MudSelectItem>
                <MudSelectItem T="ContentRating" Value="@ContentRating.Mature">Kattalar (18+)</MudSelectItem>
            </MudSelect>

            <MudNumericField T="int?" @bind-Value="_year" Label="Yil" Variant="Variant.Outlined" Class="mb-3" Min="1950" Max="2030" />

            <MudCheckBox T="bool" @bind-Checked="_featured" Label="Featured" Color="Color.Primary" Class="mb-1" />
            <MudCheckBox T="bool" @bind-Checked="_popular"  Label="Mashhur"  Color="Color.Secondary" Class="mb-4" />

            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                       OnClick="@Save" Disabled="@_saving" Style="height:48px;text-transform:none;font-weight:700;">
                @(_saving ? "Saqlanmoqda..." : (IsEdit ? "Saqlash" : "Qo'shish"))
            </MudButton>
            <MudButton Href="/admin/comics" Variant="Variant.Outlined" FullWidth="true" Class="mt-2" Style="text-transform:none;">
                ← Orqaga
            </MudButton>
        </MudPaper>
    </MudItem>
</MudGrid>
}

@code {
    [Parameter] public Guid Id { get; set; }
    bool IsEdit => Id != Guid.Empty;

    string _title = "", _altTitles = "", _desc = "", _author = "", _artist = "", _coverUrl = "", _bannerUrl = "";
    ComicStatus   _status  = ComicStatus.Ongoing;
    ComicType     _type    = ComicType.Manhwa;
    ContentRating _rating  = ContentRating.Teen;
    int?          _year;
    bool          _featured, _popular;
    List<Guid> _genreIds = new();
    List<Guid> _tagIds = new();

    List<GenreDto> _genres = new();
    List<TagDto>   _tags   = new();
    bool _loading = true;
    bool _saving  = false;
    Guid _loadedId;

    protected override async Task OnInitializedAsync()
    {
        _genres = await Mediator.Send(new GetAllGenresQuery());
        _tags   = await Mediator.Send(new GetAllTagsQuery());

        if (IsEdit)
            await LoadComic();

        _loadedId = Id;
        _loading  = false;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (Id != _loadedId && _loadedId != Guid.Empty)
        {
            _loadedId = Id;
            _loading  = true;
            StateHasChanged();

            _genres = await Mediator.Send(new GetAllGenresQuery());
            _tags   = await Mediator.Send(new GetAllTagsQuery());
            if (IsEdit) await LoadComic();
            else Reset();

            _loading = false;
        }
    }

    async Task LoadComic()
    {
        var c = await Mediator.Send(new GetComicByIdQuery(Id));
        if (c is null) { Nav.NavigateTo("/admin/comics"); return; }

        _title = c.Title ?? ""; _altTitles = c.AlternativeTitles ?? "";
        _desc = c.Description ?? ""; _author = c.Author ?? "";
        _artist = c.Artist ?? ""; _coverUrl = c.CoverImageUrl ?? "";
        _bannerUrl = c.BannerImageUrl ?? ""; _status = c.Status;
        _type = c.Type; _rating = c.Rating; _year = c.ReleaseYear;
        _featured = c.IsFeatured; _popular = c.IsPopular;

        var gMap = _genres.ToDictionary(g => g.Name, g => g.Id, StringComparer.OrdinalIgnoreCase);
        _genreIds = c.Genres.Where(n => gMap.ContainsKey(n)).Select(n => gMap[n]).ToList();

        var tMap = _tags.ToDictionary(t => t.Name, t => t.Id, StringComparer.OrdinalIgnoreCase);
        _tagIds = c.Tags.Where(n => tMap.ContainsKey(n)).Select(n => tMap[n]).ToList();
    }

    void Reset()
    {
        _title = ""; _altTitles = ""; _desc = ""; _author = ""; _artist = ""; _coverUrl = ""; _bannerUrl = "";
        _status = ComicStatus.Ongoing; _type = ComicType.Manhwa; _rating = ContentRating.Teen;
        _year = null; _featured = false; _popular = false;
        _genreIds = new List<Guid>(); _tagIds = new List<Guid>();
    }

    async Task Save()
    {
        if (string.IsNullOrWhiteSpace(_title)) { Snackbar.Add("Nomni kiriting!", Severity.Warning); return; }
        _saving = true;
        try
        {
            if (!IsEdit)
                await Mediator.Send(new CreateComicCommand(_title, _altTitles, _desc, _coverUrl, _bannerUrl, _status, _type, _rating, _author, _artist, _year, _featured, _popular, _genreIds.ToList(), _tagIds.ToList()));
            else
                await Mediator.Send(new UpdateComicCommand(Id, _title, _altTitles, _desc, _coverUrl, _bannerUrl, _status, _type, _rating, _author, _artist, _year, _featured, _popular, _genreIds.ToList(), _tagIds.ToList()));

            Snackbar.Add("✅ Saqlandi!", Severity.Success);
            Nav.NavigateTo("/admin/comics");
        }
        catch (Exception ex) { Snackbar.Add($"Xatolik: {ex.Message}", Severity.Error); }
        finally { _saving = false; }
    }
}
