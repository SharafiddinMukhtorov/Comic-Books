@page "/admin/comics/create"
@page "/admin/comics/edit/{Id:guid}"
@layout AdminLayout
@rendermode InteractiveServer
@inject IMediator Mediator
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>@(_isEdit ? "Komikni tahrirlash" : "Yangi komik") - Admin</PageTitle>

<div style="display:flex; align-items:center; gap:8px; margin-bottom:24px;">
    <MudButton Variant="Variant.Text" Color="Color.Default"
               StartIcon="@Icons.Material.Filled.ArrowBack"
               OnClick="@(() => Nav.NavigateTo("/admin/comics"))"
               Style="text-transform:none;">Orqaga</MudButton>
    <MudText Typo="Typo.h5" Class="font-bold">
        @(_isEdit ? "Komikni tahrirlash" : "Yangi komik qo'shish")
    </MudText>
</div>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else
{
    <MudGrid>
        <!-- Left: Main fields -->
        <MudItem xs="12" md="8">
            <MudPaper Elevation="2" Class="pa-5 mb-4" Style="border-radius:12px;">
                <MudText Typo="Typo.h6" Class="mb-4 font-bold">Asosiy ma'lumotlar</MudText>

                <MudTextField @bind-Value="_title" Label="Nomi *" Variant="Variant.Outlined" Class="mb-3" />
                <MudTextField @bind-Value="_altTitles" Label="Boshqa nomlar" Variant="Variant.Outlined" Class="mb-3"
                              HelperText="Vergul bilan ajrating" />
                <MudTextField @bind-Value="_desc" Label="Tavsif" Lines="5" Variant="Variant.Outlined" Class="mb-3" />
                <MudGrid>
                    <MudItem xs="6"><MudTextField @bind-Value="_author" Label="Muallif" Variant="Variant.Outlined" /></MudItem>
                    <MudItem xs="6"><MudTextField @bind-Value="_artist" Label="Rassom" Variant="Variant.Outlined" /></MudItem>
                </MudGrid>
                <MudTextField @bind-Value="_coverUrl" Label="Muqova rasmi URL" Variant="Variant.Outlined" Class="mt-3"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Image" />
                <MudTextField @bind-Value="_bannerUrl" Label="Banner rasmi URL" Variant="Variant.Outlined" Class="mt-3"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Wallpaper" />
            </MudPaper>

            <MudPaper Elevation="2" Class="pa-5" Style="border-radius:12px;">
                <MudText Typo="Typo.h6" Class="mb-4 font-bold">Janrlar va Teglar</MudText>
                <MudSelect T="Guid" @bind-SelectedValues="_genreIds"
                           Label="Janrlar" MultiSelection="true"
                           Variant="Variant.Outlined" Class="mb-3">
                    @foreach (var g in _genres)
                    {
                        <MudSelectItem T="Guid" Value="@g.Id">@g.Name</MudSelectItem>
                    }
                </MudSelect>
                <MudSelect T="Guid" @bind-SelectedValues="_tagIds"
                           Label="Teglar" MultiSelection="true" Variant="Variant.Outlined">
                    @foreach (var t in _tags)
                    {
                        <MudSelectItem T="Guid" Value="@t.Id">@t.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudPaper>
        </MudItem>

        <!-- Right: Settings -->
        <MudItem xs="12" md="4">
            @if (!string.IsNullOrEmpty(_coverUrl))
            {
                <MudPaper Elevation="2" Class="pa-4 mb-4" Style="border-radius:12px;">
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Muqova ko'rinishi</MudText>
                    <img src="@_coverUrl" alt="Muqova"
                         style="width:100%; border-radius:8px; max-height:300px; object-fit:cover; display:block;"
                         onerror="this.style.display='none'" />
                </MudPaper>
            }

            <MudPaper Elevation="2" Class="pa-5" Style="border-radius:12px;">
                <MudText Typo="Typo.h6" Class="mb-4 font-bold">Sozlamalar</MudText>

                <MudSelect T="ComicStatus" @bind-Value="_status" Label="Holati" Variant="Variant.Outlined" Class="mb-3">
                    <MudSelectItem T="ComicStatus" Value="ComicStatus.Ongoing">Davom etmoqda</MudSelectItem>
                    <MudSelectItem T="ComicStatus" Value="ComicStatus.Completed">Tugallangan</MudSelectItem>
                    <MudSelectItem T="ComicStatus" Value="ComicStatus.Hiatus">To'xtatilgan</MudSelectItem>
                    <MudSelectItem T="ComicStatus" Value="ComicStatus.Cancelled">Bekor qilingan</MudSelectItem>
                </MudSelect>

                <MudSelect T="ComicType" @bind-Value="_type" Label="Turi" Variant="Variant.Outlined" Class="mb-3">
                    <MudSelectItem T="ComicType" Value="ComicType.Manhwa">Manhwa</MudSelectItem>
                    <MudSelectItem T="ComicType" Value="ComicType.Manga">Manga</MudSelectItem>
                    <MudSelectItem T="ComicType" Value="ComicType.Manhua">Manhua</MudSelectItem>
                    <MudSelectItem T="ComicType" Value="ComicType.Comic">Comic</MudSelectItem>
                </MudSelect>

                <MudSelect T="ContentRating" @bind-Value="_rating" Label="Yosh chegarasi" Variant="Variant.Outlined" Class="mb-3">
                    <MudSelectItem T="ContentRating" Value="ContentRating.Everyone">Hammaga</MudSelectItem>
                    <MudSelectItem T="ContentRating" Value="ContentRating.Teen">O'smirlar</MudSelectItem>
                    <MudSelectItem T="ContentRating" Value="ContentRating.Mature">Kattalar</MudSelectItem>
                </MudSelect>

                <MudNumericField T="int?" @bind-Value="_year" Label="Chiqarilgan yil"
                                 Variant="Variant.Outlined" Class="mb-3" Min="1900" Max="2030" />

                <MudSwitch T="bool" @bind-Value="_featured" Label="Featured (Tanlangan)" Color="Color.Primary" Class="mb-2" />
                <MudSwitch T="bool" @bind-Value="_popular"  Label="Mashhur" Color="Color.Primary" Class="mb-4" />

                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                           Size="Size.Large" OnClick="@Save" Disabled="@_saving"
                           StartIcon="@Icons.Material.Filled.Save"
                           Style="border-radius:10px; text-transform:none; font-weight:700; font-size:1rem;">
                    @(_saving ? "Saqlanmoqda..." : (_isEdit ? "O'zgarishlarni saqlash" : "Komikni qo'shish"))
                </MudButton>
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter] public Guid Id { get; set; }
    bool _isEdit => Id != Guid.Empty;

    string _title = "", _altTitles = "", _desc = "", _author = "", _artist = "", _coverUrl = "", _bannerUrl = "";
    ComicStatus _status = ComicStatus.Ongoing;
    ComicType _type = ComicType.Manhwa;
    ContentRating _rating = ContentRating.Teen;
    int? _year;
    bool _featured, _popular;
    IEnumerable<Guid> _genreIds = new HashSet<Guid>();
    IEnumerable<Guid> _tagIds   = new HashSet<Guid>();
    List<GenreDto> _genres = new();
    List<TagDto>   _tags   = new();
    bool _loading = true, _saving;

    protected override async Task OnInitializedAsync()
    {
        _genres = await Mediator.Send(new GetAllGenresQuery());
        _tags   = await Mediator.Send(new GetAllTagsQuery());
        _loading = false;
    }

    async Task Save()
    {
        if (string.IsNullOrWhiteSpace(_title))
        {
            Snackbar.Add("Komik nomi kiritilishi shart!", Severity.Warning);
            return;
        }
        _saving = true;
        try
        {
            if (!_isEdit)
            {
                await Mediator.Send(new CreateComicCommand(
                    _title, _altTitles, _desc, _coverUrl, _bannerUrl,
                    _status, _type, _rating, _author, _artist, _year,
                    _featured, _popular,
                    _genreIds.ToList(), _tagIds.ToList()));
                Snackbar.Add("Komik muvaffaqiyatli qo'shildi! ✅", Severity.Success);
            }
            else
            {
                await Mediator.Send(new UpdateComicCommand(
                    Id, _title, _altTitles, _desc, _coverUrl, _bannerUrl,
                    _status, _type, _rating, _author, _artist, _year,
                    _featured, _popular,
                    _genreIds.ToList(), _tagIds.ToList()));
                Snackbar.Add("O'zgarishlar saqlandi! ✅", Severity.Success);
            }
            Nav.NavigateTo("/admin/comics");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Xatolik: {ex.Message}", Severity.Error);
        }
        finally { _saving = false; }
    }
}
