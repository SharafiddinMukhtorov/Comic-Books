@page "/admin/comics/create"
@page "/admin/comics/edit/{Id:guid}"
@layout AdminLayout
@rendermode InteractiveServer
@inject IMediator Mediator
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>@(_isEdit ? "Edit Comic" : "Create Comic") - Admin</PageTitle>

<div class="d-flex align-center gap-2 mb-6">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Href="/admin/comics" />
    <MudText Typo="Typo.h5" Class="font-bold">
        @(_isEdit ? "Edit Comic" : "Create New Comic")
    </MudText>
</div>

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudGrid>
        <MudItem xs="12" md="8">
            <MudPaper Elevation="2" Class="pa-6" Style="border-radius:12px;">
                <MudText Typo="Typo.h6" Class="mb-4">Basic Information</MudText>

                <MudTextField @bind-Value="_title"
                              Label="Title *"
                              Variant="Variant.Outlined"
                              Class="mb-4"
                              Required="true" />

                <MudTextField @bind-Value="_alternativeTitles"
                              Label="Alternative Titles"
                              Variant="Variant.Outlined"
                              Class="mb-4"
                              HelperText="Separate with semicolons" />

                <MudTextField @bind-Value="_description"
                              Label="Description"
                              Lines="6"
                              Variant="Variant.Outlined"
                              Class="mb-4" />

                <MudGrid>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_author"
                                      Label="Author"
                                      Variant="Variant.Outlined"
                                      Class="mb-4" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_artist"
                                      Label="Artist"
                                      Variant="Variant.Outlined"
                                      Class="mb-4" />
                    </MudItem>
                </MudGrid>

                <MudTextField @bind-Value="_coverImageUrl"
                              Label="Cover Image URL"
                              Variant="Variant.Outlined"
                              Class="mb-4"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Image" />

                <MudTextField @bind-Value="_bannerImageUrl"
                              Label="Banner Image URL"
                              Variant="Variant.Outlined"
                              Class="mb-4"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Wallpaper" />
            </MudPaper>

            <MudPaper Elevation="2" Class="pa-6 mt-4" Style="border-radius:12px;">
                <MudText Typo="Typo.h6" Class="mb-4">Genres &amp; Tags</MudText>

                <MudSelect T="Guid"
                           @bind-SelectedValues="_selectedGenreIds"
                           Label="Genres"
                           MultiSelection="true"
                           Variant="Variant.Outlined"
                           Class="mb-4">
                    @foreach (var genre in _genres)
                    {
                        <MudSelectItem T="Guid" Value="@genre.Id">@genre.Name</MudSelectItem>
                    }
                </MudSelect>

                <MudSelect T="Guid"
                           @bind-SelectedValues="_selectedTagIds"
                           Label="Tags"
                           MultiSelection="true"
                           Variant="Variant.Outlined">
                    @foreach (var tag in _tags)
                    {
                        <MudSelectItem T="Guid" Value="@tag.Id">@tag.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4">
            @if (!string.IsNullOrEmpty(_coverImageUrl))
            {
                <MudPaper Elevation="2" Class="pa-4 mb-4" Style="border-radius:12px;">
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Cover Preview</MudText>
                    <img src="@_coverImageUrl"
                         alt="Cover Preview"
                         style="width:100%; border-radius:8px; max-height:320px; object-fit:cover; display:block;" />
                </MudPaper>
            }

            <MudPaper Elevation="2" Class="pa-6" Style="border-radius:12px;">
                <MudText Typo="Typo.h6" Class="mb-4">Settings</MudText>

                <MudSelect T="ComicStatus"
                           @bind-Value="_status"
                           Label="Status"
                           Variant="Variant.Outlined"
                           Class="mb-4">
                    @foreach (ComicStatus s in Enum.GetValues<ComicStatus>())
                    {
                        <MudSelectItem T="ComicStatus" Value="@s">@s</MudSelectItem>
                    }
                </MudSelect>

                <MudSelect T="ComicType"
                           @bind-Value="_type"
                           Label="Type"
                           Variant="Variant.Outlined"
                           Class="mb-4">
                    @foreach (ComicType t in Enum.GetValues<ComicType>())
                    {
                        <MudSelectItem T="ComicType" Value="@t">@t</MudSelectItem>
                    }
                </MudSelect>

                <MudSelect T="ContentRating"
                           @bind-Value="_rating"
                           Label="Content Rating"
                           Variant="Variant.Outlined"
                           Class="mb-4">
                    @foreach (ContentRating r in Enum.GetValues<ContentRating>())
                    {
                        <MudSelectItem T="ContentRating" Value="@r">@r</MudSelectItem>
                    }
                </MudSelect>

                <MudNumericField T="int?"
                                 @bind-Value="_releaseYear"
                                 Label="Release Year"
                                 Variant="Variant.Outlined"
                                 Class="mb-4"
                                 Min="1900"
                                 Max="2030" />

                <MudSwitch T="bool"
                           @bind-Value="_isFeatured"
                           Label="Featured"
                           Color="Color.Primary"
                           Class="mb-2" />

                <MudSwitch T="bool"
                           @bind-Value="_isPopular"
                           Label="Popular"
                           Color="Color.Primary"
                           Class="mb-4" />

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Size="Size.Large"
                           OnClick="@Submit"
                           Disabled="@_saving"
                           StartIcon="@Icons.Material.Filled.Save"
                           Style="border-radius:8px;">
                    @(_saving ? "Saving..." : (_isEdit ? "Save Changes" : "Create Comic"))
                </MudButton>
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private bool _isEdit => Id != Guid.Empty;

    private string _title = "";
    private string? _alternativeTitles;
    private string? _description;
    private string? _coverImageUrl;
    private string? _bannerImageUrl;
    private ComicStatus _status = ComicStatus.Ongoing;
    private ComicType _type = ComicType.Manhwa;
    private ContentRating _rating = ContentRating.Teen;
    private string? _author;
    private string? _artist;
    private int? _releaseYear;
    private bool _isFeatured;
    private bool _isPopular;

    private List<GenreDto> _genres = new();
    private List<TagDto> _tags = new();
    private IEnumerable<Guid> _selectedGenreIds = new HashSet<Guid>();
    private IEnumerable<Guid> _selectedTagIds = new HashSet<Guid>();
    private bool _loading = true;
    private bool _saving;

    protected override async Task OnInitializedAsync()
    {
        _genres = await Mediator.Send(new GetAllGenresQuery());
        _tags = await Mediator.Send(new GetAllTagsQuery());
        _loading = false;
    }

    private async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(_title))
        {
            Snackbar.Add("Title is required.", Severity.Error);
            return;
        }

        _saving = true;
        try
        {
            if (!_isEdit)
            {
                await Mediator.Send(new CreateComicCommand(
                    _title, _alternativeTitles, _description,
                    _coverImageUrl, _bannerImageUrl,
                    _status, _type, _rating,
                    _author, _artist, _releaseYear,
                    _isFeatured, _isPopular,
                    _selectedGenreIds.ToList(),
                    _selectedTagIds.ToList()));
                Snackbar.Add("Comic created successfully!", Severity.Success);
            }
            else
            {
                await Mediator.Send(new UpdateComicCommand(
                    Id, _title, _alternativeTitles, _description,
                    _coverImageUrl, _bannerImageUrl,
                    _status, _type, _rating,
                    _author, _artist, _releaseYear,
                    _isFeatured, _isPopular,
                    _selectedGenreIds.ToList(),
                    _selectedTagIds.ToList()));
                Snackbar.Add("Comic updated successfully!", Severity.Success);
            }
            Navigation.NavigateTo("/admin/comics");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }
}
