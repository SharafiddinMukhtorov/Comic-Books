@page "/admin/chapter-pricing"
@using ComicBooks.Application.Common.Interfaces
@layout AdminLayout
@inject IMediator Mediator
@inject IChapterPricingService PricingSvc
@inject ISnackbar Snackbar

<PageTitle>Bob narxlari - Admin</PageTitle>

<MudText Typo="Typo.h5" Class="mb-1">🔐 Bob narxlari</MudText>
<MudText Typo="Typo.body2" Style="opacity:0.5;margin-bottom:20px;">
    Qaysi boblar coin talab qilishini va narxini belgilang.
</MudText>

<MudPaper Class="pa-4 mb-4" Elevation="1" Style="border-radius:12px;">
    <MudSelect T="Guid?" Value="@_comicId" ValueChanged="ComicChanged"
               Label="Komik tanlang" Variant="Variant.Outlined" Clearable="true">
        @foreach (var c in _comics)
        {
            <MudSelectItem T="Guid?" Value="@c.Id">
                @c.Title (@c.ChapterCount bob)
            </MudSelectItem>
        }
    </MudSelect>
</MudPaper>

@if (_loadingChapters)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else if (_comicId.HasValue && _chapters.Any())
{
    <MudPaper Class="pa-4" Elevation="2" Style="border-radius:12px;">

        <!-- Quick Actions -->
        <div style="display:flex;gap:8px;align-items:center;margin-bottom:16px;flex-wrap:wrap;">
            <span style="font-size:13px;opacity:0.6;">Barchasiga:</span>

            <MudButton Size="Size.Small" Variant="Variant.Outlined" Style="text-transform:none;"
                       OnClick="SetAllFree">Bepul</MudButton>

            @foreach (int p in new[] { 5, 10, 20 })
            {
                <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Warning"
                           Style="text-transform:none;"
                           OnClick="@(() => SetAllPrice(p))">@p 🪙</MudButton>
            }

            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       OnClick="SaveAll" Disabled="@_saving"
                       Style="margin-left:auto;text-transform:none;">
                @(_saving ? "Saqlanmoqda..." : "✅ Hammasini saqlash")
            </MudButton>
        </div>

        <MudTable Items="@_chapters" Dense Hover Elevation="0">
            <HeaderContent>
                <MudTh>Bob</MudTh>
                <MudTh>Sarlavha</MudTh>
                <MudTh>Qulflangan</MudTh>
                <MudTh>Narx (coin)</MudTh>
            </HeaderContent>
            <RowTemplate Context="ch">
                <MudTd>
                    <MudChip T="string" Size="Size.Small" Color="Color.Primary">Ch.@ch.ChapterNumber</MudChip>
                </MudTd>
                <MudTd><span style="opacity:0.6;">@(ch.Title ?? "—")</span></MudTd>
                <MudTd>
                    <MudSwitch T="bool"
                               Checked="@ch.IsLocked"
                               CheckedChanged="@((bool v) => OnLockChanged(ch, v))"
                               Color="Color.Warning" />
                </MudTd>
                <MudTd>
                    @if (ch.IsLocked)
                    {
                        <MudNumericField T="int"
                                         Value="@ch.CoinPrice"
                                         ValueChanged="@((int v) => ch.CoinPrice = v)"
                                         Min="1" Max="999"
                                         Variant="Variant.Outlined"
                                         Margin="Margin.Dense"
                                         Adornment="Adornment.End"
                                         AdornmentText="🪙"
                                         Style="max-width:120px;" />
                    }
                    else
                    {
                        <span style="opacity:0.35;">Bepul</span>
                    }
                </MudTd>
            </RowTemplate>
        </MudTable>

        <div style="display:flex;justify-content:flex-end;margin-top:16px;">
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       OnClick="SaveAll" Disabled="@_saving" Style="text-transform:none;">
                @(_saving ? "Saqlanmoqda..." : "✅ Saqlash")
            </MudButton>
        </div>
    </MudPaper>
}
else if (_comicId.HasValue)
{
    <MudAlert Severity="Severity.Info">Bu komikda hali boblar yo'q.</MudAlert>
}

@code {
    List<ComicDto>             _comics   = new();
    List<ChapterPriceItemDto>  _chapters = new();
    Guid? _comicId;
    bool  _saving          = false;
    bool  _loadingChapters = false;

    protected override async Task OnInitializedAsync()
    {
        var r  = await Mediator.Send(new GetComicsQuery(PageSize: 500));
        _comics = r.Items;
    }

    async Task ComicChanged(Guid? id)
    {
        _comicId  = id;
        _chapters = new();
        if (!id.HasValue) return;

        _loadingChapters = true;
        StateHasChanged();
        _chapters        = await PricingSvc.GetChapterPricingByComicAsync(id.Value);
        _loadingChapters = false;
    }

    void OnLockChanged(ChapterPriceItemDto ch, bool isLocked)
    {
        ch.IsLocked = isLocked;
        if (!isLocked) ch.CoinPrice = 0;
    }

    void SetAllFree()
    {
        foreach (var ch in _chapters) { ch.IsLocked = false; ch.CoinPrice = 0; }
    }

    void SetAllPrice(int price)
    {
        foreach (var ch in _chapters) { ch.IsLocked = true; ch.CoinPrice = price; }
    }

    async Task SaveAll()
    {
        _saving = true;
        try
        {
            await PricingSvc.SaveChapterPricingAsync(_chapters);
            Snackbar.Add("✅ Saqlandi!", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add($"Xatolik: {ex.Message}", Severity.Error); }
        finally { _saving = false; }
    }
}
