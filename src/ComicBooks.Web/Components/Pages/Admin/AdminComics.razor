@page "/admin/comics"
@layout AdminLayout
@rendermode InteractiveServer
@inject IMediator Mediator
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IDialogService DialogSvc

<PageTitle>Komiklar - Admin</PageTitle>

<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;">
    <MudText Typo="Typo.h5" Class="font-bold">📚 Komiklar</MudText>
    <MudButton Href="/admin/comics/create" Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add"
               Style="border-radius:20px;text-transform:none;font-weight:700;">Yangi komik</MudButton>
</div>

<MudPaper Elevation="1" Class="pa-4 mb-4" Style="border-radius:12px;">
    <MudGrid>
        <MudItem xs="12" sm="8">
            <MudTextField @bind-Value="_search" Label="Qidirish..." Variant="Variant.Outlined"
                          Margin="Margin.Dense" Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          OnKeyDown="@HandleKey" />
        </MudItem>
        <MudItem xs="6" sm="2">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@Load"
                       FullWidth="true" Style="height:40px;text-transform:none;">Qidirish</MudButton>
        </MudItem>
        <MudItem xs="6" sm="2">
            <MudButton Variant="Variant.Outlined" OnClick="@Clear"
                       FullWidth="true" Style="height:40px;text-transform:none;">Tozalash</MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

@if (_loading)
{ <MudProgressLinear Color="Color.Primary" Indeterminate="true" /> }

<MudTable Items="@(_result?.Items)" Hover="true" Elevation="2"
          Style="border-radius:12px;" Loading="@_loading">
    <HeaderContent>
        <MudTh>Muqova</MudTh>
        <MudTh>Nomi</MudTh>
        <MudTh>Turi</MudTh>
        <MudTh>Holati</MudTh>
        <MudTh>Boblar</MudTh>
        <MudTh>Reyting</MudTh>
        <MudTh>Amallar</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd><MudAvatar Size="Size.Medium" Image="@(string.IsNullOrEmpty(context.CoverImageUrl) ? null : context.CoverImageUrl)" /></MudTd>
        <MudTd>
            <MudText Typo="Typo.body2" Style="font-weight:700;">@context.Title</MudText>
            <MudText Typo="Typo.caption" Style="opacity:0.5;">@context.Author</MudText>
        </MudTd>
        <MudTd><MudChip T="string" Size="Size.Small" Label="true">@context.Type</MudChip></MudTd>
        <MudTd>
            <MudChip T="string" Size="Size.Small" Label="true" Color="@GetColor(context.Status)">@StatusUz(context.Status)</MudChip>
        </MudTd>
        <MudTd>@context.ChapterCount</MudTd>
        <MudTd><span style="color:#f59e0b;font-weight:700;">★ @context.AverageRating.ToString("F1")</span></MudTd>
        <MudTd>
            <!-- Href navigation - no JS -->
            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                           Size="Size.Small" Color="Color.Primary"
                           Href="@($"/admin/comics/edit/{context.Id}")"
                           Title="Tahrirlash" />
            <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                           Size="Size.Small"
                           Href="@($"/comic/{context.Slug}")"
                           Title="Ko'rish" />
            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                           Size="Size.Small" Color="Color.Error"
                           OnClick="@(() => Delete(context))"
                           Title="O'chirish" />
        </MudTd>
    </RowTemplate>
    <NoRecordsContent><MudText Class="pa-4">Hech narsa topilmadi.</MudText></NoRecordsContent>
</MudTable>

@if (_result?.TotalPages > 1)
{
    <div class="d-flex justify-center mt-4">
        <MudPagination Count="@_result.TotalPages" Selected="@_page"
                       SelectedChanged="@OnPage" Color="Color.Primary" />
    </div>
}

@code {
    PaginatedList<ComicDto>? _result;
    string _search = "";
    bool _loading = true;
    int _page = 1;

    protected override async Task OnInitializedAsync() => await Load();

    async Task Load()
    {
        _loading = true;
        _result = await Mediator.Send(new GetComicsQuery(
            PageNumber: _page, PageSize: 20,
            Search: string.IsNullOrWhiteSpace(_search) ? null : _search));
        _loading = false;
    }

    async Task OnPage(int p) { _page = p; await Load(); }
    async Task HandleKey(KeyboardEventArgs e) { if (e.Key == "Enter") await Load(); }
    void Clear() { _search = ""; _page = 1; _ = Load(); }

    async Task Delete(ComicDto c)
    {
        var ok = await DialogSvc.ShowMessageBox("O'chirish",
            $"'{c.Title}' komikini o'chirasizmi?",
            yesText: "Ha, o'chir", cancelText: "Yo'q");
        if (ok == true)
        {
            await Mediator.Send(new DeleteComicCommand(c.Id));
            Snackbar.Add("O'chirildi", Severity.Success);
            await Load();
        }
    }

    Color GetColor(ComicStatus s) => s switch
    {
        ComicStatus.Ongoing   => Color.Success,
        ComicStatus.Completed => Color.Primary,
        ComicStatus.Hiatus    => Color.Warning,
        _                     => Color.Default
    };

    string StatusUz(ComicStatus s) => s switch
    {
        ComicStatus.Ongoing   => "Davom etmoqda",
        ComicStatus.Completed => "Tugallangan",
        ComicStatus.Hiatus    => "To'xtatilgan",
        _                     => s.ToString()
    };
}
