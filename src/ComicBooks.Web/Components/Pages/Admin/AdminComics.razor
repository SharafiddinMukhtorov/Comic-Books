@page "/admin/comics"
@layout AdminLayout
@inject IMediator Mediator
@inject ISnackbar Snackbar
@inject IDialogService DialogSvc

<PageTitle>Komiklar - Admin</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h5">📚 Komiklar</MudText>
    <MudSpacer />
    <MudButton Href="/admin/comics/create" Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add" Style="text-transform:none;">Yangi komik</MudButton>
</MudStack>

<MudPaper Class="pa-3 mb-4">
    <MudStack Row="true" Spacing="2">
        <MudTextField @bind-Value="_search" Label="Qidirish..." Variant="Variant.Outlined"
                      Margin="Margin.Dense" Style="flex:1" OnKeyDown="@OnKey" />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@Load" Style="text-transform:none;height:40px;">Qidirish</MudButton>
        <MudButton Variant="Variant.Outlined" OnClick="@Clear" Style="text-transform:none;height:40px;">Tozalash</MudButton>
    </MudStack>
</MudPaper>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}

<MudTable Items="@(_result?.Items ?? new())" Hover="true" Elevation="2" Loading="@_loading">
    <HeaderContent>
        <MudTh>Muqova</MudTh>
        <MudTh>Nomi</MudTh>
        <MudTh>Turi</MudTh>
        <MudTh>Holati</MudTh>
        <MudTh>Boblar</MudTh>
        <MudTh>Reyting</MudTh>
        <MudTh>Amallar</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd><MudAvatar Image="@context.CoverImageUrl" Size="Size.Medium" /></MudTd>
        <MudTd>
            <MudText Style="font-weight:700;">@context.Title</MudText>
            <MudText Typo="Typo.caption" Style="opacity:0.5;">@context.Author</MudText>
        </MudTd>
        <MudTd><MudChip T="string" Size="Size.Small" Label="true">@context.Type</MudChip></MudTd>
        <MudTd><MudChip T="string" Size="Size.Small" Label="true" Color="@StatusColor(context.Status)">@StatusText(context.Status)</MudChip></MudTd>
        <MudTd>@context.ChapterCount</MudTd>
        <MudTd><span style="color:#f59e0b;font-weight:700;">★ @context.AverageRating.ToString("F1")</span></MudTd>
        <MudTd>
            <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Href="@($"/comic/{context.Slug}")" />
            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary" Href="@($"/admin/comics/edit/{context.Id}")" />
            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => Delete(context))" />
        </MudTd>
    </RowTemplate>
    <NoRecordsContent><MudText Class="pa-4" Style="opacity:0.5;">Hech narsa topilmadi.</MudText></NoRecordsContent>
</MudTable>

@if ((_result?.TotalPages ?? 0) > 1)
{
    <MudStack AlignItems="AlignItems.Center" Class="mt-4">
        <MudPagination Count="@_result!.TotalPages" Selected="@_page" SelectedChanged="@OnPage" Color="Color.Primary" />
    </MudStack>
}

@code {
    PaginatedList<ComicDto>? _result;
    string _search = "";
    bool _loading = true;
    int _page = 1;

    protected override async Task OnInitializedAsync() => await Load();

    async Task Load()
    {
        _loading = true;
        _result = await Mediator.Send(new GetComicsQuery(PageNumber: _page, PageSize: 20,
            Search: string.IsNullOrWhiteSpace(_search) ? null : _search.Trim()));
        _loading = false;
    }

    async Task OnPage(int p) { _page = p; await Load(); }
    async Task OnKey(KeyboardEventArgs e) { if (e.Key == "Enter") { _page = 1; await Load(); } }
    void Clear() { _search = ""; _page = 1; _ = Load(); }

    async Task Delete(ComicDto c)
    {
        var ok = await DialogSvc.ShowMessageBox("O'chirish", $"'{c.Title}' ni o'chirasizmi?", yesText: "Ha", cancelText: "Yo'q");
        if (ok == true) { await Mediator.Send(new DeleteComicCommand(c.Id)); Snackbar.Add("O'chirildi", Severity.Success); await Load(); }
    }

    Color StatusColor(ComicStatus s) => s switch { ComicStatus.Ongoing => Color.Success, ComicStatus.Completed => Color.Primary, ComicStatus.Hiatus => Color.Warning, _ => Color.Default };
    string StatusText(ComicStatus s) => s switch { ComicStatus.Ongoing => "Davom etmoqda", ComicStatus.Completed => "Tugallangan", ComicStatus.Hiatus => "To'xtatilgan", _ => s.ToString() };
}
