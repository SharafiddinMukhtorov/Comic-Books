@page "/admin/genres"
@page "/admin/tags"
@layout AdminLayout
@rendermode InteractiveServer
@inject IMediator Mediator
@inject ISnackbar Snackbar
@inject IDialogService DialogSvc

<PageTitle>Janrlar & Teglar - Admin</PageTitle>
<MudText Typo="Typo.h5" Class="mb-4">🏷️ Janrlar va Teglar</MudText>

<MudGrid>
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4 mb-4">
            <MudText Typo="Typo.h6" Class="mb-3">Yangi janr</MudText>
            <MudTextField @bind-Value="_genreName" Label="Janr nomi" Variant="Variant.Outlined" Class="mb-2" />
            <MudTextField @bind-Value="_genreDesc" Label="Tavsif (ixtiyoriy)" Variant="Variant.Outlined" Class="mb-3" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@AddGenre" Style="text-transform:none;">Qo'shish</MudButton>
        </MudPaper>
        <MudTable Items="@_genres" Hover="true" Elevation="2" Dense="true">
            <HeaderContent><MudTh>Nomi</MudTh><MudTh>Komiklar</MudTh><MudTh></MudTh></HeaderContent>
            <RowTemplate>
                <MudTd>@context.Name</MudTd>
                <MudTd>@context.ComicCount</MudTd>
                <MudTd><MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteGenre(context))" /></MudTd>
            </RowTemplate>
        </MudTable>
    </MudItem>

    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4 mb-4">
            <MudText Typo="Typo.h6" Class="mb-3">Yangi teg</MudText>
            <MudStack Row="true" Spacing="2">
                <MudTextField @bind-Value="_tagName" Label="Teg nomi" Variant="Variant.Outlined" Style="flex:1" />
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@AddTag" Style="text-transform:none;height:56px;">Qo'shish</MudButton>
            </MudStack>
        </MudPaper>
        <MudTable Items="@_tags" Hover="true" Elevation="2" Dense="true">
            <HeaderContent><MudTh>Nomi</MudTh><MudTh>Komiklar</MudTh><MudTh></MudTh></HeaderContent>
            <RowTemplate>
                <MudTd>@context.Name</MudTd>
                <MudTd>@context.ComicCount</MudTd>
                <MudTd><MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteTag(context))" /></MudTd>
            </RowTemplate>
        </MudTable>
    </MudItem>
</MudGrid>

@code {
    List<GenreDto> _genres = new();
    List<TagDto>   _tags   = new();
    string _genreName = "", _genreDesc = "", _tagName = "";

    protected override async Task OnInitializedAsync() => await Load();

    async Task Load()
    {
        _genres = await Mediator.Send(new GetAllGenresQuery());
        _tags   = await Mediator.Send(new GetAllTagsQuery());
    }

    async Task AddGenre()
    {
        if (string.IsNullOrWhiteSpace(_genreName)) return;
        await Mediator.Send(new CreateGenreCommand(_genreName.Trim(), _genreDesc.Trim()));
        Snackbar.Add($"'{_genreName}' qo'shildi!", Severity.Success);
        _genreName = ""; _genreDesc = ""; await Load();
    }

    async Task DeleteGenre(GenreDto g)
    {
        var ok = await DialogSvc.ShowMessageBox("O'chirish", $"'{g.Name}' ni o'chirasizmi?", yesText: "Ha", cancelText: "Yo'q");
        if (ok == true) { await Mediator.Send(new DeleteGenreCommand(g.Id)); Snackbar.Add("O'chirildi", Severity.Success); await Load(); }
    }

    async Task AddTag()
    {
        if (string.IsNullOrWhiteSpace(_tagName)) return;
        await Mediator.Send(new CreateTagCommand(_tagName.Trim()));
        Snackbar.Add($"'{_tagName}' qo'shildi!", Severity.Success);
        _tagName = ""; await Load();
    }

    async Task DeleteTag(TagDto t)
    {
        var ok = await DialogSvc.ShowMessageBox("O'chirish", $"'{t.Name}' ni o'chirasizmi?", yesText: "Ha", cancelText: "Yo'q");
        if (ok == true) { await Mediator.Send(new DeleteTagCommand(t.Id)); Snackbar.Add("O'chirildi", Severity.Success); await Load(); }
    }
}
