@page "/admin/chapters"
@layout AdminLayout
@rendermode InteractiveServer
@inject IMediator Mediator
@inject ISnackbar Snackbar
@inject IDialogService DialogSvc

<PageTitle>Boblar - Admin</PageTitle>

@if (_showForm)
{
    <div style="margin-bottom:16px;">
        <MudButton Variant="Variant.Text"
                   StartIcon="@Icons.Material.Filled.ArrowBack"
                   OnClick="@(() => _showForm = false)"
                   Style="text-transform:none;">Orqaga</MudButton>
    </div>

    <MudText Typo="Typo.h5" Class="font-bold mb-5">Yangi bob qo'shish</MudText>

    <MudGrid>
        <MudItem xs="12" md="7">
            <MudPaper Elevation="2" Class="pa-5" Style="border-radius:12px;">
                <MudSelect T="Guid" @bind-Value="_comicId" Label="Komik *" Variant="Variant.Outlined" Class="mb-3">
                    @foreach (var c in _comics)
                    { <MudSelectItem T="Guid" Value="@c.Id">@c.Title</MudSelectItem> }
                </MudSelect>
                <MudNumericField T="double" @bind-Value="_chapNum" Label="Bob raqami *"
                                 Variant="Variant.Outlined" Class="mb-3" Min="0.1" Step="0.5" />
                <MudTextField @bind-Value="_chapTitle" Label="Sarlavha (ixtiyoriy)"
                              Variant="Variant.Outlined" Class="mb-3" />
                <MudSwitch T="bool" @bind-Value="_locked" Label="Qulflangan" Color="Color.Warning" Class="mb-3" />
                <MudText Typo="Typo.subtitle2" Class="mb-2">Sahifalar (URL, har qatorda bitta)</MudText>
                <MudTextField @bind-Value="_pageUrls" Lines="10" Variant="Variant.Outlined" Class="mb-4"
                              Placeholder="https://example.com/p1.jpg&#10;https://example.com/p2.jpg" />
                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                           Size="Size.Large" OnClick="@SaveChapter" Disabled="@_saving"
                           Style="border-radius:10px;text-transform:none;font-weight:700;">
                    @(_saving ? "Saqlanmoqda..." : "Bobni saqlash")
                </MudButton>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="5">
            <MudPaper Elevation="1" Class="pa-4" Style="border-radius:12px;">
                <MudText Typo="Typo.subtitle2" Class="mb-3">Ko'rsatmalar</MudText>
                <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2">Sahifalar bo'sh bo'lsa mock rasmlar qo'shiladi.</MudAlert>
                <MudAlert Severity="Severity.Info" Dense="true">Bob raqami o'nlik bo'lishi mumkin (1.5).</MudAlert>
            </MudPaper>
        </MudItem>
    </MudGrid>
}
else
{
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;">
        <MudText Typo="Typo.h5" Class="font-bold">📖 Boblar</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="@(() => _showForm = true)"
                   Style="border-radius:20px;text-transform:none;font-weight:700;">Bob qo'shish</MudButton>
    </div>

    <MudPaper Elevation="1" Class="pa-4 mb-4" Style="border-radius:12px;">
        <MudSelect T="Guid?"
                   Value="@_filterComicId"
                   ValueChanged="@FilterChanged"
                   Label="Komik tanlang"
                   Variant="Variant.Outlined"
                   Margin="Margin.Dense"
                   Clearable="true">
            @foreach (var c in _comics)
            { <MudSelectItem T="Guid?" Value="@((Guid?)c.Id)">@c.Title</MudSelectItem> }
        </MudSelect>
    </MudPaper>

    @if (_chapters.Any())
    {
        <MudTable Items="@_chapters" Hover="true" Elevation="2" Style="border-radius:12px;">
            <HeaderContent>
                <MudTh>Bob #</MudTh><MudTh>Sarlavha</MudTh><MudTh>Sahifalar</MudTh><MudTh>Ko'rishlar</MudTh><MudTh>Sana</MudTh><MudTh></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd><MudChip T="string" Color="Color.Primary" Size="Size.Small" Label="true">@context.ChapterNumber-bob</MudChip></MudTd>
                <MudTd>@(context.Title ?? "—")</MudTd>
                <MudTd>@context.PageCount bet</MudTd>
                <MudTd>@context.ViewCount.ToString("N0")</MudTd>
                <MudTd>@context.PublishedAt?.ToString("dd.MM.yyyy")</MudTd>
                <MudTd>
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                   OnClick="@(() => DelChapter(context))" />
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
    else
    {
        <MudAlert Severity="Severity.Info" Style="border-radius:12px;">
            @(_filterComicId.HasValue ? "Bu komikda boblar yo'q." : "Komik tanlang.")
        </MudAlert>
    }
}

@code {
    List<ComicDto> _comics = new();
    List<ChapterDto> _chapters = new();
    Guid? _filterComicId;
    bool _showForm, _saving;
    string _pageUrls = "";
    Guid _comicId; double _chapNum = 1; string? _chapTitle; bool _locked;

    protected override async Task OnInitializedAsync()
    {
        var r = await Mediator.Send(new GetComicsQuery(PageSize: 200));
        _comics = r.Items;
    }

    async Task FilterChanged(Guid? id)
    {
        _filterComicId = id;
        _chapters = id.HasValue ? await Mediator.Send(new GetChaptersByComicQuery(id.Value)) : new();
    }

    async Task SaveChapter()
    {
        if (_comicId == Guid.Empty) { Snackbar.Add("Komik tanlang!", Severity.Warning); return; }
        if (_chapNum <= 0)          { Snackbar.Add("Bob raqamini kiriting!", Severity.Warning); return; }

        var urls = _pageUrls.Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                            .Where(u => u.StartsWith("http")).ToList();
        if (!urls.Any())
            urls = Enumerable.Range(1, 20)
                .Select(i => $"https://picsum.photos/seed/ch{_comicId}-{_chapNum}-{i}/800/1200").ToList();

        _saving = true;
        try
        {
            var pages = urls.Select((u, i) => new CreateChapterPageDto(i + 1, u, null, null)).ToList();
            await Mediator.Send(new CreateChapterCommand(_comicId, _chapNum, _chapTitle, null, _locked, DateTime.UtcNow, pages));
            Snackbar.Add("Bob qo'shildi ✅", Severity.Success);
            _comicId = Guid.Empty; _chapNum = 1; _chapTitle = null; _locked = false; _pageUrls = "";
            _showForm = false;
        }
        catch (Exception ex) { Snackbar.Add($"Xatolik: {ex.Message}", Severity.Error); }
        finally { _saving = false; }
    }

    async Task DelChapter(ChapterDto ch)
    {
        var ok = await DialogSvc.ShowMessageBox("O'chirish", $"{ch.ChapterNumber}-bobni o'chirasizmi?", yesText: "Ha", cancelText: "Yo'q");
        if (ok == true)
        {
            await Mediator.Send(new DeleteChapterCommand(ch.Id));
            Snackbar.Add("O'chirildi", Severity.Success);
            if (_filterComicId.HasValue)
                _chapters = await Mediator.Send(new GetChaptersByComicQuery(_filterComicId.Value));
        }
    }
}
