@page "/admin/chapters"
@layout AdminLayout
@rendermode InteractiveServer
@inject IMediator Mediator
@inject ISnackbar Snackbar
@inject IDialogService DialogSvc

<PageTitle>Boblar - Admin</PageTitle>
<MudText Typo="Typo.h5" Class="mb-4">📖 Boblar</MudText>

<MudGrid>
    <!-- ADD FORM -->
    <MudItem xs="12" md="5">
        <MudPaper Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-3">Bob qo'shish</MudText>

            <MudSelect T="Guid" @bind-Value="_comicId" Label="Komik *" Variant="Variant.Outlined" Class="mb-3">
                @foreach (var c in _comics)
                { <MudSelectItem T="Guid" Value="@c.Id">@c.Title</MudSelectItem> }
            </MudSelect>

            <MudNumericField T="double" @bind-Value="_chapNum" Label="Bob raqami *" Variant="Variant.Outlined" Class="mb-3" Min="0.1" Step="1" />
            <MudTextField @bind-Value="_chapTitle" Label="Sarlavha (ixtiyoriy)" Variant="Variant.Outlined" Class="mb-3" />
            <MudCheckBox T="bool" @bind-Checked="_locked" Label="Qulflangan" Color="Color.Warning" Class="mb-3" />
            <MudTextField @bind-Value="_pageUrls" Label="Sahifalar (har qatorda URL)" Lines="6" Variant="Variant.Outlined" Class="mb-3"
                          HelperText="Bo'sh qoldirsangiz mock rasmlar qo'shiladi" />

            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                       OnClick="@AddChapter" Disabled="@_saving" Style="text-transform:none;height:46px;">
                @(_saving ? "Qo'shilmoqda..." : "Bob qo'shish")
            </MudButton>
        </MudPaper>
    </MudItem>

    <!-- CHAPTER LIST -->
    <MudItem xs="12" md="7">
        <MudPaper Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-3">Boblar ro'yxati</MudText>
            <MudSelect T="Guid?" Value="@_filterComicId" ValueChanged="@FilterChanged"
                       Label="Komik tanlang" Variant="Variant.Outlined" Class="mb-3" Clearable="true">
                @foreach (var c in _comics)
                { <MudSelectItem T="Guid?" Value="@((Guid?)c.Id)">@c.Title (@c.ChapterCount bob)</MudSelectItem> }
            </MudSelect>

            @if (_filterComicId.HasValue)
            {
                @if (_loadingChapters)
                {
                    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                }
                else if (_chapters.Any())
                {
                    <MudTable Items="@_chapters" Hover="true" Dense="true" Elevation="0">
                        <HeaderContent>
                            <MudTh>Bob</MudTh><MudTh>Sarlavha</MudTh><MudTh>Betlar</MudTh><MudTh></MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd><MudChip T="string" Size="Size.Small" Color="Color.Primary" Label="true">@context.ChapterNumber</MudChip></MudTd>
                            <MudTd>@(context.Title ?? "—")</MudTd>
                            <MudTd>@context.PageCount</MudTd>
                            <MudTd>
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DelChapter(context))" />
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
                else
                {
                    <MudText Style="opacity:0.5;">Bu komikda boblar yo'q.</MudText>
                }
            }
            else
            {
                <MudText Style="opacity:0.4;">Boblarni ko'rish uchun komik tanlang.</MudText>
            }
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    List<ComicDto>   _comics  = new();
    List<ChapterDto> _chapters = new();
    Guid?  _filterComicId;
    Guid   _comicId = Guid.Empty;
    double _chapNum = 1;
    string? _chapTitle;
    bool   _locked;
    string _pageUrls = "";
    bool   _saving;
    bool   _loadingChapters;

    protected override async Task OnInitializedAsync()
    {
        var r = await Mediator.Send(new GetComicsQuery(PageSize: 500));
        _comics = r.Items;
    }

    async Task FilterChanged(Guid? id)
    {
        _filterComicId = id;
        _chapters = new();
        if (id.HasValue)
        {
            _loadingChapters = true;
            StateHasChanged();
            _chapters = await Mediator.Send(new GetChaptersByComicQuery(id.Value));
            _loadingChapters = false;
        }
    }

    async Task AddChapter()
    {
        if (_comicId == Guid.Empty) { Snackbar.Add("Komik tanlang!", Severity.Warning); return; }
        if (_chapNum <= 0) { Snackbar.Add("Bob raqami kiritilmagan!", Severity.Warning); return; }

        var urls = _pageUrls.Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                            .Where(u => u.StartsWith("http")).ToList();
        if (!urls.Any())
            urls = Enumerable.Range(1, 20).Select(i => $"https://picsum.photos/seed/{_comicId}-{(int)_chapNum}-{i}/800/1200").ToList();

        _saving = true;
        try
        {
            var pages = urls.Select((u, i) => new CreateChapterPageDto(i + 1, u, null, null)).ToList();
            await Mediator.Send(new CreateChapterCommand(_comicId, _chapNum, _chapTitle, null, _locked, DateTime.UtcNow, pages));
            Snackbar.Add("✅ Bob qo'shildi!", Severity.Success);
            _chapTitle = null; _chapNum = 1; _locked = false; _pageUrls = "";
            if (_filterComicId == _comicId)
                _chapters = await Mediator.Send(new GetChaptersByComicQuery(_comicId));
        }
        catch (Exception ex) { Snackbar.Add($"Xatolik: {ex.Message}", Severity.Error); }
        finally { _saving = false; }
    }

    async Task DelChapter(ChapterDto ch)
    {
        var ok = await DialogSvc.ShowMessageBox("O'chirish", $"{ch.ChapterNumber}-bobni o'chirasizmi?", yesText: "Ha", cancelText: "Yo'q");
        if (ok == true)
        {
            await Mediator.Send(new DeleteChapterCommand(ch.Id));
            Snackbar.Add("O'chirildi", Severity.Success);
            if (_filterComicId.HasValue)
                _chapters = await Mediator.Send(new GetChaptersByComicQuery(_filterComicId.Value));
        }
    }
}
