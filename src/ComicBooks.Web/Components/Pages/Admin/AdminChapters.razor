@page "/admin/chapters"
@layout AdminLayout
@rendermode InteractiveServer
@inject IMediator Mediator
@inject ISnackbar Snackbar
@inject IDialogService DialogSvc

<PageTitle>Boblar - Admin</PageTitle>

<MudBreadcrumbs Items="_crumbs" Class="mb-4 pa-0" />

@if (_showForm)
{
    <MudText Typo="Typo.h5" Class="font-bold mb-5">📖 Yangi bob qo'shish</MudText>

    <MudGrid>
        <MudItem xs="12" md="7">
            <MudPaper Elevation="2" Class="pa-5" Style="border-radius:12px;">

                <MudSelect T="Guid"
                           @bind-Value="_comicId"
                           Label="Komik tanlang *"
                           Variant="Variant.Outlined"
                           AnchorOrigin="Origin.BottomLeft"
                           Class="mb-4">
                    @foreach (var c in _allComics)
                    {
                        <MudSelectItem T="Guid" Value="@c.Id">@c.Title</MudSelectItem>
                    }
                </MudSelect>

                <MudNumericField T="double"
                                 @bind-Value="_chapNum"
                                 Label="Bob raqami *"
                                 Variant="Variant.Outlined"
                                 Class="mb-4"
                                 Min="0.1"
                                 Step="0.5"
                                 HideSpinButtons="false" />

                <MudTextField @bind-Value="_chapTitle"
                              Label="Sarlavha (ixtiyoriy)"
                              Variant="Variant.Outlined"
                              Class="mb-4" />

                <MudSwitch T="bool"
                           @bind-Value="_locked"
                           Label="Qulflangan (premium)"
                           Color="Color.Warning"
                           Class="mb-4" />

                <MudText Typo="Typo.subtitle2" Class="mb-2" Style="font-weight:600;">
                    📄 Sahifalar — har bir qatorda bitta URL
                </MudText>
                <MudTextField @bind-Value="_pageUrls"
                              Lines="10"
                              Variant="Variant.Outlined"
                              Class="mb-4"
                              Placeholder="https://cdn.example.com/page1.jpg&#10;https://cdn.example.com/page2.jpg&#10;..."
                              HelperText="Bo'sh qoldirsangiz, mock rasmlar avtomatik qo'shiladi" />

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Size="Size.Large"
                           OnClick="@SaveChapter"
                           Disabled="@_saving"
                           Style="border-radius:10px;text-transform:none;font-weight:700;height:50px;">
                    @if (_saving)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        <span>Saqlanmoqda...</span>
                    }
                    else { <span>Bobni saqlash</span> }
                </MudButton>
                <MudButton Variant="Variant.Text"
                           FullWidth="true"
                           Class="mt-2"
                           OnClick="@(() => _showForm = false)"
                           Style="text-transform:none;">
                    Bekor qilish
                </MudButton>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="5">
            <MudPaper Elevation="1" Class="pa-4" Style="border-radius:12px;">
                <MudText Typo="Typo.subtitle1" Class="mb-3 font-bold">💡 Ko'rsatmalar</MudText>
                <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2">
                    Sahifalar bo'sh qoldirilsa, mock rasmlar avtomatik qo'shiladi.
                </MudAlert>
                <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2">
                    Bob raqami kasr bo'lishi mumkin (masalan 1.5 — maxsus bob uchun).
                </MudAlert>
                <MudAlert Severity="Severity.Success" Dense="true">
                    URL'lar http:// yoki https:// bilan boshlanishi kerak.
                </MudAlert>
            </MudPaper>
        </MudItem>
    </MudGrid>
}
else
{
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;">
        <MudText Typo="Typo.h5" Class="font-bold">📖 Boblar boshqaruvi</MudText>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="@(() => _showForm = true)"
                   Style="border-radius:20px;text-transform:none;font-weight:700;">
            Bob qo'shish
        </MudButton>
    </div>

    <MudPaper Elevation="1" Class="pa-4 mb-4" Style="border-radius:12px;">
        <MudText Typo="Typo.subtitle2" Class="mb-2">Komik bo'yicha filtrlash</MudText>
        <MudSelect T="Guid?"
                   Value="@_filterComicId"
                   ValueChanged="@FilterChanged"
                   Label="Komik tanlang..."
                   Variant="Variant.Outlined"
                   Margin="Margin.Dense"
                   AnchorOrigin="Origin.BottomLeft"
                   Clearable="true">
            @foreach (var c in _allComics)
            {
                <MudSelectItem T="Guid?" Value="@((Guid?)c.Id)">
                    @c.Title (@c.ChapterCount bob)
                </MudSelectItem>
            }
        </MudSelect>
    </MudPaper>

    @if (_filterComicId.HasValue)
    {
        @if (_loading)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
        }
        else if (_chapters.Any())
        {
            <MudTable Items="@_chapters" Hover="true" Elevation="2" Style="border-radius:12px;">
                <ToolBarContent>
                    <MudText Typo="Typo.h6">@_chapters.Count ta bob</MudText>
                </ToolBarContent>
                <HeaderContent>
                    <MudTh>Bob #</MudTh>
                    <MudTh>Sarlavha</MudTh>
                    <MudTh>Sahifalar</MudTh>
                    <MudTh>Ko'rishlar</MudTh>
                    <MudTh>Holat</MudTh>
                    <MudTh>Sana</MudTh>
                    <MudTh>Amallar</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>
                        <MudChip T="string" Color="Color.Primary" Size="Size.Small" Label="true">
                            @context.ChapterNumber-bob
                        </MudChip>
                    </MudTd>
                    <MudTd>@(context.Title ?? "—")</MudTd>
                    <MudTd>@context.PageCount bet</MudTd>
                    <MudTd>@context.ViewCount.ToString("N0")</MudTd>
                    <MudTd>
                        @if (context.IsLocked)
                        { <MudIcon Icon="@Icons.Material.Filled.Lock" Color="Color.Warning" Size="Size.Small" /> }
                        else
                        { <MudIcon Icon="@Icons.Material.Filled.LockOpen" Size="Size.Small" Style="opacity:0.3;" /> }
                    </MudTd>
                    <MudTd>@context.PublishedAt?.ToString("dd.MM.yyyy")</MudTd>
                    <MudTd>
                        <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                       Size="Size.Small"
                                       Href="@($"/chapter/{context.Id}")"
                                       Title="Ko'rish" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Size="Size.Small"
                                       Color="Color.Error"
                                       OnClick="@(() => DelChapter(context))"
                                       Title="O'chirish" />
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
        else
        {
            <MudAlert Severity="Severity.Info" Style="border-radius:12px;">Bu komikda hali boblar yo'q.</MudAlert>
        }
    }
    else
    {
        <MudPaper Elevation="0" Class="pa-8 text-center" Style="border:2px dashed rgba(124,58,237,0.3);border-radius:14px;">
            <MudIcon Icon="@Icons.Material.Filled.AutoStories" Style="font-size:48px;opacity:0.3;" />
            <MudText Class="mt-3" Style="opacity:0.5;">Boblarni ko'rish uchun yuqoridan komik tanlang</MudText>
        </MudPaper>
    }
}

@code {
    private readonly List<BreadcrumbItem> _crumbs = new()
    {
        new("Admin", "/admin"),
        new("Boblar", "#", disabled: true)
    };

    private List<ComicDto> _allComics = new();
    private List<ChapterDto> _chapters = new();
    private Guid? _filterComicId;
    private bool _showForm;
    private bool _saving;
    private bool _loading;
    private string _pageUrls = "";
    private Guid _comicId = Guid.Empty;
    private double _chapNum = 1;
    private string? _chapTitle;
    private bool _locked;

    protected override async Task OnInitializedAsync()
    {
        var r = await Mediator.Send(new GetComicsQuery(PageSize: 200));
        _allComics = r.Items;
    }

    private async Task FilterChanged(Guid? id)
    {
        _filterComicId = id;
        _chapters = new();
        if (id.HasValue)
        {
            _loading = true;
            StateHasChanged();
            _chapters = await Mediator.Send(new GetChaptersByComicQuery(id.Value));
            _loading = false;
        }
    }

    private async Task SaveChapter()
    {
        if (_comicId == Guid.Empty) { Snackbar.Add("Komik tanlang!", Severity.Warning); return; }
        if (_chapNum <= 0) { Snackbar.Add("Bob raqamini kiriting!", Severity.Warning); return; }

        var urls = _pageUrls
            .Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(u => u.StartsWith("http"))
            .ToList();

        if (!urls.Any())
            urls = Enumerable.Range(1, 22)
                .Select(i => $"https://picsum.photos/seed/{_comicId}-{(int)_chapNum}-{i}/800/1200")
                .ToList();

        _saving = true;
        try
        {
            var pages = urls.Select((u, i) => new CreateChapterPageDto(i + 1, u, null, null)).ToList();
            await Mediator.Send(new CreateChapterCommand(
                _comicId, _chapNum, _chapTitle, null, _locked, DateTime.UtcNow, pages));

            Snackbar.Add($"✅ {(int)_chapNum}-bob muvaffaqiyatli qo'shildi!", Severity.Success);
            _comicId = Guid.Empty; _chapNum = 1; _chapTitle = null;
            _locked = false; _pageUrls = "";
            _showForm = false;

            // Refresh chapter list if filter is set
            if (_filterComicId.HasValue)
                _chapters = await Mediator.Send(new GetChaptersByComicQuery(_filterComicId.Value));
        }
        catch (Exception ex) { Snackbar.Add($"❌ Xatolik: {ex.Message}", Severity.Error); }
        finally { _saving = false; }
    }

    private async Task DelChapter(ChapterDto ch)
    {
        var ok = await DialogSvc.ShowMessageBox(
            "O'chirishni tasdiqlash",
            $"{ch.ChapterNumber}-bobni o'chirasizmi? Bu amalni qaytarib bo'lmaydi.",
            yesText: "Ha, o'chir",
            cancelText: "Bekor qilish");

        if (ok == true)
        {
            await Mediator.Send(new DeleteChapterCommand(ch.Id));
            Snackbar.Add("✅ Bob o'chirildi", Severity.Success);
            if (_filterComicId.HasValue)
                _chapters = await Mediator.Send(new GetChaptersByComicQuery(_filterComicId.Value));
        }
    }
}
