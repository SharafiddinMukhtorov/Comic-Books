@inject NavigationManager Nav
@inject BookmarkService BookmarkSvc

<div class="comic-card" style="cursor:pointer; border-radius:10px; overflow:hidden; transition:transform 0.2s, box-shadow 0.2s;"
     @onclick="@Go">
    <div style="position:relative; aspect-ratio:2/3; background:#1a1a2e; overflow:hidden; border-radius:10px 10px 0 0;">

        <img src="@Cover()"
             alt="@Comic.Title"
             style="width:100%; height:100%; object-fit:cover; display:block; transition:transform 0.3s;"
             loading="lazy"
             onerror="this.onerror=null; this.src='https://placehold.co/300x420/1a1a2e/7c3aed?text=@(Uri.EscapeDataString(Comic.Title.Length > 12 ? Comic.Title[..12] : Comic.Title))'" />

        <!-- Status badge -->
        <span style="position:absolute; top:7px; left:7px; z-index:2;
                     @BadgeStyle()
                     font-size:10px; font-weight:700; padding:2px 8px; border-radius:8px;">
            @StatusUz()
        </span>

        <!-- Type badge -->
        <span style="position:absolute; top:7px; right:30px; z-index:2;
                     background:rgba(0,0,0,0.65); color:#fff;
                     font-size:10px; font-weight:600; padding:2px 7px; border-radius:8px;">
            @Comic.Type
        </span>

        <!-- Bookmark button — stopPropagation prevents card click -->
        <span style="position:absolute; top:2px; right:2px; z-index:4;"
              @onclick:stopPropagation="true"
              @onclick="@Bookmark">
            <MudIconButton Size="Size.Small"
                           Icon="@(BookmarkSvc.IsBookmarked(Comic.Id) ? Icons.Material.Filled.Bookmark : Icons.Material.Outlined.BookmarkBorder)"
                           Style="@(BookmarkSvc.IsBookmarked(Comic.Id) ? "color:#7c3aed; padding:4px;" : "color:rgba(255,255,255,0.8); padding:4px;")" />
        </span>

        <!-- Chapter overlay -->
        @if (Comic.LatestChapterNumber.HasValue)
        {
            <div style="position:absolute; bottom:0; left:0; right:0; z-index:1;
                        background:linear-gradient(transparent, rgba(0,0,0,0.88));
                        padding:18px 8px 6px;">
                <span style="color:#a78bfa; font-size:11px; font-weight:700;">
                    @Comic.LatestChapterNumber-bob
                </span>
            </div>
        }
    </div>

    <!-- Info -->
    <div style="padding:8px 6px 6px;">
        <div style="font-size:12px; font-weight:700; line-height:1.4;
                    overflow:hidden; display:-webkit-box; -webkit-line-clamp:2;
                    -webkit-box-orient:vertical; min-height:33px; margin-bottom:3px;">
            @Comic.Title
        </div>
        <div style="display:flex; align-items:center; gap:3px;">
            <span style="color:#f59e0b; font-size:12px;">★</span>
            <span style="font-size:11px; font-weight:600; opacity:0.85;">@Comic.AverageRating.ToString("F1")</span>
            <span style="font-size:10px; opacity:0.4; margin-left:3px;">@Views()</span>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public ComicDto Comic { get; set; } = default!;

    void Go() => Nav.NavigateTo($"/comic/{Comic.Slug}");
    void Bookmark() => BookmarkSvc.Toggle(Comic.Id);
    string Cover() => !string.IsNullOrEmpty(Comic.CoverImageUrl) ? Comic.CoverImageUrl
                      : $"https://picsum.photos/seed/{Comic.Slug}/300/420";
    string Views() => Comic.ViewCount >= 1_000_000 ? $"{Comic.ViewCount/1_000_000.0:F1}M"
                    : Comic.ViewCount >= 1_000 ? $"{Comic.ViewCount/1_000}K" : Comic.ViewCount.ToString();

    string BadgeStyle() => Comic.Status switch
    {
        ComicStatus.Ongoing   => "background:#059669; color:#fff;",
        ComicStatus.Completed => "background:#7c3aed; color:#fff;",
        ComicStatus.Hiatus    => "background:#d97706; color:#fff;",
        ComicStatus.Cancelled => "background:#dc2626; color:#fff;",
        _                     => "background:#4b5563; color:#fff;"
    };

    string StatusUz() => Comic.Status switch
    {
        ComicStatus.Ongoing   => "Davom etmoqda",
        ComicStatus.Completed => "Tugallangan",
        ComicStatus.Hiatus    => "To'xtatilgan",
        _                     => Comic.Status.ToString()
    };
}
