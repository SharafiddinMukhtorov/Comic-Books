@using ComicBooks.Application.Common.Mappings
@using ComicBooks.Domain.Enums

<MudCard Class="comic-card h-100" Elevation="2" Style="cursor:pointer; transition: transform 0.2s, box-shadow 0.2s;"
         @onclick="@(() => Navigation.NavigateTo($"/comic/{Comic.Slug}"))">
    <div style="position:relative; overflow:hidden; aspect-ratio:2/3;">
        <MudImage Src="@(Comic.CoverImageUrl ?? "https://placehold.co/300x420/1a1a2e/e94560?text=No+Cover")"
                  Alt="@Comic.Title"
                  ObjectFit="ObjectFit.Cover"
                  Width="100%"
                  Height="100%"
                  Style="transition: transform 0.3s;" />

        <!-- Status badge -->
        <MudChip T="string"
                 Label="true"
                 Size="Size.Small"
                 Color="@GetStatusColor(Comic.Status)"
                 Style="position:absolute; top:6px; left:6px; font-size:10px; height:20px;">
            @Comic.Status.ToString()
        </MudChip>

        <!-- Type badge -->
        <MudChip T="string"
                 Label="true"
                 Size="Size.Small"
                 Color="Color.Dark"
                 Style="position:absolute; top:6px; right:6px; font-size:10px; height:20px; opacity:0.9;">
            @Comic.Type.ToString()
        </MudChip>

        <!-- Chapter overlay -->
        @if (Comic.LatestChapterNumber.HasValue)
        {
            <div style="position:absolute; bottom:0; left:0; right:0; background:linear-gradient(transparent,rgba(0,0,0,0.85)); padding:8px 6px 6px;">
                <MudText Typo="Typo.caption" Style="color:#e94560; font-weight:600;">
                    Ch. @Comic.LatestChapterNumber
                </MudText>
            </div>
        }
    </div>

    <MudCardContent Style="padding:8px;">
        <MudText Typo="Typo.body2"
                 Style="font-weight:600; line-height:1.3; overflow:hidden; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical;">
            @Comic.Title
        </MudText>

        @if (Comic.AverageRating > 0)
        {
            <div class="d-flex align-center mt-1">
                <MudIcon Icon="@Icons.Material.Filled.Star" Color="Color.Warning" Size="Size.Small" Style="font-size:14px;" />
                <MudText Typo="Typo.caption" Class="ml-1">@Comic.AverageRating.ToString("F1")</MudText>
                <MudText Typo="Typo.caption" Class="ml-2" Style="opacity:0.6;">
                    @FormatViews(Comic.ViewCount)
                </MudText>
            </div>
        }
    </MudCardContent>
</MudCard>

@code {
    [Parameter, EditorRequired] public ComicDto Comic { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private Color GetStatusColor(ComicStatus status) => status switch
    {
        ComicStatus.Ongoing => Color.Success,
        ComicStatus.Completed => Color.Primary,
        ComicStatus.Hiatus => Color.Warning,
        ComicStatus.Cancelled => Color.Error,
        _ => Color.Default
    };

    private string FormatViews(int views) => views switch
    {
        >= 1000000 => $"{views / 1000000.0:F1}M",
        >= 1000 => $"{views / 1000.0:F0}K",
        _ => views.ToString()
    };
}
