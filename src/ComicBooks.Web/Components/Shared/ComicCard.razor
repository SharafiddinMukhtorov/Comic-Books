@inject NavigationManager Nav
@inject BookmarkService BookmarkSvc

<div class="comic-card" @onclick="@GoToComic">
    <div style="position:relative; overflow:hidden; border-radius:10px 10px 0 0; aspect-ratio:2/3; background:#1a1a2e;">
        <img src="@CoverUrl()"
             alt="@Comic.Title"
             style="width:100%; height:100%; object-fit:cover; display:block; transition:transform 0.3s;"
             loading="lazy"
             onerror="this.onerror=null;this.src='https://via.placeholder.com/300x420/1a1a2e/7c3aed?text=@Uri.EscapeDataString(Comic.Title)'" />

        <!-- Status -->
        <div style="position:absolute; top:6px; left:6px; z-index:2;">
            <span style="@StatusBadge() font-size:10px; font-weight:700; padding:2px 7px; border-radius:8px; text-transform:uppercase; letter-spacing:0.3px;">
                @StatusText()
            </span>
        </div>

        <!-- Type -->
        <div style="position:absolute; top:6px; right:28px; z-index:2;">
            <span style="background:rgba(0,0,0,0.65); color:#fff; font-size:10px; font-weight:600; padding:2px 7px; border-radius:8px;">
                @Comic.Type
            </span>
        </div>

        <!-- Bookmark -->
        <div style="position:absolute; top:2px; right:2px; z-index:3;" @onclick:stopPropagation="true">
            <MudIconButton Size="Size.Small"
                           Icon="@(BookmarkSvc.IsBookmarked(Comic.Id) ? Icons.Material.Filled.Bookmark : Icons.Material.Outlined.BookmarkBorder)"
                           Style="@(BookmarkSvc.IsBookmarked(Comic.Id) ? "color:#7c3aed; padding:4px;" : "color:rgba(255,255,255,0.75); padding:4px;")"
                           OnClick="@(() => BookmarkSvc.Toggle(Comic.Id))" />
        </div>

        <!-- Latest chapter -->
        @if (Comic.LatestChapterNumber.HasValue)
        {
            <div style="position:absolute; bottom:0; left:0; right:0; background:linear-gradient(transparent,rgba(0,0,0,0.88)); padding:20px 8px 6px; z-index:1;">
                <span style="color:#a78bfa; font-size:11px; font-weight:700;">@Comic.LatestChapterNumber-bob</span>
            </div>
        }
    </div>

    <div style="padding:8px 4px 6px;">
        <div style="font-size:12px; font-weight:700; line-height:1.4; overflow:hidden; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; margin-bottom:3px; min-height:34px;">
            @Comic.Title
        </div>
        <div style="display:flex; align-items:center; gap:4px;">
            <span style="color:#f59e0b; font-size:12px;">★</span>
            <span style="font-size:11px; font-weight:600; opacity:0.85;">@Comic.AverageRating.ToString("F1")</span>
            <span style="font-size:10px; opacity:0.45; margin-left:2px;">· @FormatViews(Comic.ViewCount)</span>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public ComicDto Comic { get; set; } = default!;

    private void GoToComic() => Nav.NavigateTo($"/comic/{Comic.Slug}");

    private string CoverUrl() =>
        !string.IsNullOrEmpty(Comic.CoverImageUrl)
            ? Comic.CoverImageUrl
            : $"https://picsum.photos/seed/{Comic.Slug}/300/420";

    private string StatusBadge() => Comic.Status switch
    {
        ComicStatus.Ongoing    => "background:#059669; color:#fff;",
        ComicStatus.Completed  => "background:#7c3aed; color:#fff;",
        ComicStatus.Hiatus     => "background:#d97706; color:#fff;",
        ComicStatus.Cancelled  => "background:#dc2626; color:#fff;",
        _                      => "background:#4b5563; color:#fff;"
    };

    private string StatusText() => Comic.Status switch
    {
        ComicStatus.Ongoing   => "Davom etmoqda",
        ComicStatus.Completed => "Tugallangan",
        ComicStatus.Hiatus    => "To'xtatilgan",
        ComicStatus.Cancelled => "Bekor qilingan",
        _                     => Comic.Status.ToString()
    };

    private string FormatViews(int v) =>
        v >= 1_000_000 ? $"{v / 1_000_000.0:F1}M" :
        v >= 1_000     ? $"{v / 1_000}K" : v.ToString();
}
